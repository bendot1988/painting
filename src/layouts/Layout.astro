---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'A.S Painting Contractors — Commercial & Domestic Painters in Leicester',
  description = 'Leicester-based painting & decorating contractors. Commercial fit-outs, factories and offices. Domestic interiors and exteriors. Quality work, on time, on budget. Free quotes — 7 days a week.'
} = Astro.props;
import '~/styles/global.css';
import ContactFab from '~/components/ContactFab.astro';
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0e0e10" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/brand/icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/brand/logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'PaintingService',
      name: 'A.S Painting Contractors',
      image: 'https://www.as-painting.co.uk/wp-content/uploads/2021/07/A.S-Painting-Contractors-2.png',
      telephone: ['+441162914746','+448000096694'],
      areaServed: ['Leicester','Leicestershire','East Midlands'],
      address: { '@type': 'PostalAddress', addressLocality: 'Leicester', postalCode: 'LE19 4DG', addressCountry: 'GB' },
      priceRange: '££',
      openingHours: 'Mo-Su 06:00-17:00'
    })} />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <slot />
    <ContactFab />

    <script>
      // Reveal-on-scroll
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // Sticky header shadow on scroll
      const header = document.querySelector('[data-header]');
      const onScroll = () => {
        if (!header) return;
        if (window.scrollY > 8) header.classList.add('is-scrolled');
        else header.classList.remove('is-scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Mobile nav toggle
      const navToggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
      const nav = document.querySelector<HTMLElement>('[data-nav]');
      const navClose = nav?.querySelector<HTMLButtonElement>('[data-nav-close]');
      const navBackdrop = nav?.querySelector<HTMLElement>('[data-nav-backdrop]');

      const setNavOpen = (open: boolean) => {
        if (!nav || !navToggle) return;
        nav.classList.toggle('is-open', open);
        document.body.classList.toggle('nav-is-open', open);
        navToggle.setAttribute('aria-expanded', String(open));
        navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        document.body.style.overflow = open ? 'hidden' : '';
        navBackdrop?.setAttribute('aria-hidden', String(!open));
        if (open) {
          const fab = document.querySelector('[data-contact-fab]');
          fab?.classList.remove('is-open');
          const fabMenu = fab?.querySelector<HTMLElement>('[data-contact-menu]');
          const fabToggle = fab?.querySelector<HTMLButtonElement>('[data-contact-toggle]');
          if (fabMenu) fabMenu.hidden = true;
          fabToggle?.setAttribute('aria-expanded', 'false');
          fabToggle?.setAttribute('aria-label', 'Open contact options');
        }
      };

      navToggle?.addEventListener('click', () => {
        setNavOpen(!nav?.classList.contains('is-open'));
      });
      navClose?.addEventListener('click', () => setNavOpen(false));
      navBackdrop?.addEventListener('click', () => setNavOpen(false));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && nav?.classList.contains('is-open')) setNavOpen(false);
      });
      nav?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setNavOpen(false));
      });

      // Highlight nav bubble for the section in view
      const navLinks = nav?.querySelectorAll<HTMLAnchorElement>('.nav a');
      const sectionIds = ['commercial', 'domestic', 'work', 'reviews', 'quote'];
      const setActiveNav = () => {
        if (!navLinks?.length) return;

        const path = window.location.pathname;
        if (
          path === '/reviews' ||
          path === '/work' ||
          path === '/commercial' ||
          path === '/domestic' ||
          path === '/contact' ||
          path === '/sitemap' ||
          path === '/areas' ||
          path.startsWith('/areas/')
        ) {
          navLinks.forEach((link) => {
            const href = link.getAttribute('href') ?? '';
            const active = href === path || (path.startsWith('/areas/') && href === '/areas');
            link.classList.toggle('is-active', active);
            if (active) link.setAttribute('aria-current', 'location');
            else link.removeAttribute('aria-current');
          });
          return;
        }

        const offset = 100;
        let current = '';
        for (const id of sectionIds) {
          const el = document.getElementById(id);
          if (el && window.scrollY + offset >= el.offsetTop) current = id;
        }
        navLinks.forEach((link) => {
          const href = link.getAttribute('href') ?? '';
          const active =
            href === '/reviews' || href === '/work' || href === '/commercial' || href === '/domestic' || href === '/contact' || href === '/sitemap' || href === '/areas'
              ? false
              : href === `#${current}` || href === `/#${current}`;
          link.classList.toggle('is-active', active);
          if (active) link.setAttribute('aria-current', 'location');
          else link.removeAttribute('aria-current');
        });
      };
      window.addEventListener('scroll', setActiveNav, { passive: true });
      setActiveNav();

      // Subtle paint-dot cursor trail (skipped on touch & reduced motion)
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isTouch = matchMedia('(hover: none)').matches;
      if (!reduce && !isTouch) {
        const colors = ['#d4262c','#ec008c','#ffd60a','#7ED321'];
        let last = 0;
        document.addEventListener('pointermove', (e) => {
          const now = performance.now();
          if (now - last < 60) return;
          last = now;
          const dot = document.createElement('span');
          dot.className = 'paint-dot';
          const c = colors[Math.floor(Math.random() * colors.length)];
          dot.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;width:8px;height:8px;border-radius:50%;background:${c};pointer-events:none;z-index:9999;transform:translate(-50%,-50%) scale(1);transition:transform .6s ease-out, opacity .6s ease-out;opacity:.85;mix-blend-mode:multiply;`;
          document.body.appendChild(dot);
          requestAnimationFrame(() => {
            dot.style.transform = `translate(-50%,-50%) scale(0.3)`;
            dot.style.opacity = '0';
          });
          setTimeout(() => dot.remove(), 700);
        });
      }
    </script>
  </body>
</html>
