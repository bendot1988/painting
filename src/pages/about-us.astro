---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import {
  aboutHeroGallery,
  aboutHighlights,
  aboutIntro,
  aboutNarrative,
  aboutVideo,
} from '~/data/about-page';

const aboutVideoEmbedUrl = `https://www.youtube-nocookie.com/embed/${aboutVideo.id}?mute=1&rel=0&modestbranding=1`;
import { quotePageHref } from '~/data/contact';

const pageTitle = 'About Us | A.S Painting Contractors';
const pageDescription =
  'About A.S Painting Contractors — commercial painting and office decorating in Leicester and Leicestershire for public and private sector clients. Quality materials, on time and on budget.';
const aboutJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About A.S Painting Contractors',
  description: pageDescription,
  url: 'https://www.as-painting.co.uk/about-us/',
  mainEntity: {
    '@type': 'PaintingService',
    name: 'A.S Painting Contractors',
    image: 'https://www.as-painting.co.uk/wp-content/uploads/2021/07/A.S-Painting-Contractors-2.png',
    telephone: ['+441162914746', '+448000096694'],
    areaServed: ['Leicester', 'Leicestershire', 'East Midlands'],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Leicester',
      postalCode: 'LE19 4DG',
      addressCountry: 'GB',
    },
    priceRange: '££',
    openingHours: 'Mo-Su 06:00-17:00',
  },
};
---
<Layout
  title={pageTitle}
  description={pageDescription}
  jsonLd={aboutJsonLd}
>
  <Header />
  <main id="main" class="about-page">
    <section class="about-page__hero" aria-labelledby="about-heading">
      <div class="container">
        <span class="eyebrow">About us</span>
        <h1 id="about-heading" class="display h1">
          Painters you can <span class="painted-word painted-word--blue">trust.</span>
        </h1>
        <p class="lead about-page__intro">{aboutIntro}</p>
        <div class="about-page__pills" aria-label="At a glance">
          <span class="about-page__pill">25+ years experience</span>
          <span class="about-page__pill">2,000+ jobs completed</span>
          <span class="about-page__pill">Commercial &amp; domestic</span>
        </div>

        <div class="about-page__hero-gallery reveal" aria-label="Project gallery">
          {aboutHeroGallery.map((img, i) => (
            <figure class="about-page__gallery-tile" style={`--i:${i}`}>
              <img
                src={img.src}
                alt={img.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                width="640"
                height="480"
              />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="about-page__band" aria-labelledby="about-story-heading">
      <div class="container">
        <h2 id="about-story-heading" class="about-page__section-title">About us</h2>
        <div class="about-page__prose reveal">
          {aboutNarrative.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <section class="about-page__video-section" aria-labelledby="about-video-heading">
      <div class="container">
        <span class="eyebrow">On YouTube</span>
        <h2 id="about-video-heading" class="about-page__section-title">See us at work</h2>
        <p class="about-page__video-lead">{aboutVideo.lead}</p>
        <div class="about-page__video reveal">
          <div class="about-page__video-frame">
            <iframe
              src={aboutVideoEmbedUrl}
              title={aboutVideo.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
            />
          </div>
        </div>
        <p class="about-page__video-note">
          This clip has no narration. It loads muted — you can use YouTube&apos;s volume control if
          sound is ever added.
        </p>
      </div>
    </section>

    <section class="about-page__section" aria-label="What we stand for">
      <div class="container">
        <h2 class="about-page__section-title">What we stand for</h2>
        <ul class="about-page__highlights">
          {aboutHighlights.map((item, i) => (
            <li class="about-page__highlight reveal" style={`--i:${i}`}>
              <strong>{item.title}</strong>
              <p>{item.desc}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="about-page__band about-page__cta-band" aria-label="Get in touch">
      <div class="container">
        <div class="about-page__cta-inner reveal">
          <h2 class="display h3">Ready to talk about your project?</h2>
          <p>Same-day reply, fixed-price quotes, no hard sell. Commercial or domestic.</p>
          <a class="btn" href={quotePageHref}>Get a free quote <span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .about-page {
    --page-stack-gap: 50px;
  }
  .about-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .about-page__hero h1 {
    margin-top: 14px;
    max-width: 14ch;
  }
  .about-page__intro {
    max-width: 52ch;
    margin-top: 16px;
  }
  .about-page__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
    margin-bottom: 28px;
  }
  .about-page__pill {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(14, 14, 16, 0.06);
    font-size: 14px;
    font-weight: 600;
    color: var(--c-graphite);
  }

  .about-page__hero-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: var(--page-stack-gap);
  }
  .about-page__gallery-tile {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    border-radius: 16px;
    overflow: hidden;
    background: #e8e8e6;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
    transition-delay: calc(var(--i) * 50ms);
  }
  .about-page__gallery-tile:nth-child(1) { transform: rotate(2deg); }
  .about-page__gallery-tile:nth-child(2) { transform: rotate(-2.5deg); }
  .about-page__gallery-tile:nth-child(3) { transform: rotate(3deg); }
  .about-page__gallery-tile:nth-child(4) { transform: rotate(-1.5deg); }
  .about-page__gallery-tile::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--c-blue);
    z-index: 1;
    pointer-events: none;
  }
  .about-page__gallery-tile:hover {
    transform: translateY(-3px) rotate(0deg);
    box-shadow: var(--shadow-md);
  }
  .about-page__gallery-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s var(--ease);
  }
  .about-page__gallery-tile:hover img {
    transform: scale(1.05);
  }

  .about-page__band {
    background: var(--bg-alt);
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .about-page__video-section {
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .about-page__video-lead {
    max-width: 52ch;
    margin: 0 0 28px;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.55;
  }
  .about-page__video {
    max-width: min(920px, 100%);
    margin: 0 auto;
    padding: 0 clamp(8px, 2vw, 20px);
  }
  .about-page__video-frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: var(--c-ink);
    border: 3px solid var(--c-ink);
    box-shadow:
      14px 16px 0 var(--c-red),
      0 28px 56px rgba(212, 38, 44, 0.28);
    transform: rotate(-1.25deg);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .about-page__video-frame:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow:
      16px 18px 0 var(--c-red-deep),
      0 32px 64px rgba(212, 38, 44, 0.34);
  }
  .about-page__video-frame iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    vertical-align: middle;
  }
  .about-page__video-note {
    max-width: 52ch;
    margin: 16px auto 0;
    text-align: center;
    font-size: 13px;
    line-height: 1.45;
    color: var(--c-stone);
  }

  .about-page__section {
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .about-page__section-title {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    color: var(--c-ink);
  }
  .about-page__section-lead {
    max-width: 58ch;
    margin: 0 0 28px;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.55;
  }

  .about-page__prose {
    max-width: 72ch;
    display: grid;
    gap: 1.25em;
  }
  .about-page__prose p {
    margin: 0;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.65;
  }

  .about-page__highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .about-page__highlight {
    background: #fff;
    border-radius: 14px;
    padding: 18px 20px;
    border-left: 4px solid var(--c-blue);
    box-shadow: var(--shadow-sm);
    transition-delay: calc(var(--i) * 60ms);
  }
  .about-page__highlight strong {
    display: block;
    font-size: 16px;
    color: var(--c-ink);
    margin-bottom: 6px;
  }
  .about-page__highlight p {
    margin: 0;
    font-size: 14.5px;
    color: var(--c-graphite);
    line-height: 1.45;
  }

  .about-page__cta-band {
    padding-bottom: clamp(72px, 9vw, 120px);
  }
  .about-page__cta-inner {
    text-align: center;
    padding: clamp(32px, 4vw, 48px);
    border-radius: 20px;
    color: var(--c-paper);
    background-color: var(--c-ink);
    background-image: url('/images/brand/paint-strokes.jpg');
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(14, 14, 16, 0.12);
    box-shadow: var(--shadow-md);
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .about-page__cta-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 14, 16, 0.88) 0%,
      rgba(14, 14, 16, 0.78) 50%,
      rgba(14, 14, 16, 0.85) 100%
    );
  }
  .about-page__cta-inner :is(h2, p, .btn) {
    position: relative;
    z-index: 1;
  }
  .about-page__cta-inner h2 {
    color: #fff;
    margin: 0 0 10px;
  }
  .about-page__cta-inner p {
    margin: 0 0 20px;
    color: #cfcdc8;
    max-width: 40ch;
    margin-inline: auto;
  }

  @media (min-width: 900px) {
    .about-page__prose {
      grid-template-columns: 1fr 1fr;
      max-width: none;
      column-gap: clamp(24px, 4vw, 48px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-page__gallery-tile:hover {
      transform: none;
    }
    .about-page__gallery-tile:hover img {
      transform: none;
    }
    .about-page__video-frame,
    .about-page__video-frame:hover {
      transform: none;
    }
  }

  @media (max-width: 1024px) {
    .about-page__highlights {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .about-page__hero-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }
</style>
