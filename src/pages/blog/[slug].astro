---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import BlogSidebar from '~/components/BlogSidebar.astro';
import { blogPosts, formatBlogDate, getBlogPostBySlug } from '~/data/blog';
import { quotePageHref } from '~/data/contact';
import { absoluteUrl } from '~/utils/site-url';
import '~/styles/blog-ui.css';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = getBlogPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/blog/');
}

const pageUrl = absoluteUrl(`/blog/${post.slug}/`);
const pageTitle = `${post.title} | A.S Painting Contractors`;
const pageDescription = post.excerpt;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': pageUrl,
      headline: post.title,
      description: post.excerpt,
      datePublished: post.date,
      image: absoluteUrl(post.image.src),
      author: {
        '@type': 'Organization',
        name: 'A.S Painting Contractors',
      },
      publisher: {
        '@type': 'Organization',
        name: 'A.S Painting Contractors',
      },
      mainEntityOfPage: pageUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/') },
        { '@type': 'ListItem', position: 2, name: 'News', item: absoluteUrl('/blog/') },
        { '@type': 'ListItem', position: 3, name: post.title, item: pageUrl },
      ],
    },
  ],
};
---
<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`/blog/${post.slug}/`}
  jsonLd={articleJsonLd}
>
  <Header />
  <main id="main" class="blog-post">
    <article class="blog-post__article">
      <div class="container blog-post__layout">
        <div class="blog-post__main">
          <header class="blog-post__header">
            <nav class="blog-post__crumb" aria-label="Breadcrumb">
              <a href="/">Home</a>
              <span aria-hidden="true">/</span>
              <a href="/blog/">News</a>
              <span aria-hidden="true">/</span>
              <span>{post.title}</span>
            </nav>
            <time class="blog-post__date" datetime={post.date}>
              {formatBlogDate(post.date)}
            </time>
            <h1 class="display h2 blog-post__title">{post.title}</h1>
          </header>

          <div class="blog-ui-card blog-ui-card--article">
            <figure class="blog-post__figure">
              <img
                src={post.image.src}
                alt={post.image.alt}
                loading="eager"
                width="800"
                height="450"
              />
            </figure>
            <div class="blog-ui-card__body">
              <div class="blog-post__prose">
                {post.paragraphs.map((paragraph) => (
                  <p set:html={paragraph} />
                ))}
                {post.gallery && post.gallery.length > 0 && (
                  <ul class="blog-post__gallery" aria-label="Project photos">
                    {post.gallery.map((img) => (
                      <li>
                        <figure>
                          <img src={img.src} alt={img.alt} loading="lazy" width="480" height="360" />
                        </figure>
                      </li>
                    ))}
                  </ul>
                )}
                {post.externalLink && (
                  <p class="blog-post__external">
                    <a
                      href={post.externalLink.href}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {post.externalLink.label} <span class="arrow">→</span>
                    </a>
                  </p>
                )}
                {post.dotwallCredit && (
                  <p class="blog-post__credit">
                    Website by{' '}
                    <a href="https://dotwall.co.uk" target="_blank" rel="noopener noreferrer">dotwall</a>.
                  </p>
                )}
              </div>
              <footer class="blog-post__footer">
                <a class="btn btn--ghost" href="/blog/">← All news</a>
                <a class="btn" href={quotePageHref}>Get in touch <span class="arrow">→</span></a>
              </footer>
            </div>
          </div>
        </div>

        <BlogSidebar currentSlug={post.slug} />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .blog-post__article {
    padding-top: calc(38px + 50px);
    padding-bottom: clamp(72px, 9vw, 120px);
    background: var(--bg-alt);
  }
  .blog-post__layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
    gap: clamp(24px, 3vw, 40px);
    align-items: start;
  }
  .blog-post__layout :global(.blog-sidebar) {
    position: sticky;
    top: calc(72px + 20px);
  }
  .blog-post__main {
    min-width: 0;
  }
  .blog-post__header {
    margin-bottom: 20px;
  }
  .blog-post__crumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-stone);
  }
  .blog-post__crumb a {
    color: var(--c-red);
    text-decoration: none;
  }
  .blog-post__crumb a:hover {
    text-decoration: underline;
  }
  .blog-post__date {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-stone);
    margin-bottom: 8px;
  }
  .blog-post__title {
    margin: 0;
    line-height: 1.15;
  }
  .blog-post__figure {
    margin: 0;
  }
  .blog-post__figure img {
    width: 100%;
    max-height: 300px;
    object-fit: cover;
    display: block;
  }
  .blog-post__prose p {
    margin: 0 0 1.25em;
    font-size: 16px;
    line-height: 1.65;
    color: var(--c-graphite);
  }
  /* :global — links inside set:html paragraphs are not scoped by Astro */
  .blog-post__prose :global(a),
  .blog-post__external a,
  .blog-post__credit a {
    font-weight: 700;
    color: var(--c-red) !important;
    text-decoration: underline !important;
    text-decoration-color: var(--c-red) !important;
    text-underline-offset: 0.12em;
  }
  .blog-post__prose :global(a:hover),
  .blog-post__external a:hover,
  .blog-post__credit a:hover {
    text-decoration-thickness: 2px;
  }
  .blog-post__gallery {
    list-style: none;
    margin: 1.75em 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  .blog-post__gallery figure {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #e8e8e6;
  }
  .blog-post__gallery img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 520px) {
    .blog-post__gallery {
      grid-template-columns: 1fr;
    }
  }
  .blog-post__external {
    margin-top: 1.5em;
  }
  .blog-post__credit {
    margin-top: 1.5em !important;
    font-size: 15px !important;
    color: var(--c-stone) !important;
  }
  .blog-post__footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(14, 14, 16, 0.1);
  }

  @media (max-width: 900px) {
    .blog-post__layout {
      grid-template-columns: 1fr;
    }
    .blog-post__layout :global(.blog-sidebar) {
      position: static;
    }
  }
</style>
