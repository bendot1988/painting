---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { contact } from '~/data/contact';
---
<Layout title="Terms of service — A.S Painting Contractors" description="Terms of service for A.S Painting Contractors.">
  <Header />
  <main id="main" class="legal-page section">
    <div class="container legal-page__inner">
      <span class="eyebrow">Legal</span>
      <h1 class="display h2">Terms of service</h1>
      <p class="lead">
        Quotes are subject to site survey. We provide painting services only —
        not plastering or wallpaper hanging unless agreed separately in writing.
      </p>
      <p>
        Deposits, timings and scope are confirmed in your written quote before
        work begins. For questions, call
        <a href={`tel:${contact.phone.tel}`}>{contact.phone.display}</a> or email
        <a href={`mailto:${contact.email}`}>{contact.email}</a>.
      </p>
      <p><a class="btn btn--ghost" href="/#quote">Back to quote form</a></p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page { padding-block: clamp(120px, 14vw, 160px) clamp(72px, 9vw, 120px); }
  .legal-page__inner { max-width: 60ch; }
  .legal-page h1 { margin: 14px 0 18px; }
  .legal-page p { color: var(--c-graphite); line-height: 1.6; margin: 0 0 1em; }
</style>
