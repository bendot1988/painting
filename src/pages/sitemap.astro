---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { sitemapGroups } from '~/data/sitemap';

const pageTitle = 'Sitemap | A.S Painting Contractors';
const pageDescription =
  'Visual sitemap for A.S Painting Contractors: every page and section on this website, plus the XML sitemap for search engines.';

const site = import.meta.env.SITE ?? 'https://as-painting.co.uk';
const xmlHref = '/sitemap.xml';
const xmlFullUrl = `${site.replace(/\/$/, '')}${xmlHref}`;
---
<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main id="main" class="sitemap-page">
    <section class="sitemap-page__hero" aria-labelledby="sitemap-heading">
      <div class="container">
        <span class="eyebrow">Site map</span>
        <h1 id="sitemap-heading" class="display h1">
          Every page on this <span class="painted-word painted-word--lime">website.</span>
        </h1>
        <p class="lead sitemap-page__intro">
          A quick map of where everything lives: main pages, homepage sections and legal
          pages. Use the links below, or open the XML sitemap for search engines and tools.
        </p>

        <div class="sitemap-page__xml reveal">
          <div class="sitemap-page__xml-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28">
              <path fill="currentColor" d="M4 4h16v16H4V4zm2 2v12h12V6H6zm2 2h8v2H8V8zm0 4h8v2H8v-2zm0 4h5v2H8v-2z"/>
            </svg>
          </div>
          <div class="sitemap-page__xml-copy">
            <strong>XML sitemap</strong>
            <p>For Google Search Console, Bing and other crawlers.</p>
            <a class="sitemap-page__xml-link" href={xmlHref}>{xmlFullUrl}</a>
          </div>
          <a class="btn sitemap-page__xml-btn" href={xmlHref} target="_blank" rel="noopener">
            Open XML <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <section class="sitemap-page__map" aria-label="Site structure">
      <div class="container">
        <a href="/" class="sitemap-page__root reveal">
          <span class="sitemap-page__root-label">Start here</span>
          <span class="sitemap-page__root-title">Home</span>
          <span class="sitemap-page__root-desc">as-painting.co.uk</span>
        </a>

        <div class="sitemap-page__connector reveal" aria-hidden="true"></div>

        <div class="sitemap-page__groups">
          {sitemapGroups.map((group, gi) => (
            <article class={`sitemap-group sitemap-group--${group.accent} reveal`} style={`--i:${gi}`}>
              <h2 class="sitemap-group__title">{group.title}</h2>
              <ul class="sitemap-group__list">
                {group.links.map((link) => (
                  <li>
                    <a class="sitemap-link" href={link.href}>
                      <span class="sitemap-link__label">{link.label}</span>
                      {link.description && (
                        <span class="sitemap-link__desc">{link.description}</span>
                      )}
                      <span class="sitemap-link__arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .sitemap-page {
    --page-stack-gap: 50px;
  }

  .sitemap-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .sitemap-page__hero h1 {
    margin-top: 14px;
    max-width: 16ch;
  }
  .sitemap-page__intro {
    max-width: 52ch;
    margin-top: 16px;
  }

  .sitemap-page__xml {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px 20px;
    margin-top: 32px;
    padding: 20px 22px;
    border-radius: 18px;
    background: var(--bg-alt);
    border: 1px solid rgba(14, 14, 16, 0.08);
    border-left: 4px solid var(--c-lime);
  }
  .sitemap-page__xml-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(126, 211, 33, 0.15);
    color: var(--c-ink);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .sitemap-page__xml-copy {
    flex: 1;
    min-width: 200px;
  }
  .sitemap-page__xml-copy strong {
    display: block;
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--c-ink);
  }
  .sitemap-page__xml-copy p {
    margin: 4px 0 6px;
    font-size: 14px;
    color: var(--c-graphite);
  }
  .sitemap-page__xml-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-red);
    word-break: break-all;
  }
  .sitemap-page__xml-link:hover {
    text-decoration: underline;
  }
  .sitemap-page__xml-btn {
    flex-shrink: 0;
  }

  .sitemap-page__map {
    padding: var(--page-stack-gap) 0 clamp(72px, 9vw, 120px);
  }

  .sitemap-page__root {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 280px;
    margin: 0 auto;
    padding: 24px 28px;
    border-radius: 20px;
    background: var(--c-ink);
    color: var(--c-paper);
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .sitemap-page__root:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .sitemap-page__root-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-yellow);
  }
  .sitemap-page__root-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    margin-top: 6px;
    line-height: 1.1;
  }
  .sitemap-page__root-desc {
    margin-top: 6px;
    font-size: 14px;
    color: #cfcdc8;
  }

  .sitemap-page__connector {
    width: 2px;
    height: 36px;
    margin: 0 auto;
    background: linear-gradient(
      to bottom,
      var(--c-red),
      var(--c-yellow),
      var(--c-lime),
      var(--c-pink),
      var(--c-blue)
    );
    border-radius: 2px;
  }

  .sitemap-page__groups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 8px;
  }

  .sitemap-group {
    background: #fff;
    border-radius: 18px;
    padding: 22px 20px;
    box-shadow: var(--shadow-sm);
    border-top: 4px solid var(--accent, var(--c-red));
    transition-delay: calc(var(--i) * 60ms);
  }
  .sitemap-group--red    { --accent: var(--c-red); }
  .sitemap-group--yellow { --accent: var(--c-yellow); }
  .sitemap-group--lime   { --accent: var(--c-lime); }
  .sitemap-group--pink   { --accent: var(--c-pink); }
  .sitemap-group--blue   { --accent: var(--c-blue); }

  .sitemap-group__title {
    margin: 0 0 14px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-stone);
  }

  .sitemap-group__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sitemap-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 2px 10px;
    padding: 12px 14px;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background: var(--bg-alt);
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .sitemap-link:hover {
    background: #fff;
    border-color: rgba(14, 14, 16, 0.1);
    transform: translateX(4px);
  }
  .sitemap-link__label {
    grid-column: 1;
    font-weight: 700;
    font-size: 15px;
    color: var(--c-ink);
  }
  .sitemap-link__desc {
    grid-column: 1;
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--c-graphite);
  }
  .sitemap-link__arrow {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
    font-size: 18px;
    color: var(--accent, var(--c-red));
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .sitemap-link:hover .sitemap-link__arrow {
    opacity: 1;
    transform: translateX(2px);
  }

  @media (max-width: 980px) {
    .sitemap-page__groups {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .sitemap-page__xml {
      flex-direction: column;
      align-items: flex-start;
    }
    .sitemap-page__xml-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
