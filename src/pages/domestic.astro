---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import {
  domesticHeroGallery,
  domesticHighlights,
  interiorRooms,
  exteriorProjects,
  domesticFaqs,
} from '~/data/domestic-page';
import { workItems } from '~/data/showcase-work';

const domesticWork = workItems.filter((i) => i.tag === 'domestic').slice(0, 6);

const pageTitle = 'Domestic Painting | A.S Painting Contractors';
const pageDescription =
  'Domestic interior and exterior painting across Leicestershire. Kitchens, living rooms, halls, bedrooms and home exteriors. Free home visits.';
---
<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main id="main" class="domestic-page">
    <section class="domestic-page__hero" aria-labelledby="domestic-heading">
      <div class="container">
        <span class="eyebrow">Domestic · 40% of our diary</span>
        <h1 id="domestic-heading" class="display h1">
          Make it feel like <span class="painted-word painted-word--pink">home</span> again.
        </h1>
        <p class="lead domestic-page__intro">
          From a tired hallway to a full re-decoration before you move in. We work cleanly,
          finish on time and leave the house better than we found it.
        </p>
        <div class="domestic-page__pills" aria-label="Domestic services">
          <span class="domestic-page__pill">Interior painting</span>
          <span class="domestic-page__pill">Exterior painting</span>
          <span class="domestic-page__pill">Kitchens & woodwork</span>
        </div>

        <div class="domestic-page__hero-gallery reveal" aria-label="Domestic project gallery">
          {domesticHeroGallery.map((img, i) => (
            <figure class="domestic-page__gallery-tile" style={`--i:${i}`}>
              <img
                src={img.src}
                alt={img.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                width="640"
                height="480"
              />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="domestic-page__band" aria-label="Why homeowners choose us">
      <div class="container">
        <h2 class="domestic-page__section-title">Built for living in</h2>
        <ul class="domestic-page__highlights">
          {domesticHighlights.map((item, i) => (
            <li class="domestic-page__highlight reveal" style={`--i:${i}`}>
              <strong>{item.title}</strong>
              <p>{item.desc}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="domestic-page__section" aria-labelledby="interior-heading">
      <div class="container">
        <h2 id="interior-heading" class="domestic-page__section-title">Rooms we paint</h2>
        <p class="domestic-page__section-lead">
          Kitchens, living spaces, bedrooms and circulation areas. We paint walls, ceilings
          and woodwork. No wallpaper hanging. No plastering.
        </p>
        <div class="domestic-page__grid">
          {interiorRooms.map((s, i) => (
            <article class="domestic-page__card reveal" style={`--i:${i % 6}`}>
              <div class="domestic-page__card-media">
                <img src={s.src} alt={s.alt} loading="lazy" width="640" height="400" />
              </div>
              <div class="domestic-page__card-body">
                <h3>{s.name}</h3>
                <p>{s.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="domestic-page__band" aria-labelledby="exterior-heading">
      <div class="container">
        <h2 id="exterior-heading" class="domestic-page__section-title">Exterior domestic painting</h2>
        <p class="domestic-page__section-lead">
          Weather-facing work needs the right prep and products. We handle render, masonry,
          woodwork, doors, fascias and garden joinery across Leicestershire.
        </p>
        <div class="domestic-page__grid">
          {exteriorProjects.map((p, i) => (
            <article class="domestic-page__card domestic-page__card--exterior reveal" style={`--i:${i % 6}`}>
              <div class="domestic-page__card-media">
                <img src={p.src} alt={p.alt} loading="lazy" width="640" height="400" />
              </div>
              <div class="domestic-page__card-body">
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="domestic-page__section" aria-labelledby="work-snapshot-heading">
      <div class="container">
        <h2 id="work-snapshot-heading" class="domestic-page__section-title">Recent domestic projects</h2>
        <div class="domestic-page__snapshots">
          {domesticWork.map((item, i) => (
            <a class="domestic-page__snapshot reveal" href="/work" style={`--i:${i}`}>
              <img src={item.src} alt={item.alt} loading="lazy" />
              <span>{item.title}</span>
            </a>
          ))}
        </div>
        <p class="domestic-page__link-row">
          <a class="btn btn--ghost" href="/work">View all our work <span class="arrow">→</span></a>
        </p>
      </div>
    </section>

    <section class="domestic-page__band domestic-page__faqs" aria-label="Frequently asked questions">
      <div class="container">
        <h2 class="domestic-page__section-title">Quick answers</h2>
        <div class="domestic-page__faq-list">
          {domesticFaqs.map((item) => (
            <details class="domestic-page__faq">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
        <p class="domestic-page__cta">
          <a class="btn" href="/contact">Book a free home visit <span class="arrow">→</span></a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .domestic-page {
    --page-stack-gap: 50px;
    --domestic-accent: var(--c-pink);
    --domestic-exterior-accent: var(--c-lime);
  }
  .domestic-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .domestic-page__hero h1 {
    margin-top: 14px;
    max-width: 16ch;
  }
  .domestic-page__intro {
    max-width: 52ch;
    margin-top: 16px;
  }
  .domestic-page__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
    margin-bottom: 28px;
  }
  .domestic-page__pill {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(14, 14, 16, 0.06);
    font-size: 14px;
    font-weight: 600;
    color: var(--c-graphite);
  }

  .domestic-page__hero-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: var(--page-stack-gap);
  }
  .domestic-page__gallery-tile {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    border-radius: 16px;
    overflow: hidden;
    background: #e8e8e6;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
    transition-delay: calc(var(--i) * 50ms);
  }
  .domestic-page__gallery-tile:nth-child(1) { transform: rotate(-2.5deg); }
  .domestic-page__gallery-tile:nth-child(2) { transform: rotate(2deg); }
  .domestic-page__gallery-tile:nth-child(3) { transform: rotate(-1.5deg); }
  .domestic-page__gallery-tile:nth-child(4) { transform: rotate(3deg); }
  .domestic-page__gallery-tile::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--domestic-accent);
    z-index: 1;
    pointer-events: none;
  }
  .domestic-page__gallery-tile:hover {
    transform: translateY(-3px) rotate(0deg);
    box-shadow: var(--shadow-md);
  }
  .domestic-page__gallery-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s var(--ease);
  }
  .domestic-page__gallery-tile:hover img {
    transform: scale(1.05);
  }

  .domestic-page__band {
    background: var(--bg-alt);
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .domestic-page__section {
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .domestic-page__section-title {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    color: var(--c-ink);
  }
  .domestic-page__section-lead {
    max-width: 58ch;
    margin: 0 0 28px;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.55;
  }

  .domestic-page__highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .domestic-page__highlight {
    background: #fff;
    border-radius: 14px;
    padding: 18px 20px;
    border-left: 4px solid var(--domestic-accent);
    box-shadow: var(--shadow-sm);
    transition-delay: calc(var(--i) * 60ms);
  }
  .domestic-page__highlight strong {
    display: block;
    font-size: 16px;
    color: var(--c-ink);
    margin-bottom: 6px;
  }
  .domestic-page__highlight p {
    margin: 0;
    font-size: 14.5px;
    color: var(--c-graphite);
    line-height: 1.45;
  }

  .domestic-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .domestic-page__card {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border-top: 4px solid var(--domestic-accent);
    transition-delay: calc(var(--i) * 50ms);
  }
  .domestic-page__card--exterior {
    border-top-color: var(--domestic-exterior-accent);
  }
  .domestic-page__card-media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #e8e8e6;
  }
  .domestic-page__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .domestic-page__card:hover .domestic-page__card-media img {
    transform: scale(1.05);
  }
  .domestic-page__card-body {
    padding: 18px 20px 22px;
  }
  .domestic-page__card-body h3 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--c-ink);
    line-height: 1.25;
  }
  .domestic-page__card-body p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-graphite);
  }

  .domestic-page__snapshots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }
  .domestic-page__snapshot {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: block;
    text-decoration: none;
  }
  .domestic-page__snapshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .domestic-page__snapshot span {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 12px 14px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75), transparent);
  }
  .domestic-page__snapshot:hover img {
    transform: scale(1.05);
  }
  .domestic-page__link-row {
    margin: 0;
  }

  .domestic-page__faq-list {
    max-width: 720px;
  }
  .domestic-page__faq {
    border-top: 1px solid rgba(14, 14, 16, 0.1);
  }
  .domestic-page__faq:last-of-type {
    border-bottom: 1px solid rgba(14, 14, 16, 0.1);
  }
  .domestic-page__faq summary {
    list-style: none;
    cursor: pointer;
    padding: 16px 32px 16px 0;
    font-weight: 600;
    font-size: 15px;
    color: var(--c-ink);
    position: relative;
  }
  .domestic-page__faq summary::-webkit-details-marker {
    display: none;
  }
  .domestic-page__faq summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 20px;
    color: var(--c-red);
  }
  .domestic-page__faq[open] summary::after {
    content: "−";
  }
  .domestic-page__faq p {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-graphite);
  }

  .domestic-page__cta {
    margin: 36px 0 0;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .domestic-page__gallery-tile:hover {
      transform: none;
    }
    .domestic-page__gallery-tile:hover img {
      transform: none;
    }
  }

  @media (max-width: 1024px) {
    .domestic-page__grid,
    .domestic-page__snapshots {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .domestic-page__hero-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .domestic-page__highlights,
    .domestic-page__grid,
    .domestic-page__snapshots {
      grid-template-columns: 1fr;
    }
  }
</style>
