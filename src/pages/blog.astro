---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { blogIndexMeta, blogPosts, formatBlogDate } from '~/data/blog';
import { quotePageHref } from '~/data/contact';
import '~/styles/blog-ui.css';

const sortedPosts = [...blogPosts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---
<Layout title={blogIndexMeta.title} description={blogIndexMeta.description} canonical="/blog/">
  <Header />
  <main id="main" class="blog-page">
    <section class="blog-page__hero" aria-labelledby="blog-heading">
      <div class="container">
        <span class="eyebrow">News &amp; updates</span>
        <h1 id="blog-heading" class="display h1">
          News from <span class="painted-word painted-word--pink">A.S Painting.</span>
        </h1>
        <p class="lead blog-page__intro">
          Company news, project snapshots and occasional updates from our team across
          Leicestershire.
        </p>
      </div>
    </section>

    <section class="blog-page__list-section" aria-label="All news posts">
      <div class="container">
        {sortedPosts.length > 0 ? (
          <ul class="blog-page__grid">
            {sortedPosts.map((post, i) => (
              <li class="blog-page__item reveal" style={`--i:${i}`}>
                <article class="blog-ui-card blog-page__card">
                  <a class="blog-page__card-link" href={`/blog/${post.slug}/`}>
                    <figure class="blog-page__card-media">
                      <img
                        src={post.image.src}
                        alt={post.image.alt}
                        loading={i < 3 ? 'eager' : 'lazy'}
                        width="400"
                        height="260"
                      />
                    </figure>
                    <div class="blog-page__card-body">
                      <time class="blog-page__date" datetime={post.date}>
                        {formatBlogDate(post.date)}
                      </time>
                      <h2 class="blog-page__card-title">{post.title}</h2>
                      <p class="blog-page__excerpt">{post.excerpt}</p>
                      <span class="blog-page__read">
                        Read article <span class="arrow">→</span>
                      </span>
                    </div>
                  </a>
                </article>
              </li>
            ))}
          </ul>
        ) : (
          <div class="blog-ui-card">
            <p class="blog-page__empty">No news posts yet — check back soon.</p>
          </div>
        )}

        <p class="blog-page__cta">
          <a class="btn" href={quotePageHref}>Request a free quote <span class="arrow">→</span></a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-page {
    --page-stack-gap: 50px;
  }
  .blog-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .blog-page__hero h1 {
    margin-top: 14px;
    max-width: 14ch;
  }
  .blog-page__intro {
    max-width: 48ch;
    margin-top: 16px;
  }
  .blog-page__list-section {
    padding: var(--page-stack-gap) 0 clamp(72px, 9vw, 120px);
    background: var(--bg-alt);
  }
  .blog-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .blog-page__item {
    transition-delay: calc(var(--i) * 50ms);
  }
  .blog-page__card {
    padding: 0;
    overflow: hidden;
    height: 100%;
    transition: box-shadow 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .blog-page__card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .blog-page__card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .blog-page__card-media {
    margin: 0;
    aspect-ratio: 16 / 10;
    background: #e8e8e6;
    overflow: hidden;
  }
  .blog-page__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .blog-page__card:hover .blog-page__card-media img {
    transform: scale(1.04);
  }
  .blog-page__card-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .blog-page__date {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-stone);
  }
  .blog-page__card-title {
    margin: 8px 0 10px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--c-ink);
    line-height: 1.25;
  }
  .blog-page__excerpt {
    margin: 0 0 14px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-graphite);
    flex: 1;
  }
  .blog-page__read {
    font-size: 13px;
    font-weight: 700;
    color: var(--c-red);
  }
  .blog-page__empty {
    margin: 0;
    color: var(--c-graphite);
  }
  .blog-page__cta {
    margin-top: 32px;
    text-align: center;
  }

  @media (max-width: 1100px) {
    .blog-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 820px) {
    .blog-page__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-inline: auto;
    }
  }
  @media (max-width: 640px) {
    .blog-page__hero h1 {
      max-width: none;
    }
  }
</style>
