  @property --plat-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  .mp-page__package--platinum {
    border-top-color: transparent;
    overflow: visible;
    background: #fff;
    box-shadow:
      0 10px 36px rgba(14, 14, 16, 0.16),
      0 4px 12px rgba(14, 14, 16, 0.08);
  }
  .mp-page__package--platinum::before {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 21px;
    padding: 3px;
    background: conic-gradient(
      from var(--plat-angle),
      var(--c-yellow),
      var(--c-lime),
      var(--c-pink),
      var(--c-blue),
      var(--c-red),
      var(--c-yellow)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: mp-platinum-spin 5s linear infinite;
    pointer-events: none;
    z-index: 3;
  }
  .mp-page__package--platinum::after {
    content: "";
    position: absolute;
    inset: -18px;
    border-radius: 32px;
    padding: 16px;
    background: conic-gradient(
      from var(--plat-angle),
      var(--c-yellow),
      var(--c-lime),
      var(--c-pink),
      var(--c-blue),
      var(--c-red),
      var(--c-yellow)
    );
    filter: blur(22px);
    opacity: 0.55;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: mp-platinum-spin 5s linear infinite;
    pointer-events: none;
    z-index: -1;
  }
  .mp-page__package--platinum > * {
    position: relative;
    z-index: 2;
  }
  .mp-page__package--platinum h3 {
    font-size: 22px;
    color: var(--c-ink);
  }
  .mp-page__package--platinum .mp-page__package-subtitle {
    color: var(--c-ink);
    font-weight: 800;
  }
  .mp-page__package--platinum .mp-page__package-includes li {
    color: var(--c-ink);
    font-weight: 500;
  }
  .mp-page__package-badge--platinum {
    background: linear-gradient(135deg, var(--c-yellow), var(--c-pink));
    color: var(--c-ink);
    box-shadow: 0 2px 8px rgba(236, 0, 140, 0.28);
  }

  @keyframes mp-platinum-spin {
    to { --plat-angle: 360deg; }
  }

  .mp-page__confetti {
    position: absolute;
    top: 0;
    left: 50%;
    width: 0;
    height: 0;
    pointer-events: none;
    z-index: 3;
  }
  .mp-page__confetti-piece {
    position: absolute;
    top: -4px;
    left: 0;
    width: var(--cs, 8px);
    height: calc(var(--cs, 8px) * 1.6);
    background: var(--cc, var(--c-yellow));
    border-radius: 2px;
    opacity: 0;
    transform: translate(-50%, 0) rotate(var(--cr, 0deg));
    will-change: transform, opacity;
  }
  .mp-page__package--platinum.is-firing .mp-page__confetti-piece {
    animation: mp-confetti-launch 1.9s cubic-bezier(.16, .76, .32, 1) forwards;
    animation-delay: var(--cd, 0s);
  }

  @keyframes mp-confetti-launch {
    0% {
      transform: translate(-50%, 0) rotate(var(--cr));
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    55% {
      transform: translate(calc(-50% + var(--cx)), var(--cy)) rotate(calc(var(--cr) + 540deg));
      opacity: 1;
    }
    100% {
      transform: translate(calc(-50% + var(--cx) * 1.4), 90px) rotate(calc(var(--cr) + 960deg));
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mp-page__package--platinum::before,
    .mp-page__package--platinum::after {
      animation: none;
    }
    .mp-page__package--platinum.is-firing .mp-page__confetti-piece {
      animation: none;
    }
