---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import {
  agreementPreview,
  contractTerms,
  excludedFeatures,
  galleryImages,
  finalCtaImage,
  heroImage,
  includedFeatures,
  maintenanceFaqs,
  maintenancePhone,
  maintenancePhoneDisplay,
  maintenancePlansPageMeta,
  packages,
  packagesSmallPrint,
  planOptions,
  platinumAllowanceHeading,
  platinumAllowanceLead,
  platinumAllowanceRows,
  platinumImportantInfo,
  surveyPropertyTypes,
  trustBarItems,
  valueProps,
  valuePropsHeading,
} from '~/data/maintenance-plans-page';
import { thankYouPageHref } from '~/data/contact';
import { buildMaintenancePlansJsonLd } from '~/utils/maintenance-plans-json-ld';
import { normalizeTrailingSlash } from '~/utils/site-url';

const jsonLd = buildMaintenancePlansJsonLd();
const netlifyAction = normalizeTrailingSlash(Astro.url.pathname);
const successUrl = thankYouPageHref;

const checkIcon = `<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>`;
const termIcon = `<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>`;

const confettiColors = ['var(--c-yellow)', 'var(--c-pink)', 'var(--c-lime)', 'var(--c-blue)', 'var(--c-red)'];
const confettiPieces = Array.from({ length: 32 }, (_, idx) => {
  const seed = (idx + 1) * 12.9898;
  const r1 = Math.abs((Math.sin(seed) * 43758.5453) % 1);
  const r2 = Math.abs((Math.sin(seed + 1) * 43758.5453) % 1);
  const r3 = Math.abs((Math.sin(seed + 2) * 43758.5453) % 1);
  return {
    x: Math.round((r1 - 0.5) * 320),
    y: Math.round(-110 - r2 * 110),
    delay: Number((r3 * 0.45).toFixed(2)),
    color: confettiColors[idx % confettiColors.length],
    rot: Math.round(r1 * 540),
    size: 6 + Math.round(r2 * 6),
  };
});

const valuePropIcons: Record<string, string> = {
  shield: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>`,
  paintbrush: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M7 14c-1.66 0-3 1.34-3 3 0 1.31-1.16 2-2 2 .92 1.22 2.49 2 4 2 2.21 0 4-1.79 4-4 0-1.66-1.34-3-3-3zm13.71-9.37-1.34-1.34a.996.996 0 0 0-1.41 0L9 12.25 11.75 15l8.96-8.96a.996.996 0 0 0 0-1.41z"/></svg>`,
  pound: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M14 8h2V6h-2V4h-2v2H9.83C9.4 4.84 8.3 4 7 4 5.34 4 4 5.34 4 7s1.34 3 3 3h2v2H6v2h3v2h2v-2h2.17c.43 1.16 1.53 2 2.83 2 1.66 0 3-1.34 3-3s-1.34-3-3-3h-2V8h2V6h-2V4h-2v2h-2v2zm-2 0V6h2v2h-2z"/></svg>`,
  grid: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z"/></svg>`,
  pin: `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>`,
};
---
<Layout
  title={maintenancePlansPageMeta.title}
  description={maintenancePlansPageMeta.description}
  canonical={maintenancePlansPageMeta.canonical}
  jsonLd={jsonLd}
>
  <Header />
  <main id="main" class="mp-page">
    <section
      class="mp-page__hero"
      aria-labelledby="mp-heading"
      style={`background-image: url('${heroImage.src}')`}
    >
      <div class="mp-page__hero-overlay">
        <div class="container">
          <span class="eyebrow eyebrow--inv">Commercial · Maintenance</span>
          <h1 id="mp-heading" class="display h1 mp-page__hero-title">
            Commercial Decorating <span class="painted-word painted-word--yellow">Maintenance Agreement</span>
          </h1>
          <p class="lead mp-page__hero-lead">
            The smart way to protect your property, all year round.
          </p>
          <div class="mp-page__hero-actions">
            <a class="btn" href="#enquiry">Request a Free Site Survey <span class="arrow">→</span></a>
            <a class="btn btn--ghost btn--ghost-inv" href="#packages">View Packages</a>
          </div>
        </div>
      </div>
    </section>

    <section class="mp-page__section" aria-labelledby="value-props-heading">
      <div class="container">
        <h2 id="value-props-heading" class="mp-page__section-title">{valuePropsHeading}</h2>
        <ul class="mp-page__value-props">
          {valueProps.map((item, i) => (
            <li class="mp-page__value-prop reveal" style={`--i:${i % 10}`}>
              <span class="mp-page__value-prop-icon" set:html={valuePropIcons[item.icon]} />
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__band" id="packages" aria-labelledby="packages-heading">
      <div class="container">
        <h2 id="packages-heading" class="mp-page__section-title">Choose Your Cover Level</h2>
        <p class="mp-page__section-lead mp-page__section-lead--packages">{valuePropsHeading}</p>
        <div class="mp-page__packages">
          {packages.map((pkg, i) => {
            const isPlatinum = pkg.tier === 'Platinum';
            return (
              <article
                class:list={[
                  'mp-page__package',
                  `mp-page__package--${pkg.tier.toLowerCase()}`,
                  { 'mp-page__package--featured': pkg.badge },
                ]}
                style={`--i:${i}`}
                data-platinum={isPlatinum ? 'true' : null}
              >
                {isPlatinum && (
                  <div class="mp-page__confetti" aria-hidden="true">
                    {confettiPieces.map((piece) => (
                      <span
                        class="mp-page__confetti-piece"
                        style={`--cx:${piece.x}px;--cy:${piece.y}px;--cd:${piece.delay}s;--cc:${piece.color};--cr:${piece.rot}deg;--cs:${piece.size}px`}
                      />
                    ))}
                  </div>
                )}
                <div class="mp-page__package-head">
                  <div class="mp-page__package-head-text">
                    <h3>{pkg.tier}</h3>
                    <p class="mp-page__package-subtitle">{pkg.subtitle}</p>
                  </div>
                  {pkg.badge && <span class="mp-page__package-badge">{pkg.badge}</span>}
                  {isPlatinum && <span class="mp-page__package-badge mp-page__package-badge--platinum">Top Tier</span>}
                </div>
                <p class="mp-page__package-coverage" aria-label="Property coverage">
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M12 3 4 9v12h5v-7h6v7h5V9z"/></svg>
                  <span>{pkg.coverage}</span>
                </p>
                <p class="mp-page__package-price">
                  {pkg.price}
                  <span class="mp-page__package-suffix">{pkg.priceSuffix}</span>
                </p>
                <ul class="mp-page__package-includes">
                  {pkg.features.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <p class="mp-page__package-best-for">{pkg.bestFor}</p>
                <a class="btn btn--ghost mp-page__package-cta" href="#enquiry">Enquire about {pkg.tier} <span class="arrow">→</span></a>
              </article>
            );
          })}
        </div>
        <p class="mp-page__small-print">{packagesSmallPrint}</p>

        <section class="mp-page__platinum-scale" aria-labelledby="platinum-scale-heading">
          <div class="mp-page__platinum-scale-inner">
            <header class="mp-page__platinum-scale-head">
              <span class="mp-page__platinum-scale-eyebrow">Platinum · Portfolio</span>
              <h3 id="platinum-scale-heading" class="mp-page__platinum-scale-title">
                {platinumAllowanceHeading}
              </h3>
              <p class="mp-page__platinum-scale-lead">{platinumAllowanceLead}</p>
            </header>

            <ul class="mp-page__platinum-allowance" aria-label="Property allowance pricing">
              {platinumAllowanceRows.map((row, i) => (
                <li class="mp-page__platinum-allowance-row reveal" style={`--i:${i}`}>
                  <span class="mp-page__platinum-allowance-range">{row.range}</span>
                  <span class="mp-page__platinum-allowance-price">{row.pricing}</span>
                </li>
              ))}
            </ul>

            <div class="mp-page__platinum-info" aria-labelledby="platinum-info-heading">
              <h4 id="platinum-info-heading" class="mp-page__platinum-info-title">Important Information</h4>
              <ul class="mp-page__platinum-info-list">
                {platinumImportantInfo.map((item) => (
                  <li>
                    <span class="mp-page__platinum-info-icon" aria-hidden="true">i</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a class="btn mp-page__platinum-info-cta" href="#enquiry">
                Request a Portfolio Survey <span class="arrow">→</span>
              </a>
            </div>
          </div>
        </section>
      </div>
    </section>

    <section class="mp-page__agreement" aria-labelledby="agreement-heading">
      <div class="container mp-page__agreement-inner">
        <div class="mp-page__agreement-copy">
          <h2 id="agreement-heading" class="mp-page__section-title">Your Maintenance Agreement</h2>
          <p class="mp-page__section-lead">
            Every plan comes with a clear, professional agreement — setting out your package, visit
            schedule, and terms in black and white. No surprises, just complete peace of mind.
          </p>
          <ul class="mp-page__agreement-tips">
            <li>
              <span class="mp-page__agreement-tip-icon" set:html={checkIcon} />
              <div>
                <strong>One simple document</strong>
                <span>Your package, schedule, and pricing — all on a single page.</span>
              </div>
            </li>
            <li>
              <span class="mp-page__agreement-tip-icon" set:html={checkIcon} />
              <div>
                <strong>Transparent pricing</strong>
                <span>Fixed monthly fee, fully itemised. No surprise call-out charges.</span>
              </div>
            </li>
            <li>
              <span class="mp-page__agreement-tip-icon" set:html={checkIcon} />
              <div>
                <strong>Easy to cancel</strong>
                <span>30 days' notice after the initial 12-month term. No hidden hoops.</span>
              </div>
            </li>
          </ul>
          <div class="mp-page__agreement-cta">
            <a class="btn" href="#enquiry">Request Your Agreement <span class="arrow">→</span></a>
            <a class="btn btn--ghost" href={`tel:${maintenancePhone}`}>Call {maintenancePhoneDisplay}</a>
          </div>
        </div>
        <figure class="mp-page__agreement-stage">
          <div class="mp-page__agreement-shadow" aria-hidden="true"></div>
          <img
            src={agreementPreview.src}
            alt={agreementPreview.alt}
            class="mp-page__agreement-doc"
            loading="lazy"
            width="1200"
            height="1697"
          />
        </figure>
      </div>
    </section>

    <section class="mp-page__section mp-page__section--included" aria-labelledby="included-heading">
      <div class="container">
        <h2 id="included-heading" class="mp-page__section-title">What's Included With Every Plan</h2>
        <ul class="mp-page__features">
          {includedFeatures.map((feature, i) => (
            <li class="mp-page__feature reveal" style={`--i:${i % 10}`}>
              <span class="mp-page__feature-icon" set:html={checkIcon} />
              <strong class="mp-page__feature-text">{feature}</strong>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__band mp-page__section--excluded" aria-labelledby="excluded-heading">
      <div class="container">
        <h2 id="excluded-heading" class="mp-page__section-title">What's Not Included</h2>
        <p class="mp-page__section-lead">
          We believe in being upfront — these items sit outside every maintenance plan and are quoted
          separately when needed.
        </p>
        <ul class="mp-page__exclusions">
          {excludedFeatures.map((item, i) => (
            <li class="mp-page__exclusion reveal" style={`--i:${i % 8}`}>
              <span class="mp-page__mark mp-page__mark--bad" aria-hidden="true">✕</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__section" aria-labelledby="terms-heading">
      <div class="container">
        <h2 id="terms-heading" class="mp-page__section-title">Straightforward Contracts. No Nasty Surprises.</h2>
        <ul class="mp-page__terms">
          {contractTerms.map((term, i) => (
            <li class="mp-page__term reveal" style={`--i:${i % 8}`}>
              <span class="mp-page__term-icon" set:html={termIcon} />
              <div>
                <h3>{term.title}</h3>
                <p>{term.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__band" aria-labelledby="gallery-heading">
      <div class="container">
        <h2 id="gallery-heading" class="mp-page__section-title">The Difference Maintenance Makes</h2>
        <!-- TODO: replace with real before/after maintenance photos when available -->
        <div class="mp-page__gallery">
          {galleryImages.map((img, i) => (
            <figure class="mp-page__gallery-tile reveal" style={`--i:${i % 6}`}>
              <img src={img.src} alt={img.alt} loading="lazy" width="640" height="400" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="mp-page__band mp-page__enquiry" id="enquiry" aria-labelledby="enquiry-heading">
      <div class="container">
        <h2 id="enquiry-heading" class="mp-page__section-title mp-page__section-title--enquiry">Get Started — Free Site Survey</h2>
        <p class="mp-page__section-lead mp-page__section-lead--enquiry">
          Tell us about your property and we'll book a free survey — no obligation, no hard sell.
        </p>
        <form
          class="mp-page__form"
          name="maintenance-enquiry"
          method="POST"
          action={netlifyAction}
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          data-success-url={successUrl}
          aria-label="Maintenance plan enquiry"
        >
          <input type="hidden" name="form-name" value="maintenance-enquiry" />
          <p class="visually-hidden" aria-hidden="true">
            <label>Don't fill this in: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <div class="mp-page__form-grid">
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-name">Name</label>
              <input id="enquiry-name" name="name" type="text" required autocomplete="name" placeholder="Name" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-company">Company / Organisation</label>
              <input id="enquiry-company" name="company" type="text" required placeholder="Company / Organisation" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-phone">Phone number</label>
              <input id="enquiry-phone" name="phone" type="tel" required autocomplete="tel" placeholder="Phone number" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-email">Email</label>
              <input id="enquiry-email" name="email" type="email" required autocomplete="email" placeholder="Email" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-type">Property type</label>
              <select id="enquiry-type" name="property_type" required>
                <option value="" disabled selected>Property type</option>
                {surveyPropertyTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-plan">Preferred plan</label>
              <select id="enquiry-plan" name="preferred_plan" required>
                <option value="" disabled selected>Preferred plan</option>
                {planOptions.map((plan) => (
                  <option value={plan}>{plan}</option>
                ))}
              </select>
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-units">Number of offices / areas covered</label>
              <input id="enquiry-units" name="units" type="number" min="1" placeholder="Number of offices / areas covered" />
            </div>
            <div class="mp-page__field mp-page__field--full">
              <label class="visually-hidden" for="enquiry-situation">Current situation</label>
              <textarea
                id="enquiry-situation"
                name="situation"
                rows="4"
                placeholder="Tell us about your property and any current issues…"
              ></textarea>
            </div>
          </div>
          <label class="mp-page__consent">
            <input type="checkbox" name="consent" value="yes" required />
            <span>
              I agree to the <a href="/privacy/">privacy policy</a> and
              <a href="/terms/">terms of service</a>.
            </span>
          </label>
          <p class="mp-page__error" role="alert" hidden>Something went wrong. Please call us or try again.</p>
          <button type="submit" class="btn mp-page__submit">Book My Free Survey <span class="arrow">→</span></button>
        </form>
      </div>
    </section>

    <section class="mp-page__section mp-page__faqs" aria-label="Frequently asked questions">
      <div class="container">
        <h2 class="mp-page__section-title">Common Questions</h2>
        <div class="mp-page__faq-list">
          {maintenanceFaqs.map((item) => (
            <details class="mp-page__faq">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="mp-page__trust" aria-label="Why choose us">
      <div class="container">
        <ul class="mp-page__trust-list">
          {trustBarItems.map((item) => (
            <li>
              <span class="mp-page__trust-star" aria-hidden="true">★</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section
      class="mp-page__final"
      aria-labelledby="final-cta-heading"
      style={`background-image: url('${finalCtaImage.src}')`}
    >
      <div class="mp-page__final-overlay">
        <div class="container mp-page__final-inner">
          <h2 id="final-cta-heading" class="display h2 mp-page__final-title">
            <span class="mp-page__final-line">Not sure which plan</span>
            <span class="mp-page__final-line">is right for you?</span>
          </h2>
          <p class="lead">
            We'll come to your property, assess the condition, and recommend the right package —
            completely free of charge, with no obligation.
          </p>
          <div class="mp-page__final-actions">
            <a class="btn" href="#enquiry">Book a Free Site Survey <span class="arrow">→</span></a>
            <a class="btn btn--ghost btn--ghost-inv" href={`tel:${maintenancePhone}`}>Call {maintenancePhoneDisplay}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const platinumCard = document.querySelector('.mp-page__package--platinum');
  if (platinumCard && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const fireConfetti = () => {
      platinumCard.classList.remove('is-firing');
      void (platinumCard as HTMLElement).offsetWidth;
      platinumCard.classList.add('is-firing');
    };
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          fireConfetti();
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.45 });
    io.observe(platinumCard);
    platinumCard.addEventListener('mouseenter', fireConfetti);
  }

  document.querySelectorAll('form.mp-page__form[data-netlify]').forEach((form) => {
    if (form.dataset.netlifyBound) return;
    form.dataset.netlifyBound = 'true';

    const successUrl = form.dataset.successUrl ?? '/thank-you/';
    const errorEl = form.querySelector('.mp-page__error');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorEl?.setAttribute('hidden', '');

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute('aria-busy', 'true');
      }

      const body = new URLSearchParams();
      for (const [key, value] of new FormData(form).entries()) {
        body.append(key, String(value));
      }

      try {
        const response = await fetch('/.netlify/functions/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });

        const result = response.ok ? await response.json().catch(() => null) : null;
        if (response.ok && result?.ok) {
          const name = body.get('name');
          const dest = new URL(successUrl, window.location.origin);
          if (name && typeof name === 'string') {
            dest.searchParams.set('name', name.trim());
          }
          window.location.assign(dest.pathname + dest.search + dest.hash);
          return;
        }
      } catch {
        /* show error below */
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.removeAttribute('aria-busy');
      }
      errorEl?.removeAttribute('hidden');
    });
  });
</script>

<style>
  .mp-page {
    --page-stack-gap: 50px;
    overflow-x: clip;
    max-width: 100%;
  }

  .mp-page__hero {
    position: relative;
    background-color: var(--c-ink);
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  .mp-page__hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(14, 14, 16, 0.72) 0%,
      rgba(14, 14, 16, 0.88) 100%
    );
    padding: calc(38px + var(--page-stack-gap)) 0 clamp(56px, 8vw, 88px);
  }
  .mp-page__hero-title {
    margin-top: 14px;
    max-width: 22ch;
    color: #fff;
  }
  .mp-page__hero-lead {
