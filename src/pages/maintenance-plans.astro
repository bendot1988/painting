---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import {
  asPaintingWay,
  contractTerms,
  galleryImages,
  finalCtaImage,
  heroImage,
  includedFeatures,
  maintenanceFaqs,
  maintenancePlansPageMeta,
  packages,
  packagesSmallPrint,
  planOptions,
  platinumPackage,
  pricingGuideFootnote,
  pricingGuideRows,
  sectors,
  surveyPropertyTypes,
  traditionalApproach,
} from '~/data/maintenance-plans-page';
import { thankYouPageHref } from '~/data/contact';
import { buildMaintenancePlansJsonLd } from '~/utils/maintenance-plans-json-ld';
import { normalizeTrailingSlash } from '~/utils/site-url';

const jsonLd = buildMaintenancePlansJsonLd();
const netlifyAction = normalizeTrailingSlash(Astro.url.pathname);
const successUrl = thankYouPageHref;

const sectorIcon = `<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>`;
const checkIcon = `<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>`;
const termIcon = `<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>`;
---
<Layout
  title={maintenancePlansPageMeta.title}
  description={maintenancePlansPageMeta.description}
  canonical={maintenancePlansPageMeta.canonical}
  jsonLd={jsonLd}
>
  <Header />
  <main id="main" class="mp-page">
    <section
      class="mp-page__hero"
      aria-labelledby="mp-heading"
      style={`background-image: url('${heroImage.src}')`}
    >
      <div class="mp-page__hero-overlay">
        <div class="container">
          <span class="eyebrow eyebrow--inv">Commercial · Maintenance</span>
          <h1 id="mp-heading" class="display h1 mp-page__hero-title">
            Commercial Decorating <span class="painted-word painted-word--yellow">Maintenance Plans</span>
          </h1>
          <p class="lead mp-page__hero-lead">
            Stop waiting until your building looks tired. Keep it maintained year-round for a fixed
            monthly cost — no surprise invoices, no big redecoration bills.
          </p>
          <div class="mp-page__hero-actions">
            <a class="btn" href="#enquiry">Request a Free Site Survey <span class="arrow">→</span></a>
            <a class="btn btn--ghost btn--ghost-inv" href="#packages">View Packages</a>
          </div>
        </div>
      </div>
    </section>

    <section class="mp-page__section" aria-labelledby="compare-heading">
      <div class="container">
        <h2 id="compare-heading" class="mp-page__section-title">Two ways to manage decorating</h2>
        <div class="mp-page__compare">
          <div class="mp-page__compare-col mp-page__compare-col--negative">
            <h3>The Traditional Approach</h3>
            <ul>
              {traditionalApproach.map((point) => (
                <li><span class="mp-page__mark mp-page__mark--bad" aria-hidden="true">✕</span>{point}</li>
              ))}
            </ul>
          </div>
          <div class="mp-page__compare-col mp-page__compare-col--positive">
            <h3>The AS Painting Way</h3>
            <ul>
              {asPaintingWay.map((point) => (
                <li><span class="mp-page__mark mp-page__mark--good" aria-hidden="true">✓</span>{point}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="mp-page__band" aria-labelledby="sectors-heading">
      <div class="container">
        <h2 id="sectors-heading" class="mp-page__section-title">
          Designed for Property Owners and Managers Who Can't Afford Downtime
        </h2>
        <ul class="mp-page__sectors">
          {sectors.map((sector, i) => (
            <li class="mp-page__sector reveal" style={`--i:${i % 10}`}>
              <span class="mp-page__sector-icon" set:html={sectorIcon} />
              <span>{sector}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__section mp-page__section--included" aria-labelledby="included-heading">
      <div class="container">
        <h2 id="included-heading" class="mp-page__section-title">What Every Plan Covers</h2>
        <ul class="mp-page__features">
          {includedFeatures.map((feature, i) => (
            <li class="mp-page__feature reveal" style={`--i:${i % 10}`}>
              <span class="mp-page__feature-icon" set:html={checkIcon} />
              <strong class="mp-page__feature-text">{feature}</strong>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__band" id="packages" aria-labelledby="packages-heading">
      <div class="container">
        <h2 id="packages-heading" class="mp-page__section-title">Choose Your Cover Level</h2>
        <div class="mp-page__packages">
          {packages.map((pkg, i) => (
            <article class:list={['mp-page__package', { 'mp-page__package--featured': pkg.badge }]} style={`--i:${i}`}>
              {pkg.badge && <span class="mp-page__package-badge">{pkg.badge}</span>}
              <h3>{pkg.tier}</h3>
              <p class="mp-page__package-price">{pkg.price}</p>
              <ul class="mp-page__package-includes">
                {pkg.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              {pkg.excludes && (
                <ul class="mp-page__package-excludes">
                  {pkg.excludes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
              <a class="btn btn--ghost mp-page__package-cta" href="#enquiry">Enquire about {pkg.tier} <span class="arrow">→</span></a>
            </article>
          ))}
        </div>

        <div class="mp-page__platinum-shell reveal">
          <div class="mp-page__platinum-border" aria-hidden="true"></div>
          <article class="mp-page__platinum">
            <div class="mp-page__platinum-head">
              <div>
                <h3>{platinumPackage.tier}</h3>
                <p class="mp-page__platinum-subtitle">{platinumPackage.subtitle}</p>
              </div>
              <p class="mp-page__platinum-price">{platinumPackage.price}</p>
            </div>
            <dl class="mp-page__platinum-grid">
              {platinumPackage.features.map((feature) => (
                <div class="mp-page__platinum-row">
                  <dt>{feature.label}</dt>
                  <dd>{feature.value}</dd>
                </div>
              ))}
            </dl>
            <p class="mp-page__platinum-footnote">{platinumPackage.footnote}</p>
            <a class="btn mp-page__platinum-cta" href={platinumPackage.cta.href}>
              {platinumPackage.cta.label} <span class="arrow">→</span>
            </a>
          </article>
        </div>

        <p class="mp-page__small-print">{packagesSmallPrint}</p>
      </div>
    </section>

    <section class="mp-page__band mp-page__band--pricing" aria-labelledby="pricing-heading">
      <div class="container">
        <h2 id="pricing-heading" class="mp-page__section-title mp-page__section-title--pricing">What Does It Cost?</h2>
        <p class="mp-page__section-lead mp-page__section-lead--pricing">
          Every building is different, but here's a rough guide to help you budget:
        </p>
        <ul class="mp-page__pricing">
          {pricingGuideRows.map((row, i) => (
            <li class="mp-page__pricing-row reveal" style={`--i:${i}`}>
              <span class="mp-page__pricing-type">{row.property_type}</span>
              <span class="mp-page__pricing-range">{row.range}</span>
            </li>
          ))}
        </ul>
        <p class="mp-page__footnote">{pricingGuideFootnote}</p>
      </div>
    </section>

    <section class="mp-page__band" aria-labelledby="terms-heading">
      <div class="container">
        <h2 id="terms-heading" class="mp-page__section-title">Straightforward Contracts. No Nasty Surprises.</h2>
        <ul class="mp-page__terms">
          {contractTerms.map((term, i) => (
            <li class="mp-page__term reveal" style={`--i:${i % 8}`}>
              <span class="mp-page__term-icon" set:html={termIcon} />
              <div>
                <h3>{term.title}</h3>
                <p>{term.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mp-page__section" aria-labelledby="gallery-heading">
      <div class="container">
        <h2 id="gallery-heading" class="mp-page__section-title">The Difference Maintenance Makes</h2>
        <!-- TODO: replace with real before/after maintenance photos when available -->
        <div class="mp-page__gallery">
          {galleryImages.map((img, i) => (
            <figure class="mp-page__gallery-tile reveal" style={`--i:${i % 6}`}>
              <img src={img.src} alt={img.alt} loading="lazy" width="640" height="400" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="mp-page__band mp-page__enquiry" id="enquiry" aria-labelledby="enquiry-heading">
      <div class="container">
        <h2 id="enquiry-heading" class="mp-page__section-title mp-page__section-title--enquiry">Get Started — Free Site Survey</h2>
        <p class="mp-page__section-lead mp-page__section-lead--enquiry">
          Tell us about your property and we'll book a free survey — no obligation, no hard sell.
        </p>
        <form
          class="mp-page__form"
          name="maintenance-enquiry"
          method="POST"
          action={netlifyAction}
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          data-success-url={successUrl}
          aria-label="Maintenance plan enquiry"
        >
          <input type="hidden" name="form-name" value="maintenance-enquiry" />
          <p class="visually-hidden" aria-hidden="true">
            <label>Don't fill this in: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <div class="mp-page__form-grid">
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-name">Name</label>
              <input id="enquiry-name" name="name" type="text" required autocomplete="name" placeholder="Name" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-company">Company / Organisation</label>
              <input id="enquiry-company" name="company" type="text" required placeholder="Company / Organisation" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-phone">Phone number</label>
              <input id="enquiry-phone" name="phone" type="tel" required autocomplete="tel" placeholder="Phone number" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-email">Email</label>
              <input id="enquiry-email" name="email" type="email" required autocomplete="email" placeholder="Email" />
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-type">Property type</label>
              <select id="enquiry-type" name="property_type" required>
                <option value="" disabled selected>Property type</option>
                {surveyPropertyTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-plan">Preferred plan</label>
              <select id="enquiry-plan" name="preferred_plan" required>
                <option value="" disabled selected>Preferred plan</option>
                {planOptions.map((plan) => (
                  <option value={plan}>{plan}</option>
                ))}
              </select>
            </div>
            <div class="mp-page__field">
              <label class="visually-hidden" for="enquiry-units">Number of units / buildings</label>
              <input id="enquiry-units" name="units" type="number" min="1" placeholder="Number of units / buildings" />
            </div>
            <div class="mp-page__field mp-page__field--full">
              <label class="visually-hidden" for="enquiry-situation">Current situation</label>
              <textarea
                id="enquiry-situation"
                name="situation"
                rows="4"
                placeholder="Tell us about your property and any current issues…"
              ></textarea>
            </div>
          </div>
          <label class="mp-page__consent">
            <input type="checkbox" name="consent" value="yes" required />
            <span>
              I agree to the <a href="/privacy/">privacy policy</a> and
              <a href="/terms/">terms of service</a>.
            </span>
          </label>
          <p class="mp-page__error" role="alert" hidden>Something went wrong. Please call us or try again.</p>
          <button type="submit" class="btn mp-page__submit">Book My Free Survey <span class="arrow">→</span></button>
        </form>
      </div>
    </section>

    <section class="mp-page__section mp-page__faqs" aria-label="Frequently asked questions">
      <div class="container">
        <h2 class="mp-page__section-title">Common Questions</h2>
        <div class="mp-page__faq-list">
          {maintenanceFaqs.map((item) => (
            <details class="mp-page__faq">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section
      class="mp-page__final"
      aria-labelledby="final-cta-heading"
      style={`background-image: url('${finalCtaImage.src}')`}
    >
      <div class="mp-page__final-overlay">
        <div class="container mp-page__final-inner">
          <h2 id="final-cta-heading" class="display h2 mp-page__final-title">
            <span class="mp-page__final-line">Not sure which plan</span>
            <span class="mp-page__final-line">is right for you?</span>
          </h2>
          <p class="lead">
            We'll come to your property, assess the condition, and recommend a plan — completely free
            of charge, with no obligation.
          </p>
          <a class="btn" href="#enquiry">Book a Free Site Survey <span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('form.mp-page__form[data-netlify]').forEach((form) => {
    if (form.dataset.netlifyBound) return;
    form.dataset.netlifyBound = 'true';

    const successUrl = form.dataset.successUrl ?? '/thank-you/';
    const errorEl = form.querySelector('.mp-page__error');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorEl?.setAttribute('hidden', '');

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute('aria-busy', 'true');
      }

      const body = new URLSearchParams();
      for (const [key, value] of new FormData(form).entries()) {
        body.append(key, String(value));
      }

      try {
        const response = await fetch('/.netlify/functions/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });

        const result = response.ok ? await response.json().catch(() => null) : null;
        if (response.ok && result?.ok) {
          const name = body.get('name');
          const dest = new URL(successUrl, window.location.origin);
          if (name && typeof name === 'string') {
            dest.searchParams.set('name', name.trim());
          }
          window.location.assign(dest.pathname + dest.search + dest.hash);
          return;
        }
      } catch {
        /* show error below */
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.removeAttribute('aria-busy');
      }
      errorEl?.removeAttribute('hidden');
    });
  });
</script>

<style>
  .mp-page {
    --page-stack-gap: 50px;
  }

  .mp-page__hero {
    position: relative;
    background-color: var(--c-ink);
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  .mp-page__hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(14, 14, 16, 0.72) 0%,
      rgba(14, 14, 16, 0.88) 100%
    );
    padding: calc(38px + var(--page-stack-gap)) 0 clamp(56px, 8vw, 88px);
  }
  .mp-page__hero-title {
    margin-top: 14px;
    max-width: 18ch;
    color: #fff;
  }
  .mp-page__hero-lead {
    max-width: 54ch;
    margin-top: 16px;
    color: #cfcdc8;
  }
  .mp-page__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .btn--ghost-inv {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    box-shadow: none;
  }
  .btn--ghost-inv:hover,
  .btn--ghost-inv:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  .mp-page__band {
    background: var(--bg-alt);
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .mp-page__section {
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .mp-page__section-title {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    color: var(--c-ink);
  }
  .mp-page__section-lead {
    max-width: 58ch;
    margin: 0 0 28px;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.55;
  }
  .mp-page__section-lead--enquiry {
    max-width: none;
    text-align: center;
    white-space: nowrap;
  }
  .mp-page__section-title--enquiry {
    text-align: center;
  }

  .mp-page__compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-top: 28px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .mp-page__compare-col {
    padding: clamp(24px, 3vw, 32px);
    background: #fff;
  }
  .mp-page__compare-col:first-child {
    border-right: 1px solid rgba(14, 14, 16, 0.1);
  }
  .mp-page__compare-col h3 {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
  }
  .mp-page__compare-col ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }
  .mp-page__compare-col li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    line-height: 1.45;
  }
  .mp-page__mark {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .mp-page__mark--bad {
    background: rgba(212, 38, 44, 0.12);
    color: var(--c-red);
  }
  .mp-page__mark--good {
    background: rgba(126, 211, 33, 0.22);
    color: #4a9a12;
  }
  .mp-page__compare-col--negative {
    background: rgba(212, 38, 44, 0.04);
    border-left: 4px solid var(--c-red);
  }
  .mp-page__compare-col--negative h3 {
    color: var(--c-red);
  }
  .mp-page__compare-col--negative li {
    color: #6b3a3c;
  }
  .mp-page__compare-col--positive {
    background: rgba(126, 211, 33, 0.08);
    border-left: 4px solid var(--c-lime);
  }
  .mp-page__compare-col--positive h3 {
    color: #3d7a0f;
  }
  .mp-page__compare-col--positive li {
    color: #2d5012;
    font-weight: 600;
  }

  .mp-page__sectors {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .mp-page__sector {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    background: #fff;
    border-radius: 14px;
    box-shadow: var(--shadow-sm);
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
    transition-delay: calc(var(--i) * 40ms);
  }
  .mp-page__sector-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 214, 10, 0.18);
    color: var(--c-ink);
    flex-shrink: 0;
  }

  .mp-page__section--included {
    background: rgba(126, 211, 33, 0.06);
  }

  .mp-page__features {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .mp-page__feature {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: #fff;
    border-radius: 14px;
    border: 1.5px solid rgba(126, 211, 33, 0.35);
    box-shadow: 0 2px 12px rgba(126, 211, 33, 0.1);
    transition-delay: calc(var(--i) * 40ms);
  }
  .mp-page__feature-icon {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--c-lime);
    color: #fff;
    flex-shrink: 0;
  }
  .mp-page__feature-icon :global(svg) {
    width: 18px;
    height: 18px;
  }
  .mp-page__feature-text {
    font-size: 15px;
    line-height: 1.4;
    font-weight: 700;
    color: #2d5012;
  }

  .mp-page__packages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 28px;
  }
  .mp-page__package {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 18px;
    padding: 24px 22px 22px;
    box-shadow: var(--shadow-sm);
    border-top: 4px solid var(--c-blue);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
    transition-delay: calc(var(--i) * 50ms);
  }
  .mp-page__package:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .mp-page__package--featured {
    border-top-color: var(--c-yellow);
    box-shadow: var(--shadow-md);
  }
  .mp-page__package-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--c-yellow);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-ink);
  }
