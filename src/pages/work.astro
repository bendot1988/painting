---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { workItems } from '~/data/showcase-work';

const commercialCount = workItems.filter((i) => i.tag === 'commercial').length;
const domesticCount = workItems.filter((i) => i.tag === 'domestic').length;

const pageTitle = 'Our Work — A.S Painting Contractors';
const pageDescription =
  'Recent commercial and domestic painting projects across Leicestershire — offices, factories, shops, warehouses and homes.';
---
<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main id="main" class="work-page">
    <section class="work-page__hero" aria-labelledby="work-heading">
      <div class="container">
        <span class="eyebrow">Our work</span>
        <h1 id="work-heading" class="display h1">
          Real jobs. Real <span class="painted-word painted-word--lime">Leicester</span> walls.
        </h1>
        <p class="lead work-page__intro">
          A selection of recent commercial and domestic projects — factory refurbs,
          office fit-outs, shopfronts and family homes across Leicestershire.
        </p>
        <div class="work-page__filters" role="tablist" aria-label="Filter projects">
          <button class="work-page__filter is-active" type="button" role="tab" data-filter="all" aria-selected="true">
            All work <span>{workItems.length}</span>
          </button>
          <button class="work-page__filter" type="button" role="tab" data-filter="commercial" aria-selected="false">
            Commercial <span>{commercialCount}</span>
          </button>
          <button class="work-page__filter" type="button" role="tab" data-filter="domestic" aria-selected="false">
            Domestic <span>{domesticCount}</span>
          </button>
        </div>
      </div>
    </section>

    <section class="work-page__gallery" aria-label="Project gallery">
      <div class="container">
        <div class="work-page__grid" data-work-grid>
          {workItems.map((item, i) => (
            <article
              class={`work-card work-card--${item.tag} reveal`}
              data-tag={item.tag}
              style={`--i:${i % 8}`}
            >
              <div class="work-card__media">
                <img src={item.src} alt={item.alt} loading="lazy" width="640" height="480" />
              </div>
              <div class="work-card__body">
                <span class={`tag tag--${item.tag}`}>
                  {item.tag === 'commercial' ? 'Commercial' : 'Domestic'}
                </span>
                <h2>{item.title}</h2>
                <p>{item.meta}</p>
              </div>
            </article>
          ))}
        </div>
        <p class="work-page__cta">
          <a class="btn" href="/#quote">Get a free quote <span class="arrow">→</span></a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('.work-card');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      filters.forEach((b) => {
        b.classList.toggle('is-active', b === btn);
        b.setAttribute('aria-selected', String(b === btn));
      });

      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.tag === filter;
        card.hidden = !show;
      });
    });
  });
</script>

<style>
  .work-page {
    --work-stack-gap: 50px;
  }
  .work-page__hero {
    padding-top: calc(38px + var(--work-stack-gap));
    padding-bottom: 0;
  }
  .work-page__hero h1 {
    margin-top: 14px;
    max-width: 16ch;
  }
  .work-page__intro {
    max-width: 52ch;
    margin-top: 16px;
  }

  .work-page__filters {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
    margin-bottom: var(--work-stack-gap);
    padding: 6px;
    background: rgba(14, 14, 16, 0.05);
    border: 1px solid rgba(14, 14, 16, 0.08);
    border-radius: 999px;
  }
  .work-page__filter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0;
    background: transparent;
    color: var(--c-graphite);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .work-page__filter span {
    font-size: 12px;
    font-weight: 700;
    color: var(--c-stone);
  }
  .work-page__filter:hover {
    background: rgba(14, 14, 16, 0.06);
  }
  .work-page__filter.is-active {
    background: var(--c-yellow);
    color: var(--c-ink);
  }
  .work-page__filter.is-active span {
    color: var(--c-ink);
    opacity: 0.65;
  }

  .work-page__gallery {
    background: var(--bg-alt);
    padding-top: 0;
    padding-bottom: clamp(72px, 9vw, 120px);
  }
  .work-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .work-card {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition-delay: calc(var(--i) * 50ms);
  }
  .work-card--commercial {
    border-top: 4px solid var(--c-yellow);
  }
  .work-card--domestic {
    border-top: 4px solid var(--c-pink);
  }
  .work-card[hidden] {
    display: none;
  }
  .work-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e8e6;
  }
  .work-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .work-card:hover .work-card__media img {
    transform: scale(1.05);
  }
  .work-card__body {
    padding: 18px 20px 22px;
  }
  .work-card__body h2 {
    margin: 10px 0 6px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--c-ink);
  }
  .work-card__body p {
    margin: 0;
    font-size: 14px;
    color: var(--c-stone);
  }

  .work-page__cta {
    margin: 40px 0 0;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .work-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .work-page__grid {
      grid-template-columns: 1fr;
    }
    .work-page__filters {
      width: 100%;
      border-radius: 16px;
      justify-content: center;
    }
  }
</style>
