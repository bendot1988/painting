---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { contact } from '~/data/contact';
---
<Layout title="Privacy policy — A.S Painting Contractors" description="Privacy policy for A.S Painting Contractors.">
  <Header />
  <main id="main" class="legal-page section">
    <div class="container legal-page__inner">
      <span class="eyebrow">Legal</span>
      <h1 class="display h2">Privacy policy</h1>
      <p class="lead">
        We only use your details to respond to enquiries about painting work.
        We do not sell your data to third parties.
      </p>
      <p>
        If you submit our quote form, we store your name, contact details and
        project information so we can provide a quote and follow up. You can
        ask us to delete your data at any time by emailing
        <a href={`mailto:${contact.email}`}>{contact.email}</a>.
      </p>
      <h2 class="legal-page__h2">Cookies and analytics</h2>
      <p>
        If you choose <strong>Accept</strong> on our cookie notice, we load a privacy-friendly
        analytics script (hosted by Dotwall) that helps us see how many people visit the site and
        which pages they view. It does not use advertising cookies and we do not sell your data.
        You can decline analytics cookies and still use the site normally.
      </p>
      <p>
        Your choice is stored in your browser so we do not ask again on every visit. You can clear
        it anytime by removing site data for as-painting.co.uk in your browser settings.
      </p>
      <p><a class="btn btn--ghost" href="/contact">Back to quote form</a></p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page { padding-block: clamp(120px, 14vw, 160px) clamp(72px, 9vw, 120px); }
  .legal-page__inner { max-width: 60ch; }
  .legal-page h1 { margin: 14px 0 18px; }
  .legal-page__h2 {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 24px);
    margin: 1.75em 0 0.75em;
  }
  .legal-page p { color: var(--c-graphite); line-height: 1.6; margin: 0 0 1em; }
</style>
