---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import AreaLocationMap from '~/components/AreaLocationMap.astro';
import {
  areas,
  areaAccent,
  getAreaBySlug,
  getAreaIntro,
  splitAreaIntro,
  getCommercialContext,
  getDomesticContext,
  getNearbyAreas,
  areaPageTitle,
  areaPageDescription,
} from '~/data/areas';
import { quotePageHref } from '~/data/contact';
import { getAreaGalleryImages } from '~/data/area-gallery';
import { buildAreaPageJsonLd } from '~/utils/area-json-ld';

export function getStaticPaths() {
  return areas.map((area) => ({ params: { slug: area.slug } }));
}

const { slug } = Astro.params;
const area = getAreaBySlug(slug!);

if (!area) {
  return Astro.redirect('/areas');
}

const nearby = getNearbyAreas(area);
const intro = getAreaIntro(area);
const [introColA, introColB] = splitAreaIntro(intro);
const commercialContext = getCommercialContext(area);
const domesticContext = getDomesticContext(area);
const areaIndex = areas.findIndex((a) => a.slug === area.slug);
const accent = areaAccent(areaIndex >= 0 ? areaIndex : 0);
const areaJsonLd = buildAreaPageJsonLd(area, area.faqs);
const galleryImages = getAreaGalleryImages(area.name);

const commercialPoints = [
  'Factories, warehouses and production areas',
  'Offices, corridors and breakout spaces',
  'Retail units, shopfronts and food courts',
  'Schools, halls and education buildings',
  'Out-of-hours and weekend working available',
];

const domesticPoints = [
  'Full house and room-by-room decorating',
  'Kitchens, woodwork, doors and skirting',
  'Exterior render, masonry and garden joinery',
  'Landlord refreshes and pre-sale makeovers',
  'Free home visits with clear fixed quotes',
];
---
<Layout title={areaPageTitle(area.name)} description={areaPageDescription(area)} jsonLd={areaJsonLd}>
  <Header />
  <main id="main" class="area-page">
    <section class="area-page__hero" aria-labelledby="area-heading">
      <div class="container">
        <nav class="area-page__crumb" aria-label="Breadcrumb">
          <a href="/areas">Areas covered</a>
          <span aria-hidden="true">/</span>
          <span>{area.name}</span>
        </nav>
        <div class="area-page__hero-layout">
          <div class="area-page__hero-head">
            <span class="eyebrow">Leicestershire</span>
            <h1 id="area-heading" class="display h1">
              Painting &amp; decorating in <span class="painted-word painted-word--lime">{area.name}.</span>
            </h1>
            <div class="area-page__actions">
              <a class="btn" href={quotePageHref}>Get a free quote <span class="arrow">→</span></a>
              <a class="btn btn--ghost" href="/areas">All areas <span class="arrow">→</span></a>
            </div>
          </div>
          <div class="area-page__hero-map">
            <AreaLocationMap
              name={area.name}
              lat={area.lat}
              lng={area.lng}
              accent={accent}
              mapId={`area-map-${area.slug}`}
            />
          </div>
          <div class="area-page__hero-body">
            <p class="lead area-page__intro-col">{introColA}</p>
            <p class="lead area-page__intro-col">{introColB}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="area-page__band area-page__local" aria-labelledby="local-heading">
      <div class="container">
        <h2 id="local-heading" class="area-page__section-title">Local knowledge</h2>
        <div class="area-page__local-accordions reveal">
          <details class="area-page__local-accordion area-page__local-accordion--lime">
            <summary class="area-page__local-label">Landmarks &amp; town centre</summary>
            <div class="area-page__local-body" set:html={area.localLandmark} />
          </details>
          <details class="area-page__local-accordion area-page__local-accordion--blue">
            <summary class="area-page__local-label">Business parks &amp; industry</summary>
            <div class="area-page__local-body" set:html={area.industrialEstates} />
          </details>
          <details class="area-page__local-accordion area-page__local-accordion--pink">
            <summary class="area-page__local-label">Homes &amp; housing stock</summary>
            <div class="area-page__local-body" set:html={area.housingStock} />
          </details>
        </div>
      </div>
    </section>

    <section class="area-page__services" aria-label="Services in this area">
      <div class="container">
        <div class="area-page__services-grid">
        <article class="area-page__panel reveal">
          <span class="area-page__panel-tag">Commercial</span>
          <h2 class="display h3">Business painting in {area.name}</h2>
          <p>{commercialContext}</p>
          <p class="area-page__panel-note">
            Interior and exterior painting for sites that need to stay operational.
            RAMS, method statements and tidy working included as standard.
          </p>
          <ul>
            {commercialPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
          <a href="/commercial">Commercial services <span class="arrow">→</span></a>
        </article>

        <article class="area-page__panel area-page__panel--domestic reveal">
          <span class="area-page__panel-tag">Domestic</span>
          <h2 class="display h3">Home painting in {area.name}</h2>
          <p>{domesticContext}</p>
          <ul>
            {domesticPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
          <a href="/domestic">Domestic services <span class="arrow">→</span></a>
        </article>
        </div>
      </div>
    </section>

    <section class="area-page__gallery" aria-labelledby="gallery-heading">
      <div class="container">
        <h2 id="gallery-heading" class="area-page__section-title">
          Recent painting work in {area.name}
        </h2>
        <p class="area-page__gallery-intro">
          Commercial and domestic projects across {area.name} and Leicestershire — interiors,
          exteriors, kitchens and industrial units.
        </p>
        <ul class="area-page__gallery-grid reveal">
          {galleryImages.map((img, i) => (
            <li class="area-page__gallery-item" style={`--i:${i % 12}`}>
              <figure>
                <img
                  src={img.src}
                  alt={img.alt}
                  loading={i < 6 ? 'eager' : 'lazy'}
                  width="640"
                  height="480"
                />
              </figure>
            </li>
          ))}
        </ul>
        <p class="area-page__gallery-more">
          <a href="/work">View all our work <span class="arrow">→</span></a>
        </p>
      </div>
    </section>

    <section class="area-page__faqs" aria-labelledby="faq-heading">
      <div class="container">
        <h2 id="faq-heading" class="area-page__section-title">Questions about painting in {area.name}</h2>
        <div class="area-page__faq-list reveal">
          {area.faqs.map((item) => (
            <details class="area-page__faq">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {nearby.length > 0 && (
      <section class="area-page__nearby" aria-labelledby="nearby-heading">
        <div class="container">
          <h2 id="nearby-heading" class="area-page__section-title">Nearby areas we cover</h2>
          <ul class="area-page__nearby-list">
            {nearby.map((n) => (
              <li>
                <a href={`/areas/${n.slug}`}>Painting &amp; decorating in {n.name}</a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section class="area-page__cta-band" aria-label="Get a quote">
      <div class="container">
        <div class="area-page__cta-inner reveal">
          <h2 class="display h3">Need painters in {area.name}?</h2>
          <p>Same-day reply, fixed-price quotes, no hard sell. Call, message or use our form.</p>
          <a class="btn" href={quotePageHref}>Contact us <span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer areaName={area.name} />
</Layout>

<style>
  .area-page {
    --page-stack-gap: 50px;
  }
  .area-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .area-page__crumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-stone);
  }
  .area-page__crumb a {
    color: var(--c-red);
    text-decoration: none;
  }
  .area-page__crumb a:hover {
    text-decoration: underline;
  }
  .area-page__hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 40%);
    grid-template-rows: auto auto;
    column-gap: clamp(28px, 4vw, 52px);
    row-gap: clamp(32px, 5vw, 56px);
    align-items: start;
  }
  .area-page__hero-head {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }
  .area-page__hero-head h1 {
    margin-top: 14px;
    max-width: 16ch;
  }
  .area-page__hero-map {
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
  }
  .area-page__hero-map :global(.area-location-map) {
    height: clamp(240px, 28vw, 320px);
  }
  .area-page__hero-body {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(20px, 3vw, 40px);
    padding-top: 4px;
  }
  .area-page__intro-col {
    margin: 0;
    color: var(--c-graphite);
    font-size: clamp(16px, 1.05vw, 17px);
    line-height: 1.65;
  }
  .area-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .area-page__band {
    background: var(--bg-alt);
    padding: clamp(48px, 6vw, 72px) 0;
  }
  .area-page__local-accordions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }
  .area-page__local-accordion {
    background: #fff;
    border-radius: 16px;
    border-top: 4px solid var(--local-accent, var(--c-lime));
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .area-page__local-accordion--lime {
    --local-accent: var(--c-lime);
  }
  .area-page__local-accordion--blue {
    --local-accent: var(--c-blue);
  }
  .area-page__local-accordion--pink {
    --local-accent: var(--c-pink);
  }
  .area-page__local-label:hover {
    background: rgba(14, 14, 16, 0.03);
  }
  .area-page__local-label {
    list-style: none;
    cursor: pointer;
    margin: 0;
    padding: 18px 48px 18px 24px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--c-ink);
    position: relative;
  }
  .area-page__local-label::-webkit-details-marker {
    display: none;
  }
  .area-page__local-label::after {
    content: "+";
    position: absolute;
    right: 22px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 22px;
    font-weight: 400;
    line-height: 1;
    color: var(--local-accent, var(--c-lime));
  }
  .area-page__local-accordion[open] .area-page__local-label::after {
    content: "−";
  }
  .area-page__local-body {
    padding: 0 24px 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--c-graphite);
  }
  .area-page__local-body :global(p) {
    margin: 0 0 12px;
  }
  .area-page__local-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .area-page__local-body :global(strong) {
    font-weight: 700;
    color: var(--c-ink);
  }

  .area-page__services {
    padding: clamp(48px, 6vw, 72px) 0 0;
  }
  .area-page__services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    max-width: 100%;
  }
  .area-page__panel {
    padding: clamp(24px, 3vw, 32px);
    border-radius: 20px;
    background: var(--bg-alt);
    border: 1px solid rgba(14, 14, 16, 0.08);
    border-top: 4px solid var(--c-yellow);
  }
  .area-page__panel--domestic {
    border-top-color: var(--c-pink);
  }
  .area-page__panel-tag {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-stone);
  }
  .area-page__panel h2 {
    margin: 0 0 12px;
    max-width: 20ch;
  }
  .area-page__panel > p {
    margin: 0 0 16px;
    color: var(--c-graphite);
    line-height: 1.55;
    font-size: 15px;
  }
  .area-page__panel-note {
    font-size: 14px !important;
    color: var(--c-stone) !important;
  }
  .area-page__panel ul {
    margin: 0 0 20px;
    padding-left: 1.2em;
    color: var(--c-graphite);
    font-size: 14.5px;
    line-height: 1.5;
  }
  .area-page__panel li + li {
    margin-top: 6px;
  }
  .area-page__panel > a {
    font-weight: 700;
    color: var(--c-red);
    text-decoration: none;
  }
  .area-page__panel > a:hover {
    text-decoration: underline;
  }

  .area-page__gallery {
    padding: clamp(48px, 6vw, 72px) 0 0;
    background: var(--bg-alt);
  }
  .area-page__gallery-intro {
    margin: 0 0 24px;
    max-width: 52ch;
    font-size: 16px;
    line-height: 1.55;
    color: var(--c-graphite);
  }
  .area-page__gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .area-page__gallery-item {
    transition-delay: calc(var(--i) * 35ms);
  }
  .area-page__gallery-item figure {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
  }
  .area-page__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s var(--ease);
  }
  .area-page__gallery-item:hover img {
    transform: scale(1.04);
  }
  .area-page__gallery-more {
    margin: 28px 0 0;
    text-align: center;
  }
  .area-page__gallery-more a {
    font-weight: 700;
    color: var(--c-red);
    text-decoration: none;
  }
  .area-page__gallery-more a:hover {
    text-decoration: underline;
  }

  .area-page__faqs {
    padding: clamp(48px, 6vw, 72px) 0 0;
  }
  .area-page__faq-list {
    max-width: 720px;
  }
  .area-page__faq {
    border-top: 1px solid rgba(14, 14, 16, 0.1);
  }
  .area-page__faq:last-of-type {
    border-bottom: 1px solid rgba(14, 14, 16, 0.1);
  }
  .area-page__faq summary {
    list-style: none;
    cursor: pointer;
    padding: 16px 32px 16px 0;
    font-weight: 600;
    font-size: 15px;
    color: var(--c-ink);
    position: relative;
  }
  .area-page__faq summary::-webkit-details-marker {
    display: none;
  }
  .area-page__faq summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 20px;
    color: var(--c-red);
  }
  .area-page__faq[open] summary::after {
    content: '−';
  }
  .area-page__faq p {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-graphite);
  }

  .area-page__nearby {
    padding: var(--page-stack-gap) 0 0;
  }
  .area-page__section-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 700;
    margin: 0 0 16px;
  }
  .area-page__nearby-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .area-page__nearby-list a {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgba(14, 14, 16, 0.1);
    font-size: 14px;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .area-page__nearby-list a:hover {
    border-color: var(--c-lime);
    color: var(--c-red);
  }

  .area-page__cta-band {
    padding: var(--page-stack-gap) 0 clamp(72px, 9vw, 120px);
  }
  .area-page__cta-inner {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    text-align: center;
    padding: clamp(32px, 4vw, 48px);
    border-radius: 20px;
    color: var(--c-paper);
    background-color: var(--c-ink);
    background-image: url('/images/brand/paint-strokes.jpg');
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(14, 14, 16, 0.12);
    box-shadow: var(--shadow-md);
  }
  .area-page__cta-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 14, 16, 0.88) 0%,
      rgba(14, 14, 16, 0.78) 50%,
      rgba(14, 14, 16, 0.85) 100%
    );
  }
  .area-page__cta-inner :is(h2, p, .btn) {
    position: relative;
    z-index: 1;
  }
  .area-page__cta-inner h2 {
    color: #fff;
    margin: 0 0 10px;
  }
  .area-page__cta-inner p {
    margin: 0 0 20px;
    color: #cfcdc8;
    max-width: 40ch;
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .area-page__hero-layout {
      grid-template-columns: 1fr;
      row-gap: 28px;
    }
    .area-page__hero-head {
      grid-column: 1;
      grid-row: 1;
    }
    .area-page__hero-head h1 {
      max-width: none;
    }
    .area-page__hero-map {
      grid-column: 1;
      grid-row: 2;
    }
    .area-page__hero-body {
      grid-column: 1;
      grid-row: 3;
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 1024px) {
    .area-page__local-accordions {
      grid-template-columns: 1fr;
    }
    .area-page__gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 720px) {
    .area-page__gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .area-page__services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
