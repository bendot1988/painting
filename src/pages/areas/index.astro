---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import AreasMap from '~/components/AreasMap.astro';
import {
  areas,
  areaAccent,
  areaListTitle,
} from '~/data/areas';
import { quotePageHref } from '~/data/contact';

const pageTitle = 'Areas Covered | A.S Painting Contractors';
const pageDescription =
  'Painting and decorating across Leicester and Leicestershire. Find your town or village and see how we can help with commercial and domestic work.';
---
<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main id="main" class="areas-page">
    <section class="areas-page__hero" aria-labelledby="areas-heading">
      <div class="container">
        <span class="eyebrow">Where we work</span>
        <h1 id="areas-heading" class="display h1">
          Areas <span class="painted-word painted-word--lime">covered.</span>
        </h1>
        <p class="lead areas-page__intro">
          Based in Leicester, we work across the county for homeowners, landlords and
          businesses. Select your area below for local information, or
          <a href="/contact">get in touch</a> if you are not sure we cover you.
        </p>
      </div>
    </section>

    <AreasMap />

    <section class="areas-page__list" aria-label="Towns and villages we cover">
      <div class="container">
        <ul class="areas-page__grid">
          {areas.map((area, i) => (
            <li class="reveal" style={`--i:${i % 12}`}>
              <a
                class={`areas-page__card areas-page__card--${areaAccent(i)}`}
                href={`/areas/${area.slug}`}
              >
                <span class="areas-page__card-dot" aria-hidden="true"></span>
                <span class="areas-page__card-title">{areaListTitle(area.name)}</span>
                <span class="areas-page__card-cta">View area <span class="arrow">→</span></span>
              </a>
            </li>
          ))}
        </ul>

        <div class="areas-page__cta reveal">
          <p>Not listed? We still travel across Leicestershire and the East Midlands for commercial work.</p>
          <a class="btn" href={quotePageHref}>Request a free quote <span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .areas-page {
    --page-stack-gap: 50px;
  }
  .areas-page__hero {
    padding-top: calc(38px + var(--page-stack-gap));
    padding-bottom: 0;
  }
  .areas-page__hero h1 {
    margin-top: 14px;
    max-width: 12ch;
  }
  .areas-page__intro {
    max-width: 52ch;
    margin-top: 16px;
  }
  .areas-page__intro a {
    color: var(--c-red);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .areas-page__list {
    padding: 0 0 clamp(72px, 9vw, 120px);
  }
  .areas-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .areas-page__card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 100%;
    padding: 20px 22px;
    border-radius: 16px;
    background: #fff;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    border-top: 4px solid var(--accent, var(--c-red));
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
    transition-delay: calc(var(--i) * 40ms);
  }
  .areas-page__card--red    { --accent: var(--c-red); }
  .areas-page__card--yellow { --accent: var(--c-yellow); }
  .areas-page__card--lime   { --accent: var(--c-lime); }
  .areas-page__card--pink   { --accent: var(--c-pink); }
  .areas-page__card--blue   { --accent: var(--c-blue); }
  .areas-page__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .areas-page__card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent, var(--c-red));
  }
  .areas-page__card-title {
    font-family: var(--font-display);
    font-size: clamp(16px, 1.8vw, 18px);
    font-weight: 700;
    line-height: 1.3;
    color: var(--c-ink);
    flex: 1;
  }
  .areas-page__card-cta {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-stone);
  }
  .areas-page__card:hover .areas-page__card-cta {
    color: var(--c-red);
  }

  .areas-page__cta {
    margin-top: 48px;
    padding: 28px 24px;
    text-align: center;
    border-radius: 18px;
    background: var(--bg-alt);
    border: 1px solid rgba(14, 14, 16, 0.08);
  }
  .areas-page__cta p {
    margin: 0 0 18px;
    max-width: 42ch;
    margin-inline: auto;
    color: var(--c-graphite);
    font-size: 16px;
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .areas-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .areas-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
