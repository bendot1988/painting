---
import { homepageSectors as sectors } from '~/data/commercial-page';
---
<section id="commercial" class="section commercial" aria-label="Commercial painting">
  <div class="container commercial__inner">
    <div class="commercial__copy reveal">
      <span class="eyebrow">Commercial · 60% of our diary</span>
      <h2 class="display h2">
        Painting that <span class="painted-word">works</span> for hours.
      </h2>
      <p class="lead">
        Factories, offices, retail and warehouses across Leicestershire. Interior and
        exterior painting planned around your operations.
      </p>

      <ul class="commercial__bullets">
        <li>
          <strong>Out-of-hours, weekends and nights.</strong>
          <span>We work around your operations, not the other way around.</span>
        </li>
        <li>
          <strong>RAMS, COSHH and PPE in place.</strong>
          <span>Risk assessments and method statements supplied before work starts.</span>
        </li>
        <li>
          <strong>Interior and exterior painting.</strong>
          <span>Shutters, cladding, stair towers, shopfronts and full interior programmes.</span>
        </li>
      </ul>

      <div class="commercial__ctas">
        <a class="btn" href="/#quote">Get a fixed-price quote <span class="arrow">→</span></a>
        <a class="btn btn--ghost" href="/commercial">Commercial services <span class="arrow">→</span></a>
      </div>
    </div>

    <div class="commercial__media reveal">
      <div class="commercial__photo commercial__photo--main">
        <img src="/images/commercial-interior-qualvis-reception.jpeg" alt="Repainted Qualvis reception with feature wall and branded signage" loading="lazy" />
      </div>
      <div class="commercial__photo commercial__photo--alt">
        <img src="/images/commercial-interior-warehouse-epoxy-floor-01.jpeg" alt="Freshly coated warehouse with epoxy resin floor and bright white walls" loading="lazy" />
      </div>
      <div class="commercial__photo commercial__photo--small">
        <img src="/images/commercial-interior-yellow-accent-office.jpeg" alt="Office space with a bold yellow accent wall and crisp white trim" loading="lazy" />
      </div>
    </div>
  </div>

  <div class="container">
    <div class="sectors reveal">
      <h3 class="sectors__title">Sectors we work in</h3>
      <div class="sectors__grid">
        {sectors.map((s) => (
          <article class="sector-card">
            <div class="sector-card__media">
              <img src={s.src} alt={s.alt} loading="lazy" />
            </div>
            <div class="sector-card__body">
              <h4>{s.name}</h4>
              <p>{s.desc}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="commercial__more">
        <a class="btn btn--ghost" href="/commercial">See full commercial offering <span class="arrow">→</span></a>
      </p>
    </div>
  </div>
</section>

<style>
  .commercial { padding-top: clamp(72px, 9vw, 120px); padding-bottom: clamp(72px, 9vw, 120px); background: var(--c-cream); }
  .commercial__inner {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  .commercial__copy h2 { margin: 16px 0 18px; }

  .commercial__bullets { list-style: none; padding: 0; margin: 18px 0 28px; display: grid; gap: 14px; }
  .commercial__bullets li {
    padding: 14px 16px;
    background: #fff;
    border-radius: 12px;
    border-left: 4px solid var(--c-yellow);
    box-shadow: var(--shadow-sm);
    font-size: 15px;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .commercial__bullets li:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .commercial__bullets strong {
    display: block;
    color: var(--c-ink);
    margin-bottom: 4px;
  }
  .commercial__bullets span {
    display: block;
    color: var(--c-graphite);
    font-weight: 500;
  }

  .commercial__ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .commercial__more { margin: 28px 0 0; text-align: center; }

  .commercial__media {
    position: relative;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    aspect-ratio: 5 / 6;
  }
  .commercial__photo {
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    position: relative;
  }
  .commercial__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .commercial__photo:hover img {
    transform: scale(1.06);
  }
  .commercial__photo--main { grid-row: 1 / span 2; }
  .commercial__photo--alt  { transform: rotate(2deg); }
  .commercial__photo--small { transform: rotate(-2deg); }

  .sectors {
    margin-top: 64px;
    padding-top: 36px;
    border-top: 1px solid rgba(14,14,16,0.10);
  }
  .sectors__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--c-stone);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }
  .sectors__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .sector-card {
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .sector-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .sector-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #e8e8e6;
  }
  .sector-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .sector-card:hover .sector-card__media img {
    transform: scale(1.04);
  }
  .sector-card__body {
    padding: 18px 20px 22px;
  }
  .sector-card__body h4 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: var(--tracking-snug);
    color: var(--c-ink);
    line-height: 1.2;
  }
  .sector-card__body p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-graphite);
    letter-spacing: var(--tracking-body);
  }

  @media (prefers-reduced-motion: reduce) {
    .commercial__photo:hover img { transform: none; }
    .commercial__bullets li:hover,
    .sector-card:hover { transform: none; }
  }

  @media (max-width: 980px) {
    .commercial__inner { grid-template-columns: 1fr; }
    .commercial__media { aspect-ratio: 4 / 3; }
    .sectors__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .sectors__grid { gap: 12px; }
    .sector-card__body { padding: 14px 14px 16px; }
    .sector-card__body h4 { font-size: 15px; }
    .sector-card__body p { font-size: 13px; line-height: 1.45; }
  }
</style>
