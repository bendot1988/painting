---
import { contact, quotePageHref } from '~/data/contact';
---
<div class="contact-fab" data-contact-fab>
  <div class="contact-fab__menu" id="contact-fab-menu" data-contact-menu hidden>
    <p class="contact-fab__menu-title">How can we help?</p>
    <ul>
      <li>
        <a class="contact-fab__action" href={`tel:${contact.phone.tel}`}>
          <span class="contact-fab__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1H7c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1z"/></svg>
          </span>
          <span>
            <strong>Call us</strong>
            <small>{contact.phone.display}</small>
          </span>
        </a>
      </li>
      <li>
        <a class="contact-fab__action" href={contact.whatsapp.href} target="_blank" rel="noopener noreferrer">
          <span class="contact-fab__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 3a9 9 0 0 0-7.8 13.5L3 21l4.7-1.2A9 9 0 1 0 12 3zm.2 4.5c.5 0 .9.4.9.9s-.4.9-.9.9-.9-.4-.9-.9.4-.9.9-.9zm-2.4 1.8h.1c.2 0 .4.1.5.3.5.8 1.2 1.4 2 1.8.2.1.3 0 .4-.1l.4-.5c.1-.1.2-.2.4-.1l1.4.6c.2.1.3.2.3.3v.5c0 .2 0 .5-.5.7-.4.2-1.1.2-2-.2-1.3-.5-2.7-1.8-3.3-3.1-.4-.9-.4-1.6-.2-2 .1-.2.3-.4.5-.4z"/></svg>
          </span>
          <span>
            <strong>WhatsApp us</strong>
            <small>{contact.whatsapp.display}</small>
          </span>
        </a>
      </li>
      <li>
        <a class="contact-fab__action" href={quotePageHref}>
          <span class="contact-fab__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M4 6h16v12H4V6zm2 2v8h12V8H6zm2 2h8v1.5H8V10zm0 2.5h5V14H8v-1.5z"/></svg>
          </span>
          <span>
            <strong>Fill in our form</strong>
            <small>Free quote — same-day reply</small>
          </span>
        </a>
      </li>
      <li>
        <a class="contact-fab__action" href={`mailto:${contact.email}`}>
          <span class="contact-fab__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M4 6h16v12H4V6zm0 1.2 8 5.2 8-5.2H4zm16 9.6H4V8.4l8 5.2 8-5.2v8.4z"/></svg>
          </span>
          <span>
            <strong>Email us</strong>
            <small>{contact.email}</small>
          </span>
        </a>
      </li>
    </ul>
  </div>

  <button
    type="button"
    class="contact-fab__toggle"
    data-contact-toggle
    aria-expanded="false"
    aria-controls="contact-fab-menu"
    aria-label="Open contact options"
  >
    <img
      class="contact-fab__roller"
      src="/images/brand/paint-roller.png"
      alt=""
      width="34"
      height="34"
      aria-hidden="true"
    />
  </button>
</div>

<script>
  const fab = document.querySelector('[data-contact-fab]');
  const toggle = fab?.querySelector<HTMLButtonElement>('[data-contact-toggle]');
  const menu = fab?.querySelector<HTMLElement>('[data-contact-menu]');

  const closeMenu = () => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open contact options');
    menu.hidden = true;
    fab?.classList.remove('is-open');
  };

  const openMenu = () => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close contact options');
    menu.hidden = false;
    fab?.classList.add('is-open');
  };

  toggle?.addEventListener('click', () => {
    if (fab?.classList.contains('is-open')) closeMenu();
    else openMenu();
  });

  document.addEventListener('click', (e) => {
    if (!fab?.classList.contains('is-open')) return;
    if (!fab.contains(e.target as Node)) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  const footer = document.querySelector('.footer');
  const fadeZone = 140;

  const updateFabNearFooter = () => {
    if (!fab || !footer) return;
    const footerTop = footer.getBoundingClientRect().top;
    const trigger = window.innerHeight - 24;
    if (footerTop >= trigger) {
      fab.style.removeProperty('--fab-opacity');
      fab.classList.remove('is-near-footer');
      return;
    }
    const progress = Math.min(1, (trigger - footerTop) / fadeZone);
    fab.style.setProperty('--fab-opacity', String(1 - progress));
    if (progress >= 0.85) {
      fab.classList.add('is-near-footer');
      if (fab.classList.contains('is-open')) closeMenu();
    } else {
      fab.classList.remove('is-near-footer');
    }
  };

  updateFabNearFooter();
  window.addEventListener('scroll', updateFabNearFooter, { passive: true });
  window.addEventListener('resize', updateFabNearFooter, { passive: true });
</script>

<style>
  .contact-fab {
    position: fixed;
    right: max(16px, env(safe-area-inset-right));
    bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 80;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    opacity: var(--fab-opacity, 1);
    transition: opacity 0.3s var(--ease);
  }
  .contact-fab.is-near-footer {
    pointer-events: none;
  }

  .contact-fab__toggle {
    width: 58px;
    height: 58px;
    border: 0;
    border-radius: 50%;
    background: var(--c-red);
    color: #fff;
    box-shadow: 0 8px 28px rgba(212, 38, 44, 0.45);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), background 0.2s;
  }
  .contact-fab__toggle:hover {
    transform: scale(1.06) rotate(-6deg);
    box-shadow: 0 12px 32px rgba(212, 38, 44, 0.5);
    background: var(--c-red-deep);
  }
  .contact-fab.is-open .contact-fab__toggle {
    transform: rotate(12deg) scale(1.04);
  }
  .contact-fab__roller {
    display: block;
    width: 34px;
    height: auto;
    object-fit: contain;
    transform: rotate(-12deg);
    transition: transform 0.35s var(--ease);
    mix-blend-mode: screen;
  }
  .contact-fab.is-open .contact-fab__roller {
    transform: rotate(10deg) scale(0.94);
  }

  .contact-fab__menu {
    width: min(300px, calc(100vw - 32px));
    background: #fff;
    border-radius: 18px;
    padding: 16px;
    box-shadow: 0 16px 48px rgba(14, 14, 16, 0.2);
    border: 1px solid rgba(14, 14, 16, 0.08);
    transform-origin: bottom right;
    animation: contact-fab-in 0.28s var(--ease);
  }
  .contact-fab__menu[hidden] {
    display: none;
  }
  @keyframes contact-fab-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .contact-fab__menu-title {
    margin: 0 0 10px;
    padding: 0 4px;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--c-ink);
  }
  .contact-fab__menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact-fab__action {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--c-ink);
    transition: background 0.2s;
  }
  .contact-fab__action:hover {
    background: rgba(14, 14, 16, 0.05);
  }
  .contact-fab__action strong {
    display: block;
    font-size: 14.5px;
    font-weight: 700;
    line-height: 1.25;
  }
  .contact-fab__action small {
    display: block;
    font-size: 12px;
    color: var(--c-stone);
    margin-top: 2px;
  }
  .contact-fab__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(212, 38, 44, 0.1);
    color: var(--c-red);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    body.nav-is-open .contact-fab {
      visibility: hidden;
      pointer-events: none;
      opacity: 0 !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-fab {
      transition: none;
    }
    .contact-fab__toggle,
    .contact-fab__roller {
      transition: none;
    }
    .contact-fab__menu {
      animation: none;
    }
  }
</style>
