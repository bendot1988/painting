---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  lead: string;
}

const { title, description, heading, lead } = Astro.props;
---
<Layout title={title} description={description}>
  <Header />
  <main id="main" class="legal-page section">
    <div class="container legal-page__inner">
      <span class="eyebrow">Legal</span>
      <h1 class="display h2">{heading}</h1>
      <p class="lead">{lead}</p>
      <slot />
      <p class="legal-page__back">
        <a class="btn btn--ghost" href="/contact/">Contact us</a>
        <a class="legal-page__back-link" href="/">Back to home</a>
      </p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page {
    padding-block: clamp(120px, 14vw, 160px) clamp(72px, 9vw, 120px);
  }
  .legal-page__inner {
    max-width: 65ch;
  }
  .legal-page h1 {
    margin: 14px 0 18px;
  }
  .legal-page :global(h2.legal-page__h2) {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 24px);
    margin: 2em 0 0.75em;
  }
  .legal-page :global(h3.legal-page__h3) {
    font-family: var(--font-display);
    font-size: 17px;
    margin: 1.5em 0 0.5em;
  }
  .legal-page :global(p),
  .legal-page :global(li) {
    color: var(--c-graphite);
    line-height: 1.65;
    font-size: 15px;
  }
  .legal-page :global(p) {
    margin: 0 0 1em;
  }
  .legal-page :global(ul) {
    margin: 0 0 1.25em;
    padding-left: 1.35em;
  }
  .legal-page :global(li + li) {
    margin-top: 0.35em;
  }
  .legal-page :global(a) {
    color: var(--c-red);
    font-weight: 600;
  }
  .legal-page :global(a:hover) {
    text-decoration: underline;
  }
  .legal-page__back {
    margin-top: 2.5em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px 24px;
  }
  .legal-page__back-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-stone);
    text-decoration: none;
  }
  .legal-page__back-link:hover {
    color: var(--c-red);
    text-decoration: underline;
  }
</style>
