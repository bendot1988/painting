---
import { showcaseItems as items } from '~/data/showcase-work';
---
<section id="work" class="section section--ink showcase" aria-label="Recent work">
  <div class="container">
    <div class="row-meta reveal">
      <div>
        <span class="eyebrow">Recent work</span>
        <h2 class="display h2">Real jobs.<br/>Real <span class="painted-word painted-word--lime">Leicester</span> walls.</h2>
      </div>
      <div>
        <p class="lead">
          A selection from the last few months — factory refurbs, office fit-outs,
          retail units and family homes. Tap a chip to filter.
        </p>
        <p class="showcase__more">
          <a class="btn btn--ghost" href="/work">View all our work <span class="arrow">→</span></a>
        </p>
      </div>
    </div>

    <div class="filters reveal" role="tablist" aria-label="Filter projects">
      <button class="filter is-active" role="tab" data-filter="all" aria-selected="true">All work</button>
      <button class="filter" role="tab" data-filter="commercial" aria-selected="false">Commercial</button>
      <button class="filter" role="tab" data-filter="domestic" aria-selected="false">Domestic</button>
    </div>

    <div class="grid" data-grid>
      {items.map((it, i) => (
        <figure class={`tile reveal ${it.size ? `tile--${it.size}` : ''} tile--${it.tag}`} data-tag={it.tag} style={`--i:${i}`}>
          <img src={it.src} alt={it.alt} loading="lazy" />
          <figcaption>
            <span class={`tag tag--${it.tag}`}>{it.tag === 'commercial' ? 'Commercial' : 'Domestic'}</span>
            <h3>{it.title}</h3>
            <p>{it.meta}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const tiles = document.querySelectorAll<HTMLElement>('.tile');
  filters.forEach((b) => {
    b.addEventListener('click', () => {
      filters.forEach((x) => { x.classList.remove('is-active'); x.setAttribute('aria-selected','false'); });
      b.classList.add('is-active');
      b.setAttribute('aria-selected','true');
      const f = b.dataset.filter;
      tiles.forEach((t) => {
        const show = f === 'all' || t.dataset.tag === f;
        t.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .showcase { padding-bottom: clamp(72px, 9vw, 130px); }
  .showcase__more { margin: 18px 0 0; }
  .filters {
    display: inline-flex; padding: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 999px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .filter {
    background: transparent; color: var(--c-paper);
    border: 0; padding: 10px 18px; border-radius: 999px;
    font-weight: 600; font-size: 14px;
    transition: background .2s, color .2s, transform .2s;
  }
  .filter:hover { background: rgba(255,255,255,0.06); }
  .filter.is-active {
    background: var(--c-yellow);
    color: var(--c-ink);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    grid-auto-flow: dense;
    gap: 16px;
    width: 100%;
  }
  .tile {
    position: relative; margin: 0;
    border-radius: 18px; overflow: hidden;
    background: #1c1c1f;
    grid-column: span 1;
    grid-row: span 1;
    min-height: 200px;
    transition: transform .35s var(--ease);
  }
  .tile:hover { transform: translateY(-4px); }
  .tile img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .8s var(--ease), filter .35s; }
  .tile:hover img { transform: scale(1.05); }
  .tile figcaption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 16px 18px;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.30) 60%, transparent 100%);
    transform: translateY(8px); opacity: 0;
    transition: transform .35s var(--ease), opacity .35s;
  }
  .tile:hover figcaption,
  .tile:focus-within figcaption { transform: none; opacity: 1; }
  .tile h3 { font-family: var(--font-display); font-weight: 700; font-size: 18px; margin: 6px 0 2px; }
  .tile p { margin: 0; font-size: 13px; color: #d8d6cf; }
  .tile .tag { font-size: 11px; padding: 3px 8px; }

  /* Bento sizing — spans fit a 4-column grid with dense packing */
  .tile--lg { grid-column: span 2; grid-row: span 2; }
  .tile--md { grid-column: span 1; grid-row: span 2; }
  .tile--sm { grid-column: span 1; grid-row: span 1; }

  /* A coloured edge cue for tag — read at a glance */
  .tile--commercial::after { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--c-yellow); }
  .tile--domestic::after   { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--c-pink); }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    .tile--lg { grid-column: span 2; grid-row: span 2; }
    .tile--md { grid-column: span 1; grid-row: span 2; }
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
      gap: 12px;
    }
    .tile, .tile--md, .tile--lg { grid-column: span 1; grid-row: span 1; min-height: 220px; }
    .tile figcaption { transform: none; opacity: 1; }
  }
</style>
