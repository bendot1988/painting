---
const stats = [
  { value: 15, suffix: '+', label: 'Years on the tools' },
  { value: 500, suffix: '+', label: 'Projects delivered' },
  { value: 7, suffix: '', label: 'Days a week, 6am–5pm' },
  { value: 100, suffix: '%', label: 'Insured & vetted team' },
];
---
<section class="trust" aria-label="At a glance" data-trust-strip>
  <div class="container">
    <div class="trust__grid">
      {stats.map((s, i) => (
        <div class="trust__stat reveal" style={`--i:${i}`}>
          <div
            class="trust__num display"
            data-trust-count
            data-to={s.value}
            data-suffix={s.suffix}
            data-delay={i * 90}
          >
            0{s.suffix}
          </div>
          <div class="trust__lbl">{s.label}</div>
        </div>
      ))}
    </div>
    <div class="trust__swatch" aria-hidden="true">
      <div class="swatch-row"><span class="s1"/><span class="s2"/><span class="s3"/><span class="s4"/><span class="s5"/></div>
      <span class="trust__motto">Same crew. Same standards. Domestic to industrial.</span>
    </div>
  </div>
</section>

<script>
  const strip = document.querySelector('[data-trust-strip]');
  if (strip) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const counters = [...strip.querySelectorAll<HTMLElement>('[data-trust-count]')];

    const runCounter = (el: HTMLElement) => {
      const target = Number(el.dataset.to ?? 0);
      const suffix = el.dataset.suffix ?? '';
      const delay = Number(el.dataset.delay ?? 0);
      const duration = target >= 100 ? 1600 : 1200;

      const finish = () => {
        el.textContent = `${target}${suffix}`;
      };

      if (reduce || el.dataset.counted === 'true') {
        finish();
        return;
      }
      el.dataset.counted = 'true';

      const startCount = (startTime: number) => {
        const tick = (now: number) => {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - (1 - progress) ** 3;
          const value = Math.round(target * eased);
          el.textContent = `${value}${suffix}`;
          if (progress < 1) requestAnimationFrame(tick);
          else finish();
        };
        requestAnimationFrame(tick);
      };

      if (delay > 0) window.setTimeout(() => requestAnimationFrame(startCount), delay);
      else requestAnimationFrame(startCount);
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          runCounter(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      },
      { threshold: 0.4 }
    );

    counters.forEach((el) => {
      if (reduce) runCounter(el);
      else io.observe(el);
    });
  }
</script>

<style>
  .trust {
    padding-block: clamp(40px, 5vw, 64px);
    background: var(--bg);
    border-top: 1px solid rgba(14,14,16,0.06);
    border-bottom: 1px solid rgba(14,14,16,0.06);
  }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .trust__stat {
    transition-delay: calc(var(--i) * 70ms);
    border-left: 4px solid var(--c-red);
    padding: 6px 0 6px 18px;
  }
  .trust__stat:nth-child(2) { border-color: var(--c-yellow); }
  .trust__stat:nth-child(3) { border-color: var(--c-lime); }
  .trust__stat:nth-child(4) { border-color: var(--c-pink); }
  .trust__num {
    font-size: clamp(36px, 4.4vw, 56px);
    color: var(--c-ink);
    line-height: 0.95;
    font-variant-numeric: tabular-nums;
  }
  .trust__lbl {
    margin-top: 6px;
    font-size: 14px;
    color: var(--c-stone);
    font-weight: 500;
  }
  .trust__swatch {
    margin-top: 28px;
    display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
  }
  .trust__motto {
    font-size: 14px; color: var(--c-graphite);
    font-weight: 500;
  }
  @media (max-width: 720px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
</style>
