---
import {
  ANALYTICS_DOMAIN,
  ANALYTICS_SCRIPT_SRC,
  COOKIE_CONSENT_KEY,
} from '~/lib/cookies';
---
<div
  class="cookie-banner"
  data-cookie-banner
  role="dialog"
  aria-label="Cookie preferences"
  aria-live="polite"
  hidden
>
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      We use a small analytics cookie to understand how visitors use our site — no ads, no
      selling your data.
      <a href="/privacy/">Privacy policy</a>
    </p>
    <div class="cookie-banner__actions">
      <button type="button" class="cookie-banner__btn cookie-banner__btn--ghost" data-cookie-reject>
        Decline
      </button>
      <button type="button" class="cookie-banner__btn cookie-banner__btn--accept" data-cookie-accept>
        Accept
      </button>
    </div>
  </div>
</div>

<script
  define:vars={{
    consentKey: COOKIE_CONSENT_KEY,
    scriptSrc: ANALYTICS_SCRIPT_SRC,
    scriptDomain: ANALYTICS_DOMAIN,
  }}
>
  const banner = document.querySelector('[data-cookie-banner]');

  function loadAnalytics() {
    if (document.querySelector('script[data-analytics]')) return;
    const script = document.createElement('script');
    script.defer = true;
    script.dataset.domain = scriptDomain;
    script.dataset.analytics = '';
    script.src = scriptSrc;
    document.head.appendChild(script);
  }

  function hideBanner() {
    if (!banner) return;
    banner.classList.remove('is-visible');
    window.setTimeout(() => {
      banner.hidden = true;
    }, 320);
  }

  function setConsent(value) {
    try {
      localStorage.setItem(consentKey, value);
    } catch {
      /* private browsing — still honour choice for this session */
    }
    if (value === 'accepted') loadAnalytics();
    hideBanner();
  }

  const stored = (() => {
    try {
      return localStorage.getItem(consentKey);
    } catch {
      return null;
    }
  })();

  if (stored === 'accepted') {
    loadAnalytics();
  } else if (stored !== 'rejected' && banner) {
    banner.hidden = false;
    requestAnimationFrame(() => banner.classList.add('is-visible'));
  }

  banner?.querySelector('[data-cookie-accept]')?.addEventListener('click', () => {
    setConsent('accepted');
  });
  banner?.querySelector('[data-cookie-reject]')?.addEventListener('click', () => {
    setConsent('rejected');
  });
</script>

<style>
  .cookie-banner {
    position: fixed;
    left: 50%;
    bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 260;
    width: fit-content;
    max-width: calc(100% - 2 * var(--gutter));
    pointer-events: none;
    opacity: 0;
    transform: translateX(-50%) translateY(12px);
    transition:
      opacity 0.32s var(--ease),
      transform 0.32s var(--ease);
  }
  .cookie-banner.is-visible {
    pointer-events: auto;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .cookie-banner__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px 16px;
    padding: 12px 16px;
    border-radius: 14px;
    background: rgba(14, 14, 16, 0.94);
    color: #e8e8e6;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 12px 40px rgba(14, 14, 16, 0.35);
    backdrop-filter: blur(10px);
  }
  .cookie-banner__text {
    margin: 0;
    flex: 1 1 16rem;
    max-width: 36rem;
    font-size: 13px;
    line-height: 1.4;
    color: #cfcdc8;
  }
  .cookie-banner__text a {
    color: var(--c-yellow);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-banner__text a:hover {
    color: #fff;
  }
  .cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    flex-shrink: 0;
  }
  .cookie-banner__btn {
    font-family: var(--font-header);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: var(--tracking-ui);
    padding: 8px 14px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .cookie-banner__btn--ghost {
    background: transparent;
    color: #cfcdc8;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .cookie-banner__btn--ghost:hover,
  .cookie-banner__btn--ghost:focus-visible {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }
  .cookie-banner__btn--accept {
    background: var(--c-red);
    color: #fff;
    box-shadow: 0 4px 0 0 var(--c-red-deep);
  }
  .cookie-banner__btn--accept:hover,
  .cookie-banner__btn--accept:focus-visible {
    background: var(--c-red-deep);
    transform: translateY(-1px);
  }

  @media (max-width: 520px) {
    .cookie-banner {
      max-width: min(21rem, calc(100% - 24px));
    }
    .cookie-banner__inner {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      padding: 10px 12px;
    }
    .cookie-banner__text {
      flex: none;
      max-width: none;
      font-size: 12px;
      line-height: 1.35;
    }
    .cookie-banner__actions {
      width: auto;
      align-self: flex-end;
      justify-content: flex-end;
    }
    .cookie-banner__btn {
      flex: 0 0 auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner {
      transition: none;
    }
  }
</style>
