---
const steps = [
  { n: '01', code: 'AS-001', t: 'Talk to us', d: 'Quick call or message. We listen first — type of property, scope, timing, your headache. No script.' , c: 'red' },
  { n: '02', code: 'AS-115', t: 'Site visit & survey', d: 'We come and look. Measure up, photograph, talk through colours, prep needs and access.', c: 'yellow' },
  { n: '03', code: 'AS-237', t: 'Fixed-price quote', d: 'A clear, itemised quote — what we do, what we use, how long, how much. No surprises.', c: 'lime' },
  { n: '04', code: 'AS-348', t: 'Prep, paint, perfect', d: 'Dust sheets, masking, fillers, sanders, primers — then the topcoats. We don’t skip the boring bits.', c: 'pink' },
  { n: '05', code: 'AS-459', t: 'Walk-round & sign-off', d: 'You inspect with us. We snag and tidy. You only sign when you’re happy. Aftercare in writing.', c: 'ink' },
];
---
<section id="process" class="section section--cream process" aria-label="How we work">
  <div class="container">
    <div class="row-meta reveal">
      <div>
        <span class="eyebrow">How we work</span>
        <h2 class="display h2">Five steps.<br/>No <span class="painted-word">surprises.</span></h2>
      </div>
      <p class="lead">
        Same process whether it's a £600 hallway or a £60k factory repaint.
        Clear quote, clear timings, clean finish. That's it.
      </p>
    </div>

    <ol class="process__list">
      {steps.map((s, i) => (
        <li class={`process__step process__step--${s.c} reveal`} style={`--i:${i}`}>
          <div class="process__num">
            <span class="display">{s.n}</span>
            <small>{s.code}</small>
          </div>
          <div class="process__body">
            <h3 class="display">{s.t}</h3>
            <p>{s.d}</p>
          </div>
          <span class="process__chip" aria-hidden="true"></span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process__list {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }
  .process__step {
    position: relative;
    background: #fff;
    border-radius: 18px;
    padding: 24px 22px 28px;
    box-shadow: var(--shadow-sm);
    transition-delay: calc(var(--i) * 80ms);
    overflow: hidden;
    isolation: isolate;
  }
  .process__step::before {
    content: ""; position: absolute; left: 0; top: 0; right: 0; height: 6px;
    background: var(--swatch, var(--c-red));
  }
  .process__step--red    { --swatch: var(--c-red); }
  .process__step--yellow { --swatch: var(--c-yellow); }
  .process__step--lime   { --swatch: var(--c-lime); }
  .process__step--pink   { --swatch: var(--c-pink); }
  .process__step--ink    { --swatch: var(--c-ink); }

  .process__num {
    display: flex; align-items: baseline; gap: 8px;
    margin-bottom: 10px;
  }
  .process__num span {
    font-size: 56px; line-height: 0.9; color: var(--c-ink);
    letter-spacing: -0.04em;
  }
  .process__num small {
    font-family: var(--font-body);
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
    color: var(--c-stone); text-transform: uppercase;
  }
  .process__body h3 { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
  .process__body p  { font-size: 14.5px; color: var(--c-graphite); line-height: 1.5; margin: 0; }

  /* Drip on hover */
  .process__chip {
    position: absolute; right: -20px; bottom: -20px;
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--swatch, var(--c-red));
    opacity: 0.10;
    transition: transform .6s var(--ease), opacity .35s;
    z-index: -1;
  }
  .process__step:hover .process__chip {
    transform: scale(2.6);
    opacity: 0.18;
  }

  @media (max-width: 1100px) {
    .process__list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .process__list { grid-template-columns: 1fr; }
  }
</style>
