---
const commercial = [
  'Factories &amp; warehouses',
  'Office fit-outs &amp; refurb',
  'Retail, leisure &amp; hospitality',
  'Schools, care &amp; healthcare',
  'Cladding, lines &amp; epoxy floors',
  'Out-of-hours / weekend work',
];
const domestic = [
  'Interior rooms &amp; whole houses',
  'Exterior render, masonry &amp; doors',
  'Kitchens, woodwork &amp; trim',
  'Wallpaper hanging &amp; specialist finishes',
  'Plastering &amp; making good',
];
---
<section id="services" class="section section--services" aria-label="What we do">
  <div class="container">
    <div class="row-meta reveal">
      <div>
        <span class="eyebrow">What we do</span>
        <h2 class="display h2">Two crews.<br/>One <span class="painted-word painted-word--yellow">standard.</span></h2>
      </div>
      <p class="lead">
        Roughly six in ten of our jobs are commercial — factories, offices, retail
        and education — but we never lost the love for great domestic work.
        Whichever you need, you get the same prep, same paint, same finish.
      </p>
    </div>

    <div class="services-grid">
      <article class="card service-card service-card--commercial reveal" aria-labelledby="svc-com">
        <header>
          <span class="tag tag--commercial">Commercial · ~60% of work</span>
          <h3 id="svc-com" class="display h3">Built for trade.</h3>
          <p>
            Painting that survives forklifts, pallets and Monday mornings. We work
            around your operations, dust-controlled, with risk assessments and
            method statements as standard.
          </p>
        </header>
        <ul>
          {commercial.map((c) => <li set:html={c} />)}
        </ul>
        <a class="service-card__cta" href="#commercial">See commercial work <span aria-hidden="true">→</span></a>
        <div class="service-card__art" aria-hidden="true">
          <svg viewBox="0 0 200 200">
            <rect x="14" y="14" width="172" height="172" rx="22" fill="none" stroke="#0e0e10" stroke-width="3"/>
            <path d="M40 130 L160 130" stroke="#1f6feb" stroke-width="6" stroke-linecap="round"/>
            <path d="M40 110 L120 110" stroke="#ffd60a" stroke-width="6" stroke-linecap="round"/>
            <path d="M40 90  L150 90"  stroke="#d4262c" stroke-width="6" stroke-linecap="round"/>
            <circle cx="172" cy="42" r="14" fill="#7ed321"/>
          </svg>
        </div>
      </article>

      <article class="card service-card service-card--domestic reveal" aria-labelledby="svc-dom">
        <header>
          <span class="tag tag--domestic">Domestic · ~40% of work</span>
          <h3 id="svc-dom" class="display h3">Loved your home? Now love it again.</h3>
          <p>
            Whole-house refreshes to a single feature wall. Tidy boots, dust
            sheets down, a clean finish — the kind of decorator your mum would
            actually recommend.
          </p>
        </header>
        <ul>
          {domestic.map((d) => <li set:html={d} />)}
        </ul>
        <a class="service-card__cta" href="#domestic">See domestic work <span aria-hidden="true">→</span></a>
        <div class="service-card__art" aria-hidden="true">
          <svg viewBox="0 0 200 200">
            <path d="M30 110 L100 50 L170 110 L170 170 L30 170 Z" fill="none" stroke="#0e0e10" stroke-width="3" stroke-linejoin="round"/>
            <rect x="86" y="120" width="28" height="50" fill="#ec008c"/>
            <rect x="48"  y="125" width="22" height="22" fill="#ffd60a"/>
            <rect x="130" y="125" width="22" height="22" fill="#7ed321"/>
            <circle cx="35" cy="40" r="10" fill="#d4262c"/>
          </svg>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .section--services { padding-top: clamp(72px, 8vw, 110px); }
  .services-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 24px;
  }
  .service-card {
    padding: 36px;
    display: flex; flex-direction: column; gap: 18px;
    border-radius: var(--radius-lg);
  }
  .service-card--commercial { background: #fff; }
  .service-card--domestic   { background: var(--c-ink); color: var(--c-paper); }
  .service-card--domestic header h3 { color: #fff; }
  .service-card--domestic p { color: #cfcdc8; }
  .service-card--domestic ul li { border-bottom-color: rgba(255,255,255,0.10); }
  .service-card--domestic ul li::before { background: var(--c-pink); }

  .service-card header h3 { margin: 10px 0 8px; }
  .service-card p { color: var(--c-graphite); margin: 0; max-width: 50ch; }

  .service-card ul {
    list-style: none; padding: 0; margin: 6px 0 0;
  }
  .service-card ul li {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(14,14,16,0.08);
    font-size: 15px; font-weight: 500;
  }
  .service-card ul li::before {
    content: ""; width: 10px; height: 10px; border-radius: 50%;
    background: var(--c-red); flex: 0 0 auto;
  }
  .service-card ul li:last-child { border-bottom: 0; }

  .service-card__cta {
    align-self: start;
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 6px;
    font-weight: 700; font-size: 15px;
    color: var(--c-red);
    border-bottom: 2px solid var(--c-red);
    padding-bottom: 2px;
    transition: gap .25s;
  }
  .service-card--domestic .service-card__cta { color: var(--c-yellow); border-bottom-color: var(--c-yellow); }
  .service-card__cta:hover { gap: 14px; }

  .service-card__art {
    position: absolute;
    right: -10px; bottom: -10px;
    width: 140px; height: 140px;
    opacity: 0.95;
    transform: rotate(-6deg);
    pointer-events: none;
  }
  .service-card--domestic .service-card__art svg path,
  .service-card--domestic .service-card__art svg rect[stroke] { stroke: #fff; }
  .service-card--domestic .service-card__art svg path[stroke] { stroke: #fff; }

  @media (max-width: 880px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-card { padding: 28px; }
  }
</style>
