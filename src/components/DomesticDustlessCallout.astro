---
import {
  dustlessSandingDomesticCallout,
  dustlessSandingFeaturedImage,
  dustlessSandingGallery,
  dustlessSandingSlug,
} from '~/data/dustless-sanding';

const { title, lead, paragraphs, blogLabel } = dustlessSandingDomesticCallout;
const blogHref = `/blog/${dustlessSandingSlug}/`;
---
<section
  class="dustless-callout reveal"
  aria-labelledby="dustless-callout-heading"
>
  <div class="container dustless-callout__inner">
    <figure class="dustless-callout__media">
      <img
        src={dustlessSandingFeaturedImage.src}
        alt={dustlessSandingFeaturedImage.alt}
        loading="lazy"
        width="800"
        height="600"
      />
    </figure>
    <div class="dustless-callout__copy">
      <h2 id="dustless-callout-heading" class="dustless-callout__title display h3">
        {title}
      </h2>
      <p class="dustless-callout__lead">{lead}</p>
      {paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <p class="dustless-callout__actions">
        <a class="btn btn--ghost" href={blogHref}>{blogLabel} <span class="arrow">→</span></a>
        <a class="dustless-callout__contact" href="/contact/">Book a free home visit</a>
      </p>
    </div>
  </div>
  <div class="container">
    <ul class="dustless-callout__gallery" aria-label="Dustless sanding and protected domestic prep">
      {dustlessSandingGallery.map((img) => (
        <li>
          <figure>
            <img src={img.src} alt={img.alt} loading="lazy" width="400" height="500" />
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .dustless-callout {
    padding: clamp(40px, 5vw, 56px) 0;
    background: var(--bg-alt);
    border-top: 1px solid rgba(14, 14, 16, 0.06);
  }
  .dustless-callout__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 40px);
    align-items: center;
    margin-bottom: clamp(20px, 3vw, 28px);
  }
  .dustless-callout__media {
    margin: 0;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #e8e8e6;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--c-pink);
  }
  .dustless-callout__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dustless-callout__title {
    margin: 0 0 12px;
    line-height: 1.15;
  }
  .dustless-callout__lead {
    margin: 0 0 14px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--c-graphite);
    font-weight: 600;
  }
  .dustless-callout__copy p {
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--c-graphite);
  }
  .dustless-callout__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 20px;
    margin: 18px 0 0 !important;
  }
  .dustless-callout__contact {
    font-weight: 700;
    color: var(--c-red);
    text-decoration: none;
  }
  .dustless-callout__contact:hover {
    text-decoration: underline;
  }
  .dustless-callout__gallery {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .dustless-callout__gallery figure {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #e8e8e6;
    box-shadow: var(--shadow-sm);
  }
  .dustless-callout__gallery img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 900px) {
    .dustless-callout__gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .dustless-callout__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
