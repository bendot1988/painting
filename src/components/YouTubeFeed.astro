---
import { fetchChannelVideos, formatVideoDate, YOUTUBE_CHANNEL_URL } from '~/lib/youtube-feed';

const INITIAL_VISIBLE = 3;
const LOAD_MORE_COUNT = 3;

const videos = await fetchChannelVideos(15);
const hasVideos = videos.length > 0;
---

{hasVideos && (
  <section class="yt-feed" id="videos" aria-label="Latest videos on YouTube">
    <div class="container yt-feed__inner">
    <div class="yt-feed__head">
      <div>
        <span class="eyebrow">On YouTube</span>
        <h2 class="display h2">See the work in action</h2>
      </div>
      <a class="btn btn--ghost yt-feed__channel" href={YOUTUBE_CHANNEL_URL} target="_blank" rel="noopener noreferrer">
        View channel <span class="arrow">→</span>
      </a>
    </div>

    <ul class="yt-feed__grid" data-yt-grid>
      {videos.map((video, index) => (
        <li
          class:list={['yt-feed__item', { 'is-hidden': index >= INITIAL_VISIBLE }]}
          data-yt-item
          data-index={index}
        >
          <a class="yt-feed__card" href={video.url} target="_blank" rel="noopener noreferrer">
            <span class="yt-feed__thumb">
              <img src={video.thumbnail} alt="" loading="lazy" width="640" height="360" />
              <span class="yt-feed__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="28" height="28">
                  <path d="M8 5v14l11-7z" fill="currentColor" />
                </svg>
              </span>
            </span>
            <span class="yt-feed__meta">
              <h3>{video.title}</h3>
              {video.published && <time datetime={video.published}>{formatVideoDate(video.published)}</time>}
            </span>
          </a>
        </li>
      ))}
    </ul>

    {videos.length > INITIAL_VISIBLE && (
      <div class="yt-feed__actions">
        <button type="button" class="btn yt-feed__more" data-yt-load-more data-step={LOAD_MORE_COUNT}>
          Load more videos
        </button>
      </div>
    )}
    </div>
  </section>
)}

<script>
  const loadMoreBtn = document.querySelector<HTMLButtonElement>('[data-yt-load-more]');
  loadMoreBtn?.addEventListener('click', () => {
    const step = Number(loadMoreBtn.dataset.step || 3);
    const hidden = [...document.querySelectorAll<HTMLElement>('[data-yt-item].is-hidden')];
    hidden.slice(0, step).forEach((item) => item.classList.remove('is-hidden'));

    if (document.querySelectorAll('[data-yt-item].is-hidden').length === 0) {
      loadMoreBtn.hidden = true;
    }
  });
</script>

<style>
  .yt-feed {
    padding: clamp(56px, 8vw, 96px) 0 clamp(48px, 6vw, 72px);
    background: var(--bg);
    border-top: 1px solid rgba(14, 14, 16, 0.08);
  }
  .yt-feed__head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .yt-feed__head h2 {
    margin-top: 12px;
    max-width: 16ch;
  }
  .yt-feed__channel {
    flex-shrink: 0;
  }

  .yt-feed__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
    width: 100%;
    max-width: none;
  }
  .yt-feed__item.is-hidden {
    display: none;
  }
  .yt-feed__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .yt-feed__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .yt-feed__thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #1c1c1f;
  }
  .yt-feed__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .yt-feed__card:hover .yt-feed__thumb img {
    transform: scale(1.05);
  }
  .yt-feed__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(14, 14, 16, 0.28);
    color: #fff;
    transition: background 0.25s;
  }
  .yt-feed__card:hover .yt-feed__play {
    background: rgba(14, 14, 16, 0.42);
  }
  .yt-feed__play svg {
    width: 56px;
    height: 56px;
    padding: 14px;
    border-radius: 50%;
    background: rgba(212, 38, 44, 0.92);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }
  .yt-feed__meta {
    display: block;
    padding: 16px 18px 18px;
  }
  .yt-feed__meta h3 {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.25;
    letter-spacing: var(--tracking-snug);
    color: var(--c-ink);
  }
  .yt-feed__meta time {
    font-size: 13px;
    color: var(--c-stone);
    letter-spacing: var(--tracking-body);
  }

  .yt-feed__actions {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }
  .yt-feed__more[hidden] {
    display: none;
  }

  @media (max-width: 1024px) {
    .yt-feed__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .yt-feed__grid {
      grid-template-columns: 1fr;
    }
    .yt-feed__head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
