---
const nav = [
  { href: '#commercial', label: 'Commercial' },
  { href: '#domestic',   label: 'Domestic' },
  { href: '#work',       label: 'Our Work' },
  { href: '#process',    label: 'How We Work' },
  { href: '#areas',      label: 'Areas' },
  { href: '#quote',      label: 'Get a Quote' },
];
---
<header class="site-header" data-header>
  <div class="container site-header__row">
    <a href="#top" class="brand" aria-label="A.S Painting Contractors — home">
      <img src="/images/brand/logo.png" alt="A.S Painting Contractors" width="140" height="72" />
    </a>

    <nav class="nav" data-nav aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-header__cta">
      <a href="tel:+441162914746" class="phone" aria-label="Call A.S Painting Contractors on 0116 291 4746">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1H7c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1z"/></svg>
        <span>0116 291 4746</span>
      </a>
      <a href="#quote" class="btn btn--ink">Free quote <span class="arrow">→</span></a>
      <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(250, 247, 242, 0.78);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: background .25s, border-color .25s, box-shadow .25s;
  }
  .site-header.is-scrolled {
    background: rgba(250, 247, 242, 0.92);
    border-bottom-color: rgba(14,14,16,0.08);
    box-shadow: 0 6px 24px rgba(14,14,16,0.06);
  }
  .site-header__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    padding-block: 14px;
  }
  .brand img { height: 56px; width: auto; }

  .nav { justify-self: center; }
  .nav ul {
    list-style: none; display: flex; gap: 6px; padding: 0; margin: 0;
  }
  .nav a {
    display: inline-block;
    padding: 10px 14px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--c-graphite);
    border-radius: 999px;
    position: relative;
    transition: color .2s, background .2s;
  }
  .nav a:hover { color: var(--c-ink); background: rgba(14,14,16,0.04); }

  .site-header__cta { display: flex; align-items: center; gap: 14px; }
  .phone {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--c-ink); font-weight: 600; font-size: 14px;
    padding: 8px 12px; border-radius: 999px;
    transition: background .2s;
  }
  .phone:hover { background: rgba(14,14,16,0.05); }
  .phone svg { color: var(--c-red); }

  .nav-toggle {
    display: none; background: none; border: 0;
    width: 44px; height: 44px;
    flex-direction: column; gap: 5px; justify-content: center; align-items: center;
    border-radius: 12px;
  }
  .nav-toggle span {
    display: block; width: 22px; height: 2px;
    background: var(--c-ink); border-radius: 2px;
    transition: transform .25s, opacity .2s;
  }

  @media (max-width: 1024px) {
    .nav { display: none; }
    .phone span { display: none; }
  }
  @media (max-width: 720px) {
    .site-header__row { grid-template-columns: auto 1fr auto; gap: 12px; }
    .brand img { height: 44px; }
    .nav-toggle { display: flex; }
    .site-header__cta .btn { display: none; }
    .nav.is-open {
      display: block;
      position: absolute; top: 100%; left: 0; right: 0;
      background: var(--c-paper);
      border-bottom: 1px solid rgba(14,14,16,0.08);
      padding: 12px var(--gutter) 24px;
    }
    .nav.is-open ul { flex-direction: column; gap: 0; }
    .nav.is-open a {
      display: block; padding: 14px 12px;
      border-radius: 0;
      border-bottom: 1px solid rgba(14,14,16,0.06);
    }
  }
</style>
