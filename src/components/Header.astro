---
import { contact, quotePageHref, siteStats } from '~/data/contact';

const pathname = Astro.url.pathname;
const homeHref = pathname === '/' ? '#top' : '/';

const nav = [
  { href: '/commercial/', label: 'Commercial', match: 'commercial' },
  { href: '/domestic/', label: 'Domestic', match: 'domestic' },
  { href: '/work/', label: 'Our work', match: 'work-page' },
  { href: '/reviews/', label: 'Our reviews', match: 'reviews-page' },
  { href: '/contact/', label: 'Contact', match: 'contact-page' },
];
const quoteHref = quotePageHref;
---
<header class="site-header" data-header>
  <div class="site-header__top">
    <div class="site-header__inner site-header__top-line">
      <p class="site-header__credibility">
        <span>{siteStats.experience}</span>
        <span class="site-header__credibility-extra">
          <span class="site-header__sep" aria-hidden="true">·</span>
          <span>{siteStats.jobs}</span>
        </span>
      </p>
      <a href={`tel:${contact.phone.tel}`} class="site-header__phone" aria-label={`Call A.S Painting Contractors on ${contact.phone.display}`}>
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1H7c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1z"/>
        </svg>
        <span>{contact.phone.display}</span>
      </a>
    </div>
  </div>

  <div class="site-header__inner site-header__row">
    <a href={homeHref} class="brand" aria-label="A.S Painting Contractors — home">
      <img src="/images/brand/logo.png" alt="A.S Painting Contractors" width="264" height="144" />
    </a>

    <div class="site-header__end">
      <nav class="nav" data-nav aria-label="Primary">
        <div class="nav__backdrop" data-nav-backdrop aria-hidden="true"></div>
        <div class="nav__drawer">
          <div class="nav__head">
            <a href={homeHref} class="nav__brand" tabindex="-1">
              <img src="/images/brand/logo.png" alt="A.S Painting Contractors" width="200" height="110" />
            </a>
            <button type="button" class="nav__close" data-nav-close aria-label="Close menu">
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                <path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" d="M5 5l14 14M19 5L5 19"/>
              </svg>
            </button>
          </div>
          <ul class="nav__links nav__links--mobile">
            {nav.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
          <div class="nav__foot">
            <a href={quoteHref} class="btn nav__quote-btn">Free quote <span class="arrow">→</span></a>
            <a href={`tel:${contact.phone.tel}`} class="nav__phone-link">{contact.phone.display}</a>
          </div>
        </div>
        <ul class="nav__links nav__links--desktop">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="site-header__cta">
        <a href={quoteHref} class="btn btn--ink">Free quote <span class="arrow">→</span></a>
        <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    overflow: visible;
    background: var(--c-paper);
    border-bottom: 1px solid transparent;
    transition: background .25s, border-color .25s, box-shadow .25s;
  }
  .site-header.is-scrolled {
    background: var(--c-paper);
    border-bottom-color: rgba(14,14,16,0.08);
    box-shadow: 0 6px 24px rgba(14,14,16,0.06);
  }

  .site-header__top {
    background: var(--c-yellow);
    border-bottom: 1px solid rgba(14, 14, 16, 0.08);
  }
  .site-header__inner {
    width: 100%;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }
  .site-header__top-line {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    column-gap: clamp(16px, 2vw, 24px);
    min-height: 34px;
    padding-block: 5px;
    font-family: var(--font-header);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: var(--tracking-ui);
    color: var(--c-ink);
  }
  .site-header__phone {
    justify-self: end;
  }
  .site-header__credibility,
  .site-header__phone {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
  }
  .site-header__sep {
    opacity: 0.45;
    font-weight: 700;
  }
  .site-header__phone {
    color: var(--c-ink);
    transition: opacity .2s;
  }
  .site-header__phone:hover { opacity: 0.75; }
  .site-header__phone svg { color: var(--c-red); flex-shrink: 0; }

  .site-header__row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    column-gap: clamp(16px, 2vw, 24px);
    min-height: 52px;
    padding-block: 6px 10px;
  }
  .brand {
    position: relative;
    z-index: 55;
    margin-bottom: -38px;
    line-height: 0;
    flex-shrink: 0;
  }
  .brand img {
    height: 115px;
    width: auto;
    display: block;
  }

  .site-header__end {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(12px, 2vw, 20px);
    justify-self: end;
    min-width: 0;
  }

  .nav__backdrop,
  .nav__head,
  .nav__foot {
    display: none;
  }
  .nav__drawer {
    display: contents;
  }
  .nav__links--mobile {
    display: none;
  }
  .nav__links--desktop {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    padding: 0;
    margin: 0;
  }
  .site-header :is(.nav a, .btn) {
    font-family: var(--font-header);
  }
  .nav a {
    display: inline-block;
    padding: 10px 16px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: var(--tracking-ui);
    color: var(--c-graphite);
    background: rgba(14, 14, 16, 0.07);
    border-radius: 999px;
    transition: color .2s, background .2s;
    white-space: nowrap;
  }
  .nav a:hover,
  .nav a:focus-visible {
    color: var(--c-white);
    background: var(--c-red);
  }
  .nav a.is-active {
    color: var(--c-white);
    background: var(--c-blue);
  }
  .nav a.is-active:hover,
  .nav a.is-active:focus-visible {
    color: var(--c-white);
    background: var(--c-red);
  }
  .nav__brand {
    background: none;
    padding: 0;
    border-radius: 0;
  }
  .nav__brand:hover,
  .nav__brand:focus-visible {
    background: none;
    color: inherit;
  }

  .site-header__cta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav-toggle {
    display: none;
    border: 0;
    width: 44px;
    height: 44px;
    flex-direction: column;
    gap: 5px;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
    background: var(--c-red);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 4px 0 0 var(--c-red-deep), 0 2px 8px rgba(212, 38, 44, 0.28);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    background: var(--c-red-deep);
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 var(--c-red-deep), 0 4px 12px rgba(212, 38, 44, 0.35);
  }
  .nav-toggle:active {
    transform: translateY(1px);
    box-shadow: 0 2px 0 0 var(--c-red-deep);
  }
  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.2s;
  }

  @media (max-width: 1024px) {
    .site-header { overflow: visible; }
    .nav-toggle { display: flex; }
    .site-header__cta .btn { display: none; }

    .nav {
      position: fixed;
      inset: 0;
      z-index: 200;
      visibility: hidden;
      pointer-events: none;
    }
    .nav.is-open {
      visibility: visible;
      pointer-events: auto;
    }
    .nav__backdrop {
      display: block;
      position: absolute;
      inset: 0;
      background: rgba(14, 14, 16, 0.55);
      opacity: 0;
      transition: opacity 0.3s var(--ease);
    }
    .nav.is-open .nav__backdrop {
      opacity: 1;
    }
    .nav__drawer {
      display: flex;
      flex-direction: column;
      position: absolute;
      inset: 0;
      background: var(--c-paper);
      padding: max(16px, env(safe-area-inset-top)) var(--gutter) max(24px, env(safe-area-inset-bottom));
      transform: translateY(-8px);
      opacity: 0;
      transition: transform 0.32s var(--ease), opacity 0.28s var(--ease);
      overflow-y: auto;
    }
    .nav.is-open .nav__drawer {
      transform: translateY(0);
      opacity: 1;
    }
    .nav__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 20px;
      margin-bottom: 8px;
      border-bottom: 1px solid rgba(14, 14, 16, 0.08);
    }
    .nav__brand {
      display: inline-block;
      line-height: 0;
    }
    .nav__brand img {
      height: 72px;
      width: auto;
      display: block;
    }
    .nav__close {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border: 0;
      border-radius: 12px;
      background: rgba(14, 14, 16, 0.06);
      color: var(--c-ink);
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s;
    }
    .nav__close:hover,
    .nav__close:focus-visible {
      background: var(--c-red);
      color: #fff;
    }
    .nav__links--desktop {
      display: none;
    }
    .nav__links--mobile {
      display: flex;
      list-style: none;
      flex: 1;
      flex-direction: column;
      justify-content: center;
      align-self: center;
      width: 100%;
      max-width: min(320px, 100%);
      gap: 10px;
      padding: 12px 0 24px;
      margin: 0;
    }
    .nav__links--mobile li { width: 100%; }
    .nav__links--mobile a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 52px;
      padding: 14px 20px;
      font-size: 17px;
      border-radius: 14px;
      text-align: center;
    }
    .nav__foot {
      display: flex;
      flex-direction: column;
      align-items: center;
      align-self: center;
      width: 100%;
      max-width: min(320px, 100%);
      gap: 12px;
      padding-top: 16px;
      border-top: 1px solid rgba(14, 14, 16, 0.08);
    }
    .nav .nav__quote-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 52px;
      margin: 0;
      padding: 14px 22px;
      font-size: 17px;
      font-weight: 600;
      border-radius: 14px;
      text-align: center;
      background: var(--c-red);
      color: #fff;
      border: none;
      box-shadow: 0 6px 0 0 var(--c-red-deep), var(--shadow-sm);
    }
    .nav .nav__quote-btn:hover,
    .nav .nav__quote-btn:focus-visible {
      color: #fff;
      background: var(--c-red-deep);
      transform: translateY(-2px);
      box-shadow: 0 8px 0 0 var(--c-red-deep), var(--shadow-md);
    }
    .nav__phone-link {
      display: block;
      text-align: center;
      font-family: var(--font-header);
      font-size: 16px;
      font-weight: 600;
      color: var(--c-red);
      text-decoration: none;
      background: none;
      padding: 0;
      border-radius: 0;
    }
    .nav__phone-link:hover {
      opacity: 0.8;
      background: none;
      color: var(--c-red);
    }

    .nav-toggle {
      position: relative;
      z-index: 210;
    }
    .nav.is-open + .site-header__cta .nav-toggle {
      visibility: hidden;
      pointer-events: none;
    }
  }

  @media (max-width: 768px) {
    .site-header__credibility-extra {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .site-header__row { gap: 12px; }
    .site-header__top-line {
      font-size: 12px;
      min-height: 32px;
      padding-block: 4px;
    }
    .brand { margin-bottom: -28px; }
    .brand img { height: 91px; }
    .site-header__cta { gap: 8px; }
    .nav__brand img { height: 64px; }
  }

  @media (max-width: 560px) {
    .site-header__credibility {
      font-size: 12px;
      gap: 4px;
    }
  }

  @media (max-width: 480px) {
    .site-header__phone span { display: none; }
  }
</style>
