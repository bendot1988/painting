---
const nav = [
  { href: '#commercial', label: 'Commercial' },
  { href: '#domestic',   label: 'Domestic' },
  { href: '#work',       label: 'Our Work' },
  { href: '#process',    label: 'How We Work' },
  { href: '#areas',      label: 'Areas' },
  { href: '#quote',      label: 'Get a Quote' },
];
---
<header class="site-header" data-header>
  <div class="container site-header__row">
    <a href="#top" class="brand" aria-label="A.S Painting Contractors — home">
      <img src="/images/brand/logo.png" alt="A.S Painting Contractors" width="140" height="72" />
    </a>

    <nav class="nav" data-nav aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-header__cta">
      <a href="tel:+441162914746" class="phone" aria-label="Call A.S Painting Contractors on 0116 291 4746">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1H7c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1z"/></svg>
        <span>0116 291 4746</span>
      </a>
      <a href="#quote" class="btn btn--ink">Free quote <span class="arrow">→</span></a>
      <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(250, 247, 242, 0.78);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: background .25s, border-color .25s, box-shadow .25s;
  }
  .site-header.is-scrolled {
    background: rgba(250, 247, 242, 0.92);
    border-bottom-color: rgba(14,14,16,0.08);
    box-shadow: 0 6px 24px rgba(14,14,16,0.06);
  }
  .site-header__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    padding-block: 14px;
  }
  .brand img { height: 56px; width: auto; }

  .nav { justify-self: center; }
  .nav ul {
    list-style: none; display: flex; gap: 6px; padding: 0; margin: 0;
  }
  .nav a {
    display: inline-block;
    padding: 10px 14px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--c-graphite);
    border-radius: 999px;
    position: relative;
    transition: color .2s, background .2s;
  }
  .nav a:hover { color: var(--c-ink); background: rgba(14,14,16,0.04); }

  .site-header__cta { display: flex; align-items: center; gap: 14px; justify-self: end; }
  .phone {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--c-ink); font-weight: 600; font-size: 14px;
    padding: 8px 12px; border-radius: 999px;
    transition: background .2s;
  }
  .phone:hover { background: rgba(14,14,16,0.05); }
  .phone svg { color: var(--c-red); }

  .nav-toggle {
    display: none; background: none; border: 0;
    width: 44px; height: 44px;
    flex-direction: column; gap: 5px; justify-content: center; align-items: center;
    border-radius: 12px;
  }
  .nav-toggle span {
    display: block; width: 22px; height: 2px;
    background: var(--c-ink); border-radius: 2px;
    transition: transform .25s, opacity .2s;
  }

  @media (max-width: 1024px) {
    .nav { display: none; }
    .phone span { display: none; }
    .phone {
      width: 42px;
      height: 42px;
      justify-content: center;
      padding: 0;
      border: 1px solid rgba(212, 38, 44, 0.28);
      background: rgba(212, 38, 44, 0.08);
    }
    .phone svg { width: 20px; height: 20px; color: var(--c-red); }
  }
  @media (max-width: 720px) {
    .site-header { overflow: visible; }
    .site-header__row { grid-template-columns: auto 1fr auto; gap: 12px; }
    .brand img { height: 56px; }
    .site-header__cta { gap: 10px; }
    .nav-toggle { display: flex; }
    .site-header__cta .btn { display: none; }

    .nav {
      display: block;
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: auto;
      bottom: auto;
      width: 100vw;
      max-width: 100vw;
      background: #fff;
      border: 1px solid rgba(14,14,16,0.10);
      border-radius: 0;
      padding: 14px;
      transform: translateY(-10px) scale(0.98);
      transform-origin: top right;
      opacity: 0;
      pointer-events: none;
      transition: transform .24s ease, opacity .18s ease;
      z-index: 70;
      box-shadow: 0 18px 34px rgba(14,14,16,0.16);
    }
    .nav::before {
      content: "";
      position: absolute;
      left: 14px;
      right: 14px;
      top: 7px;
      height: 3px;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--c-red), var(--c-pink), var(--c-yellow), var(--c-lime));
      pointer-events: none;
    }
    .nav.is-open {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    .nav ul {
      position: relative;
      z-index: 1;
      width: 100%;
      flex-direction: column;
      gap: 6px;
    }
    .nav li { width: 100%; }
    .nav a {
      display: block;
      width: 100%;
      padding: 14px 12px;
      border-radius: 10px;
      border: 1px solid rgba(14,14,16,0.08);
      color: var(--c-ink);
      background: #fff;
    }
    .nav a:hover {
      color: var(--c-ink);
      background: rgba(255,214,10,0.11);
      border-color: rgba(255,214,10,0.4);
    }

    .nav-toggle {
      position: relative;
      width: 44px;
      height: 44px;
      border-radius: 12px;
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
