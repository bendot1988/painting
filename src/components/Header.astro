---
const pathname = Astro.url.pathname;
const sectionHref = (id: string) => (pathname === '/' ? `#${id}` : `/#${id}`);
const homeHref = pathname === '/' ? '#top' : '/';

const nav = [
  { href: sectionHref('commercial'), label: 'Commercial', match: 'commercial' },
  { href: sectionHref('domestic'),   label: 'Domestic',   match: 'domestic' },
  { href: sectionHref('work'),       label: 'Our work',   match: 'work' },
  { href: '/reviews',                label: 'Our reviews', match: 'reviews-page' },
  { href: sectionHref('quote'),      label: 'Get a quote', match: 'quote' },
];
---
<header class="site-header" data-header>
  <div class="site-header__top">
    <div class="site-header__inner site-header__top-line">
      <p class="site-header__area">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/>
        </svg>
        Leicester, Leicestershire
      </p>
      <a href="tel:+441162914746" class="site-header__phone" aria-label="Call A.S Painting Contractors on 0116 291 4746">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1H7c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1z"/>
        </svg>
        <span>0116 291 4746</span>
      </a>
    </div>
  </div>

  <div class="site-header__inner site-header__row">
    <a href={homeHref} class="brand" aria-label="A.S Painting Contractors — home">
      <img src="/images/brand/logo.png" alt="A.S Painting Contractors" width="264" height="144" />
    </a>

    <div class="site-header__end">
      <nav class="nav" data-nav aria-label="Primary">
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="site-header__cta">
        <a href={sectionHref('quote')} class="btn btn--ink">Free quote <span class="arrow">→</span></a>
        <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    overflow: visible;
    background: var(--c-paper);
    border-bottom: 1px solid transparent;
    transition: background .25s, border-color .25s, box-shadow .25s;
  }
  .site-header.is-scrolled {
    background: var(--c-paper);
    border-bottom-color: rgba(14,14,16,0.08);
    box-shadow: 0 6px 24px rgba(14,14,16,0.06);
  }

  .site-header__top {
    background: var(--c-yellow);
    border-bottom: 1px solid rgba(14, 14, 16, 0.08);
  }
  .site-header__inner {
    width: 100%;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }
  .site-header__top-line {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    column-gap: clamp(16px, 2vw, 24px);
    min-height: 34px;
    padding-block: 5px;
    font-family: var(--font-header);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: var(--tracking-ui);
    color: var(--c-ink);
  }
  .site-header__phone {
    justify-self: end;
  }
  .site-header__area,
  .site-header__phone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
  }
  .site-header__area svg { color: var(--c-red); flex-shrink: 0; }
  .site-header__phone {
    color: var(--c-ink);
    transition: opacity .2s;
  }
  .site-header__phone:hover { opacity: 0.75; }
  .site-header__phone svg { color: var(--c-red); flex-shrink: 0; }

  .site-header__row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    column-gap: clamp(16px, 2vw, 24px);
    min-height: 52px;
    padding-block: 6px 10px;
  }
  .brand {
    position: relative;
    z-index: 55;
    margin-bottom: -38px;
    line-height: 0;
    flex-shrink: 0;
  }
  .brand img {
    height: 115px;
    width: auto;
    display: block;
  }

  .site-header__end {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(12px, 2vw, 20px);
    justify-self: end;
    min-width: 0;
  }

  .nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    padding: 0;
    margin: 0;
  }
  .site-header :is(.nav a, .btn) {
    font-family: var(--font-header);
  }
  .nav a {
    display: inline-block;
    padding: 10px 16px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: var(--tracking-ui);
    color: var(--c-graphite);
    background: rgba(14, 14, 16, 0.07);
    border-radius: 999px;
    transition: color .2s, background .2s;
    white-space: nowrap;
  }
  .nav a:hover,
  .nav a:focus-visible {
    color: var(--c-white);
    background: var(--c-red);
  }
  .nav a.is-active {
    color: var(--c-white);
    background: var(--c-blue);
  }
  .nav a.is-active:hover,
  .nav a.is-active:focus-visible {
    color: var(--c-white);
    background: var(--c-red);
  }

  .site-header__cta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    width: 44px;
    height: 44px;
    flex-direction: column;
    gap: 5px;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--c-ink);
    border-radius: 2px;
    transition: transform .25s, opacity .2s;
  }

  @media (max-width: 1024px) {
    .nav { display: none; }
  }

  @media (max-width: 720px) {
    .site-header { overflow: visible; }
    .site-header__row { gap: 12px; }
    .site-header__top-line {
      font-size: 12px;
      min-height: 32px;
      padding-block: 4px;
    }
    .brand { margin-bottom: -28px; }
    .brand img { height: 91px; }
    .site-header__cta { gap: 8px; }
    .nav-toggle { display: flex; }
    .site-header__cta .btn { display: none; }

    .nav {
      display: block;
      position: absolute;
      top: calc(100% + 8px);
      right: var(--gutter);
      left: auto;
      width: min(100vw - var(--gutter) * 2, 360px);
      max-width: calc(100vw - var(--gutter) * 2);
      background: #fff;
      border: 1px solid rgba(14,14,16,0.10);
      border-radius: 16px;
      padding: 14px;
      transform: translateY(-10px) scale(0.98);
      transform-origin: top right;
      opacity: 0;
      pointer-events: none;
      transition: transform .24s ease, opacity .18s ease;
      z-index: 70;
      box-shadow: 0 18px 34px rgba(14,14,16,0.16);
    }
    .nav::before {
      content: "";
      position: absolute;
      left: 14px;
      right: 14px;
      top: 7px;
      height: 3px;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--c-red), var(--c-pink), var(--c-yellow), var(--c-lime));
      pointer-events: none;
    }
    .nav.is-open {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    .nav ul {
      position: relative;
      z-index: 1;
      width: 100%;
      flex-direction: column;
      gap: 6px;
    }
    .nav li { width: 100%; }
    .nav a {
      display: block;
      width: 100%;
      padding: 14px 16px;
      border-radius: 999px;
      border: none;
      color: var(--c-graphite);
      background: rgba(14, 14, 16, 0.07);
    }
    .nav a:hover,
    .nav a:focus-visible {
      color: var(--c-white);
      background: var(--c-red);
    }
    .nav a.is-active {
      color: var(--c-white);
      background: var(--c-blue);
    }
    .nav a.is-active:hover,
    .nav a.is-active:focus-visible {
      color: var(--c-white);
      background: var(--c-red);
    }

    .nav-toggle {
      position: relative;
      width: 44px;
      height: 44px;
      border-radius: 12px;
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle[aria-expanded="true"] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  @media (max-width: 480px) {
    .site-header__phone span { display: none; }
  }
</style>
