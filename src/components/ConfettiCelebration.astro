---
/** Full-viewport confetti burst — respects prefers-reduced-motion */
---
<canvas class="confetti" aria-hidden="true"></canvas>

<script>
  const canvas = document.querySelector('canvas.confetti');
  if (!canvas) throw new Error('Confetti canvas missing');

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced) {
    canvas.remove();
  } else {
    startConfetti(canvas);
  }

  /** @param {HTMLCanvasElement} canvas */
  function startConfetti(canvas) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const colors = ['#d4262c', '#ffd60a', '#7ed321', '#ec008c', '#1f6feb', '#ffffff'];
    const pieces = [];
    const count = 140;
    let raf = 0;
    let running = true;

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    for (let i = 0; i < count; i++) {
      pieces.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height * -0.4 - 20,
        w: 6 + Math.random() * 8,
        h: 10 + Math.random() * 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * Math.PI * 2,
        spin: (Math.random() - 0.5) * 0.2,
        vx: (Math.random() - 0.5) * 2.2,
        vy: 2.5 + Math.random() * 4,
        drift: (Math.random() - 0.5) * 0.04,
      });
    }

    const burstAt = performance.now();
    const duration = 5500;

    const tick = (now) => {
      if (!running) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const elapsed = now - burstAt;
      const gravity = elapsed < 800 ? 0.08 : 0.14;

      for (const p of pieces) {
        p.vy += gravity;
        p.vx += p.drift;
        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.spin;

        if (p.y > canvas.height + 40) {
          p.y = -20;
          p.x = Math.random() * canvas.width;
          p.vy = 2 + Math.random() * 3;
        }

        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = elapsed > duration - 1200 ? Math.max(0, 1 - (elapsed - (duration - 1200)) / 1200) : 1;
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        ctx.restore();
      }

      if (elapsed < duration) {
        raf = requestAnimationFrame(tick);
      } else {
        running = false;
        canvas.remove();
        window.removeEventListener('resize', resize);
      }
    };

    raf = requestAnimationFrame(tick);

    document.addEventListener(
      'visibilitychange',
      () => {
        if (document.hidden) cancelAnimationFrame(raf);
        else if (running) raf = requestAnimationFrame(tick);
      },
      { once: false },
    );
  }
</script>

<style>
  .confetti {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }
</style>
