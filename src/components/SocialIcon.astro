---
import type { SocialIcon as IconId } from '~/data/social';

interface Props {
  icon: IconId;
  size?: number;
}
const { icon, size = 22 } = Astro.props;
---
<svg class="social-icon__svg" viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
  {icon === 'whatsapp' && (
    <path
      fill="currentColor"
      d="M12 2a10 10 0 0 0-8.7 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 0 1 6.8 12.1l.3.3-.8 2.9 3-0.8.3.3A8 8 0 1 1 12 4zm-1.1 4.2c.2 0 .4.2.5.4l.6 1.4c.1.2 0 .5-.2.6l-.8.6c.5 1 .9 1.2 1.9 1.9l.6-.8c.1-.2.4-.2.6-.2l1.4.6c.2.1.4.3.4.5 0 1.1-.9 2.5-1.3 2.8-.4.3-1.8.7-2.7.7-1.6 0-3.3-.8-4.6-2.1-1.3-1.3-2.1-3-2.1-4.6 0-.9.4-2.3.7-2.7.3-.4 1.7-1.3 2.8-1.3z"
    />
  )}
  {icon === 'youtube' && (
    <path
      fill="currentColor"
      d="M21.6 7.2a2.8 2.8 0 0 0-2-2C17.8 4.6 12 4.6 12 4.6s-5.8 0-7.6.6a2.8 2.8 0 0 0-2 2A29.4 29.4 0 0 0 2 12a29.4 29.4 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.6 7.6.6 7.6.6s5.8 0 7.6-.6a2.8 2.8 0 0 0 2-2 29.4 29.4 0 0 0 .4-4.8 29.4 29.4 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"
    />
  )}
</svg>

<style>
  .social-icon__svg {
    display: block;
  }
</style>
