---
import type { SocialIcon as IconId } from '~/data/social';

interface Props {
  icon: IconId;
  size?: number;
}
const { icon, size = 22 } = Astro.props;
---
{icon === 'tiktok' ? (
  <img
    src="/images/social/tiktok.png"
    alt=""
    width={size}
    height={size}
    class="social-icon__img"
    aria-hidden="true"
  />
) : (
  <svg class="social-icon__svg" viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
    {icon === 'whatsapp' && (
      <path
        fill="currentColor"
        d="M12 2a10 10 0 0 0-8.7 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 2a8 8 0 0 1 6.8 12.1l.3.3-.8 2.9 3-0.8.3.3A8 8 0 1 1 12 4zm-1.1 4.2c.2 0 .4.2.5.4l.6 1.4c.1.2 0 .5-.2.6l-.8.6c.5 1 .9 1.2 1.9 1.9l.6-.8c.1-.2.4-.2.6-.2l1.4.6c.2.1.4.3.4.5 0 1.1-.9 2.5-1.3 2.8-.4.3-1.8.7-2.7.7-1.6 0-3.3-.8-4.6-2.1-1.3-1.3-2.1-3-2.1-4.6 0-.9.4-2.3.7-2.7.3-.4 1.7-1.3 2.8-1.3z"
      />
    )}
    {icon === 'youtube' && (
      <path
        fill="currentColor"
        d="M21.6 7.2a2.8 2.8 0 0 0-2-2C17.8 4.6 12 4.6 12 4.6s-5.8 0-7.6.6a2.8 2.8 0 0 0-2 2A29.4 29.4 0 0 0 2 12a29.4 29.4 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.6 7.6.6 7.6.6s5.8 0 7.6-.6a2.8 2.8 0 0 0 2-2 29.4 29.4 0 0 0 .4-4.8 29.4 29.4 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"
      />
    )}
    {icon === 'instagram' && (
      <>
        <path
          fill="currentColor"
          d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm0 2a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H7zm5 2.5A4.5 4.5 0 1 1 7.5 12 4.5 4.5 0 0 1 12 7.5zm0 2A2.5 2.5 0 1 0 14.5 12 2.5 2.5 0 0 0 12 9.5zM17.8 6.2a1 1 0 1 1-1.4 1.4 1 1 0 0 1 1.4-1.4z"
        />
      </>
    )}
    {icon === 'linkedin' && (
      <path
        fill="currentColor"
        d="M6.5 8.5H3.7V20h2.8V8.5zM5.1 3.5a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2zM9.2 8.5H12v1.6h.1c.4-.7 1.4-1.5 2.9-1.5 3.1 0 3.7 2 3.7 4.7V20h-2.8v-5.6c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V20H9.2V8.5z"
      />
    )}
    {icon === 'x' && (
      <path
        fill="currentColor"
        d="M16.3 4h2.8l-6.1 7 7.2 9H14l-4.4-5.7L4.6 20H1.8l6.5-7.5L1.5 4h5.8l4 5.3L16.3 4zm-1 14.2h1.5L7.1 5.7H5.5l9.8 12.5z"
      />
    )}
    {icon === 'google' && (
      <path
        fill="currentColor"
        d="M12 2a7 7 0 0 0-4.9 11.9L4 20l6.2-3.1A7 7 0 1 0 12 2zm0 2a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 1.8c.5 0 1 .1 1.4.3l-1.1 1.1a2.2 2.2 0 0 0-2.5 2.2c0 1.2 1 2.2 2.2 2.2.8 0 1.5-.4 1.8-1.1H12v-1.5h3.4c0 2.3-1.9 4.2-4.3 4.2a4.3 4.3 0 1 1 0-8.6z"
      />
    )}
  </svg>
)}

<style>
  .social-icon__img,
  .social-icon__svg {
    display: block;
  }
  .social-icon__img {
    object-fit: contain;
  }
</style>
