---
import googleReviews from '~/data/google-reviews.json';
import { reviewSnippet, type GoogleReview } from '~/lib/reviews';

/** Four Google reviews highlighted on the homepage — keep in sync with google-reviews.json */
const featured = [
  { name: 'Reena Purewal', type: 'commercial' as const },
  { name: 'Arun Singh', type: 'domestic' as const },
  { name: 'Chris Yewdall', type: 'domestic' as const },
  { name: 'William Senior', type: 'commercial' as const },
];

const all = googleReviews.reviews as GoogleReview[];
const reviews = featured
  .map(({ name, type }) => {
    const source = all.find((r) => r.name === name);
    if (!source) return null;
    return {
      body: reviewSnippet(source.review, 200),
      name: source.name,
      role: source.date,
      type,
    };
  })
  .filter((r): r is NonNullable<typeof r> => r !== null);
---
<section id="reviews" class="section section--ink testimonials" aria-label="What clients say">
  <div class="container">
    <div class="row-meta reveal">
      <div>
        <span class="eyebrow">Reviews</span>
        <h2 class="display h2">
          Quietly proud of <span class="painted-word painted-word--yellow">our reviews.</span>
        </h2>
      </div>
      <div>
        <p class="lead">
          A handful of recent Google reviews — real clients across homes,
          offices, factories and shopfronts in Leicestershire.
        </p>
        <p class="testimonials__more">
          <a class="btn btn--ghost" href="/reviews">Read all Google reviews <span class="arrow">→</span></a>
        </p>
      </div>
    </div>

    <div class="reviews">
      {reviews.map((r, i) => (
        <article class={`review reveal review--${r.type}`} style={`--i:${i}`}>
          <div class="review__stars" aria-label="5 out of 5">
            ★★★★★
          </div>
          <blockquote>
            <p>{r.body}</p>
          </blockquote>
          <footer>
            <strong>{r.name}</strong>
            <span>{r.role}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .review {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    padding: 22px;
    transition-delay: calc(var(--i) * 70ms);
    position: relative;
  }
  .review--commercial { border-top: 4px solid var(--c-yellow); }
  .review--domestic   { border-top: 4px solid var(--c-pink); }
  .review__stars { color: var(--c-yellow); letter-spacing: 2px; font-size: 14px; margin-bottom: 8px; }
  .review blockquote { margin: 0 0 14px; }
  .review p { font-size: 15.5px; color: #ebeae6; line-height: 1.5; margin: 0; }
  .review footer { display: flex; flex-direction: column; }
  .review strong { font-size: 14px; color: #fff; }
  .review span { font-size: 12px; color: #b0aea8; margin-top: 2px; }
  .testimonials__more { margin: 18px 0 0; }

  @media (max-width: 1024px) {
    .reviews { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .reviews { grid-template-columns: 1fr; }
  }
</style>
