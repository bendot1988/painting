---
import GoogleRatingBadge from '~/components/GoogleRatingBadge.astro';
import { contact, thankYouPageHref } from '~/data/contact';
import { quoteFaqs } from '~/data/faqs';
import { normalizeTrailingSlash } from '~/utils/site-url';

interface Props {
  compact?: boolean;
  hideContacts?: boolean;
  /** Where to send the visitor after a successful submit */
  successUrl?: string;
}
const {
  compact = false,
  hideContacts = false,
  successUrl = thankYouPageHref,
} = Astro.props;

/** Path-only action for no-JS fallback */
const netlifyAction = normalizeTrailingSlash(Astro.url.pathname);

---
<section id="quote" class:list={['section', 'quote', compact && 'quote--compact']} aria-label="Get a free quote">
  <div class="container">
    <div class="quote__card reveal">
      <div class="quote__copy">
        <span class="eyebrow eyebrow--inv">Free quote</span>
        <h2 class="display h2">
          Paint — <span class="painted-word painted-word--yellow">done properly.</span>
        </h2>
        <p class="lead">
          We paint commercial and domestic properties across Leicestershire — offices,
          factories, shops, warehouses and homes. Tell us what you need and we'll
          come back the same day.
        </p>

        <div class="quote__faqs" aria-label="Frequently asked questions">
          <h3 class="quote__faqs-title">Quick answers</h3>
          {quoteFaqs.map((item) => (
            <details class="quote__faq">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>

        {!hideContacts && (
          <ul class="quote__contacts">
            <li>
              <a class="quote__contact-link" href={`tel:${contact.phone.tel}`}>
                <span class="quote__lbl">Phone</span>
                <span class="quote__value">{contact.phone.display}</span>
              </a>
            </li>
            <li>
              <a class="quote__contact-link" href={`tel:${contact.freephone.tel}`}>
                <span class="quote__lbl">Freephone</span>
                <span class="quote__value">{contact.freephone.display}</span>
              </a>
            </li>
            <li>
              <a class="quote__contact-link" href={contact.whatsapp.href} target="_blank" rel="noopener noreferrer">
                <span class="quote__lbl">WhatsApp</span>
                <span class="quote__value">{contact.whatsapp.display}</span>
              </a>
            </li>
            <li>
              <a class="quote__contact-link" href={`mailto:${contact.email}`}>
                <span class="quote__lbl">Email</span>
                <span class="quote__value">{contact.email}</span>
              </a>
            </li>
          </ul>
        )}
      </div>

      <form
        class="quote__form"
        name="quote"
        method="POST"
        action={netlifyAction}
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        data-success-url={successUrl}
        aria-label="Quote request form"
      >
        <input type="hidden" name="form-name" value="quote" />
        <p class="visually-hidden" aria-hidden="true">
          <label>Don’t fill this in: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>
        <p class="quote__form-intro">Request a free quote — we'll reply the same day.</p>

        <div class="quote__field">
          <label class="visually-hidden" for="q-name">Your name</label>
          <input
            id="q-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="Your name"
          />
        </div>
        <div class="quote__field">
          <label class="visually-hidden" for="q-phone">Phone number</label>
          <input
            id="q-phone"
            name="phone"
            type="tel"
            required
            autocomplete="tel"
            placeholder="Phone number"
          />
        </div>
        <div class="quote__field quote__field--full">
          <label class="visually-hidden" for="q-email">Email address</label>
          <input
            id="q-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="Email address"
          />
        </div>
        <fieldset class="quote__field quote__field--full quote__checks">
          <legend class="quote__field-label">What kind of job?</legend>
          <label class="quote__check">
            <input type="checkbox" name="job_commercial" value="yes" />
            <span>Commercial</span>
          </label>
          <label class="quote__check">
            <input type="checkbox" name="job_domestic" value="yes" />
            <span>Domestic</span>
          </label>
          <label class="quote__check">
            <input type="checkbox" name="job_not_sure" value="yes" />
            <span>Not sure yet</span>
          </label>
        </fieldset>
        <div class="quote__field quote__field--full">
          <label class="visually-hidden" for="q-msg">Tell us about the project</label>
          <textarea
            id="q-msg"
            name="message"
            rows="4"
            placeholder="Tell us about the project — e.g. office repaint, factory floor to ceiling, or full house interior."
          ></textarea>
        </div>

        <label class="quote__consent quote__field--full">
          <input type="checkbox" name="consent" value="yes" required />
          <span>
            I agree to the <a href="/privacy/">privacy policy</a> and
            <a href="/terms/">terms of service</a>.
          </span>
        </label>

        <p class="quote__error quote__field--full" role="alert" hidden>
          Something went wrong sending your details. Please call us or try again.
        </p>

        <div class="quote__submit quote__field--full">
          <button type="submit" class="btn quote__btn">Send my details <span class="arrow">→</span></button>
        </div>

        <GoogleRatingBadge class="quote__rating quote__field--full" centered />
      </form>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('form.quote__form[data-netlify]').forEach((form) => {
    if (form.dataset.netlifyBound) return;
    form.dataset.netlifyBound = 'true';

    const successUrl = form.dataset.successUrl ?? '/thank-you/';
    const errorEl = form.querySelector('.quote__error');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorEl?.setAttribute('hidden', '');

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute('aria-busy', 'true');
      }

      const body = new URLSearchParams();
      for (const [key, value] of new FormData(form).entries()) {
        body.append(key, String(value));
      }

      try {
        const response = await fetch('/.netlify/functions/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });

        const result = response.ok ? await response.json().catch(() => null) : null;
        if (response.ok && result?.ok) {
          const name = body.get('name');
          const dest = new URL(successUrl, window.location.origin);
          if (name && typeof name === 'string') {
            dest.searchParams.set('name', name.trim());
          }
          window.location.assign(dest.pathname + dest.search + dest.hash);
          return;
        }
      } catch {
        /* show error below */
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.removeAttribute('aria-busy');
      }
      errorEl?.removeAttribute('hidden');
    });
  });
</script>

<style>
  .quote {
    padding-top: clamp(72px, 9vw, 130px);
    padding-bottom: clamp(72px, 9vw, 130px);
  }
  .quote--compact {
    padding-top: 0;
    padding-bottom: clamp(48px, 6vw, 80px);
  }
  .quote__card {
    position: relative;
    background: var(--c-ink);
    color: var(--c-paper);
    border-radius: 28px;
    padding: clamp(28px, 4vw, 56px);
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(28px, 4vw, 56px);
    overflow: hidden;
    isolation: isolate;
  }
  .quote__card::before {
    content: "";
    position: absolute;
    right: -120px;
    top: -120px;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255, 214, 10, 0.45), transparent 70%);
    z-index: -1;
  }
  .quote__card::after {
    content: "";
    position: absolute;
    left: -100px;
    bottom: -100px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(236, 0, 140, 0.3), transparent 70%);
    z-index: -1;
  }
  .quote__copy h2 {
    color: #fff;
    margin: 14px 0 14px;
    max-width: 14ch;
  }
  .quote__copy .lead {
    color: #cfcdc8;
    max-width: 42ch;
    margin: 0;
  }
  .eyebrow--inv { color: var(--c-yellow); }

  .quote__faqs {
    margin-top: 28px;
  }
  .quote__faqs-title {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-yellow);
  }
  .quote__faq {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .quote__faq:last-of-type {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .quote__faq summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 28px 14px 0;
    font-weight: 600;
    font-size: 15px;
    color: #fff;
    position: relative;
  }
  .quote__faq summary::-webkit-details-marker { display: none; }
  .quote__faq summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 20px;
    font-weight: 400;
    color: var(--c-yellow);
    line-height: 1;
  }
  .quote__faq[open] summary::after {
    content: "−";
  }
  .quote__faq p {
    margin: 0 0 14px;
    padding-right: 8px;
    font-size: 14.5px;
    line-height: 1.5;
    color: #cfcdc8;
  }

  .quote__contacts {
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  .quote__contact-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 14px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .quote__contact-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 214, 10, 0.35);
  }
  .quote__lbl {
    font-size: 11px;
    font-weight: 700;
    color: #b0aea8;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .quote__value {
    color: #fff;
    font-weight: 600;
    font-size: 14.5px;
  }

  .quote__form {
    background: #fff;
    color: var(--c-ink);
    border-radius: 22px;
    padding: clamp(22px, 3vw, 30px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    align-self: start;
    box-shadow: var(--shadow-md);
  }
  .quote__form-intro {
    grid-column: 1 / -1;
    margin: 0 0 4px;
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
  }
  .quote__success {
    grid-column: 1 / -1;
    margin: 0 0 12px;
    padding: 14px 16px;
    border-radius: 12px;
    background: rgba(126, 211, 33, 0.12);
    border: 1px solid rgba(126, 211, 33, 0.35);
    color: var(--c-ink);
    font-size: 15px;
    line-height: 1.5;
  }
  .quote__error {
    margin: 0;
    padding: 14px 16px;
    border-radius: 12px;
    background: rgba(212, 38, 44, 0.08);
    border: 1px solid rgba(212, 38, 44, 0.35);
    color: var(--c-ink);
    font-size: 14.5px;
    line-height: 1.5;
  }
  .quote__btn:disabled {
    opacity: 0.65;
    cursor: wait;
  }
  .quote__field {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .quote__field--full {
    grid-column: 1 / -1;
  }
  .quote__field-label {
    display: block;
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-stone);
  }
  .quote__field input,
  .quote__field textarea {
    font: inherit;
    width: 100%;
    padding: 14px 16px;
    border: 1.5px solid rgba(14, 14, 16, 0.12);
    border-radius: 12px;
    background: var(--c-paper);
    color: var(--c-ink);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .quote__field input::placeholder,
  .quote__field textarea::placeholder {
    color: var(--c-stone);
    opacity: 1;
  }
  .quote__field input:focus,
  .quote__field textarea:focus {
    outline: 0;
    border-color: var(--c-red);
    box-shadow: 0 0 0 4px rgba(212, 38, 44, 0.12);
  }

  .quote__checks {
    border: 0;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .quote__checks .quote__field-label {
    margin-bottom: 4px;
    padding: 0;
  }
  .quote__check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 500;
    color: var(--c-graphite);
    cursor: pointer;
  }
  .quote__check input {
    width: 18px;
    height: 18px;
    margin: 0;
    flex-shrink: 0;
    accent-color: var(--c-red);
  }

  .quote__consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--c-graphite);
    cursor: pointer;
  }
  .quote__consent input {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    flex-shrink: 0;
    accent-color: var(--c-red);
  }
  .quote__consent a {
    color: var(--c-red);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .quote__submit {
    margin-top: 4px;
  }
  .quote__rating {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(14, 14, 16, 0.08);
  }
  .quote__btn {
    width: 100%;
    justify-content: center;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 980px) {
    .quote__card {
      grid-template-columns: 1fr;
    }
    .quote__copy h2 {
      max-width: none;
    }
  }
  @media (max-width: 540px) {
    .quote__form {
      grid-template-columns: 1fr;
    }
    .quote__contacts {
      grid-template-columns: 1fr;
    }
  }
</style>
