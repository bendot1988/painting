---
---
<section id="quote" class="section quote" aria-label="Get a free quote">
  <div class="container">
    <div class="quote__card reveal">
      <div class="quote__copy">
        <span class="eyebrow eyebrow--inv">Free quote</span>
        <h2 class="display h2">
          Tell us what needs <span class="painted-word painted-word--yellow">a fresh coat.</span>
        </h2>
        <p class="lead">
          Drop a few details and we'll come back the same day with next steps.
          Prefer to talk? Call <a href="tel:+441162914746">0116 291 4746</a> or
          freephone <a href="tel:+448000096694">0800 0096 694</a> — 7 days a week,
          6 am to 5 pm.
        </p>

        <ul class="quote__contacts">
          <li>
            <span class="quote__lbl">Phone</span>
            <a href="tel:+441162914746">0116 291 4746</a>
          </li>
          <li>
            <span class="quote__lbl">Freephone</span>
            <a href="tel:+448000096694">0800 0096 694</a>
          </li>
          <li>
            <span class="quote__lbl">WhatsApp</span>
            <a href="https://wa.me/447548971520" target="_blank" rel="noopener">07548 971 520</a>
          </li>
          <li>
            <span class="quote__lbl">Email</span>
            <a href="mailto:info@as-painting.co.uk">info@as-painting.co.uk</a>
          </li>
          <li>
            <span class="quote__lbl">Hours</span>
            <span>Mon–Sun · 6 am – 5 pm</span>
          </li>
          <li>
            <span class="quote__lbl">Base</span>
            <span>Leicester · LE19 4DG</span>
          </li>
        </ul>
      </div>

      <form class="quote__form" action="mailto:info@as-painting.co.uk" method="post" enctype="text/plain" aria-label="Quote request form">
        <div class="quote__field">
          <label for="q-name">Your name</label>
          <input id="q-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="quote__field">
          <label for="q-phone">Phone</label>
          <input id="q-phone" name="phone" type="tel" required autocomplete="tel" />
        </div>
        <div class="quote__field quote__field--full">
          <label for="q-email">Email</label>
          <input id="q-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="quote__field quote__field--full">
          <label>What kind of job?</label>
          <div class="quote__radios" role="radiogroup">
            <label><input type="radio" name="type" value="commercial" checked /> <span>Commercial</span></label>
            <label><input type="radio" name="type" value="domestic" /> <span>Domestic</span></label>
            <label><input type="radio" name="type" value="not-sure" /> <span>Not sure yet</span></label>
          </div>
        </div>
        <div class="quote__field quote__field--full">
          <label for="q-msg">Tell us about the project</label>
          <textarea id="q-msg" name="message" rows="4" placeholder="e.g. 3-bed semi, full interior, magnolia to off-white. Or: 800 m² warehouse, two coats, weekend work."></textarea>
        </div>
        <div class="quote__field quote__field--full quote__submit">
          <button type="submit" class="btn">Send my details <span class="arrow">→</span></button>
          <small>By submitting you consent to us getting in touch about your enquiry.</small>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .quote { padding-top: clamp(72px, 9vw, 130px); padding-bottom: clamp(72px, 9vw, 130px); }
  .quote__card {
    position: relative;
    background: var(--c-ink);
    color: var(--c-paper);
    border-radius: 28px;
    padding: clamp(28px, 4vw, 60px);
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(28px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
  }
  .quote__card::before {
    content: ""; position: absolute; right: -120px; top: -120px;
    width: 380px; height: 380px; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,214,10,0.5), transparent 70%);
    z-index: -1;
  }
  .quote__card::after {
    content: ""; position: absolute; left: -100px; bottom: -100px;
    width: 320px; height: 320px; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(236,0,140,0.35), transparent 70%);
    z-index: -1;
  }
  .quote__copy h2 { color: #fff; margin: 14px 0 16px; }
  .quote__copy a { color: var(--c-yellow); border-bottom: 1px solid currentColor; }

  .eyebrow--inv { color: var(--c-yellow); }

  .quote__contacts {
    list-style: none; padding: 0; margin: 24px 0 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 22px;
  }
  .quote__contacts li { display: flex; flex-direction: column; gap: 2px; }
  .quote__lbl {
    font-size: 11px; font-weight: 700;
    color: #b0aea8;
    text-transform: uppercase; letter-spacing: 0.12em;
  }
  .quote__contacts a, .quote__contacts span:not(.quote__lbl) {
    color: #fff; font-weight: 600; font-size: 15px; border-bottom: 0;
  }

  /* Form */
  .quote__form {
    background: #fff;
    color: var(--c-ink);
    border-radius: 22px;
    padding: 26px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    align-self: start;
    box-shadow: var(--shadow-md);
  }
  .quote__field { display: flex; flex-direction: column; gap: 6px; }
  .quote__field--full { grid-column: 1 / -1; }
  .quote__field label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--c-stone);
  }
  .quote__field input, .quote__field textarea {
    font: inherit;
    padding: 12px 14px;
    border: 1.5px solid rgba(14,14,16,0.12);
    border-radius: 10px;
    background: var(--c-paper);
    color: var(--c-ink);
    transition: border-color .2s, box-shadow .2s;
  }
  .quote__field input:focus, .quote__field textarea:focus {
    outline: 0; border-color: var(--c-red);
    box-shadow: 0 0 0 4px rgba(212,38,44,0.15);
  }

  .quote__radios { display: flex; gap: 8px; flex-wrap: wrap; }
  .quote__radios label {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1.5px solid rgba(14,14,16,0.12);
    cursor: pointer; font-size: 14px; font-weight: 500;
    background: var(--c-paper);
    text-transform: none; letter-spacing: 0;
  }
  .quote__radios input { accent-color: var(--c-red); margin: 0; }
  .quote__radios label:has(input:checked) {
    border-color: var(--c-red); background: #fff;
    box-shadow: inset 0 0 0 2px var(--c-red);
  }

  .quote__submit { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 4px; }
  .quote__submit small { color: var(--c-stone); font-size: 12px; flex: 1; min-width: 200px; }

  @media (max-width: 980px) {
    .quote__card { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    .quote__form { grid-template-columns: 1fr; }
    .quote__contacts { grid-template-columns: 1fr; }
  }
</style>
