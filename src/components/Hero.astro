---
---
<section id="top" class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="eyebrow">Leicester · Est. 2010 · Commercial &amp; Domestic</span>

      <h1 class="display h1">
        Bold colour.<br/>
        Sharp lines.<br/>
        <span class="painted-word">No mess.</span>
      </h1>

      <p class="lead">
        Trusted painting &amp; decorating contractors for factories, offices,
        retail fit-outs and homes across Leicestershire. Big jobs, small jobs —
        we keep it moving and we keep it tidy.
      </p>

      <div class="hero__ctas">
        <a class="btn" href="#commercial">
          Commercial work <span class="arrow">→</span>
        </a>
        <a class="btn btn--ghost" href="#domestic">
          Domestic work <span class="arrow">→</span>
        </a>
      </div>

      <ul class="hero__bullets" aria-label="Why pick A.S Painting">
        <li><span aria-hidden="true">●</span> Fully insured &amp; vetted team</li>
        <li><span aria-hidden="true">●</span> Out-of-hours commercial</li>
        <li><span aria-hidden="true">●</span> Free, fixed-price quotes</li>
      </ul>
    </div>

    <div class="hero__media">
      <div class="hero__frame">
        <img
          src="/images/work/proj-04.jpg"
          alt="A.S Painting Contractors branded van outside a domestic property with a painter on a ladder"
          width="900" height="1200"
          fetchpriority="high"
        />
      </div>

      <!-- Floating tape badge (outside frame so it isn't clipped) -->
      <div class="hero__tape" aria-hidden="true">
        <span>Keep it moving.</span>
      </div>

      <!-- Floating stat card -->
      <div class="hero__chip">
        <div class="hero__chip-num">15<span>+</span></div>
        <div>
          <div class="hero__chip-h">years on the tools</div>
          <div class="hero__chip-s">Leicester · Leicestershire · East Midlands</div>
        </div>
      </div>

      <!-- Decorative paint splatter behind frame -->
      <svg class="hero__splat" viewBox="0 0 600 600" aria-hidden="true">
        <g>
          <circle cx="120" cy="140" r="56" fill="#ffd60a"/>
          <circle cx="60"  cy="220" r="20" fill="#ffd60a"/>
          <circle cx="200" cy="80"  r="14" fill="#ffd60a"/>
          <path d="M310 90 q40 -50 90 -10 q60 50 -10 90 q-50 30 -90 -20 q-30 -40 10 -60z" fill="#ec008c"/>
          <circle cx="430" cy="60"  r="12" fill="#ec008c"/>
          <circle cx="80"  cy="430" r="44" fill="#7ed321"/>
          <circle cx="36"  cy="500" r="10" fill="#7ed321"/>
          <circle cx="160" cy="510" r="20" fill="#d4262c"/>
          <circle cx="230" cy="556" r="8"  fill="#d4262c"/>
          <circle cx="500" cy="500" r="44" fill="#1f6feb" opacity=".18"/>
        </g>
      </svg>
    </div>
  </div>

  <!-- Painted-stripe divider -->
  <div class="hero__stripe" aria-hidden="true">
    <div></div><div></div><div></div><div></div><div></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(36px, 5vw, 72px);
    padding-bottom: clamp(56px, 8vw, 110px);
    background:
      radial-gradient(1200px 600px at 92% -20%, rgba(255,214,10,0.18), transparent 60%),
      radial-gradient(900px 600px at -10% 120%, rgba(236,0,140,0.12), transparent 65%),
      var(--bg);
    overflow: clip;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  .hero__copy h1 {
    margin: 18px 0 22px;
  }
  .hero__copy h1 .painted-word { z-index: 0; }
  .hero__ctas {
    display: flex; flex-wrap: wrap; gap: 14px;
    margin: 26px 0 28px;
  }
  .hero__bullets {
    list-style: none; padding: 0; margin: 0;
    display: flex; gap: 24px; flex-wrap: wrap;
    color: var(--c-graphite);
    font-size: 14px;
  }
  .hero__bullets li { display: flex; align-items: center; gap: 8px; }
  .hero__bullets span { color: var(--c-red); }

  .hero__media {
    position: relative;
    isolation: isolate;
  }
  .hero__frame {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4 / 5;
    transform: rotate(2deg);
    transition: transform .6s var(--ease);
  }
  .hero__frame:hover { transform: rotate(0deg); }
  .hero__frame img { width: 100%; height: 100%; object-fit: cover; }
  .hero__splat {
    position: absolute;
    inset: -8% -10% auto auto;
    width: 78%;
    z-index: -1;
    filter: blur(0.2px);
    transform: rotate(-12deg);
  }

  .hero__tape {
    position: absolute;
    top: 6%; left: -6%;
    background: var(--c-yellow);
    color: var(--c-ink);
    padding: 10px 22px;
    transform: rotate(-6deg);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 22px rgba(14,14,16,0.22);
    z-index: 2;
  }
  .hero__tape::before, .hero__tape::after {
    content: ""; position: absolute; top: 4px; bottom: 4px; width: 8px;
    background: rgba(0,0,0,0.06);
  }
  .hero__tape::before { left: 0; }
  .hero__tape::after { right: 0; }

  .hero__chip {
    position: absolute;
    bottom: 24px; right: -28px;
    background: #fff;
    padding: 14px 18px 14px 14px;
    border-radius: 18px;
    box-shadow: var(--shadow-md);
    display: flex; align-items: center; gap: 14px;
    transform: rotate(-3deg);
  }
  .hero__chip-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 44px;
    line-height: 1;
    color: var(--c-red);
    letter-spacing: -0.03em;
  }
  .hero__chip-num span { font-size: 24px; vertical-align: super; color: var(--c-ink); }
  .hero__chip-h { font-weight: 700; font-size: 13px; color: var(--c-ink); }
  .hero__chip-s { font-size: 12px; color: var(--c-stone); margin-top: 2px; }

  /* Painted stripe divider — five colour bars with frayed-edge mask */
  .hero__stripe {
    margin-top: clamp(40px, 6vw, 80px);
    height: 14px;
    display: flex;
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 14' preserveAspectRatio='none'><path d='M0 4 C 60 -2, 120 8, 200 4 S 360 12, 460 5 S 640 1, 740 6 S 900 12, 1000 5 L 1000 14 L 0 14 Z' fill='black'/></svg>");
            mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 14' preserveAspectRatio='none'><path d='M0 4 C 60 -2, 120 8, 200 4 S 360 12, 460 5 S 640 1, 740 6 S 900 12, 1000 5 L 1000 14 L 0 14 Z' fill='black'/></svg>");
    -webkit-mask-size: 100% 100%; mask-size: 100% 100%;
    -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
  }
  .hero__stripe > div { flex: 1; }
  .hero__stripe > div:nth-child(1) { background: var(--c-red); }
  .hero__stripe > div:nth-child(2) { background: var(--c-yellow); }
  .hero__stripe > div:nth-child(3) { background: var(--c-lime); }
  .hero__stripe > div:nth-child(4) { background: var(--c-pink); }
  .hero__stripe > div:nth-child(5) { background: var(--c-ink); }

  @media (max-width: 980px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__media { order: -1; max-width: 520px; margin: 0 auto; }
    .hero__chip { right: -10px; }
  }
  @media (max-width: 520px) {
    .hero__chip { transform: rotate(0); right: 8px; bottom: 8px; padding: 10px 12px; gap: 10px; }
    .hero__chip-num { font-size: 32px; }
    .hero__tape { font-size: 14px; padding: 8px 14px; }
  }
</style>
