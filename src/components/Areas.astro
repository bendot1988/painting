---
import { areaNames } from '~/data/areas';

const loop = [...areaNames, ...areaNames];
const emblemSrc = '/images/brand/leicester-emblem.png';
const emblemAlt =
  'A.S Painting Contractors emblem featuring Leicester landmarks including King Power Stadium, the Clock Tower and Leicester Cathedral, with painting equipment and a work van';
---
<section id="areas" class="section areas" aria-label="Areas covered">
  <div class="container">
    <div class="areas__intro reveal">
      <div class="areas__copy">
        <span class="eyebrow">Where we work</span>
        <h2 class="display h2">
          Leicester &amp; <span class="painted-word painted-word--lime">Leicestershire.</span>
        </h2>
        <p class="lead">
          Based in the south of the city, we cover Leicestershire end-to-end,
          plus most of the East Midlands for commercial contracts. If you're not
          sure, ask. We probably do.
        </p>
        <p class="areas__more">
          <a class="btn btn--ghost" href="/areas">View all areas covered <span class="arrow">→</span></a>
        </p>
      </div>
      <figure class="areas__emblem">
        <img
          src={emblemSrc}
          alt={emblemAlt}
          width={640}
          height={640}
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </div>

  <div class="areas__marquee" aria-hidden="true">
    <div class="marquee">
      {loop.map((a, i) => (
        <span class="areas__chip">
          <span class="areas__dot" data-i={i % 5}></span>
          {a}
        </span>
      ))}
    </div>
  </div>
  <div class="areas__marquee" aria-hidden="true">
    <div class="marquee marquee--reverse">
      {loop.slice().reverse().map((a, i) => (
        <span class="areas__chip areas__chip--alt">
          <span class="areas__dot" data-i={i % 5}></span>
          {a}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .areas {
    padding-top: clamp(72px, 8vw, 110px);
    padding-bottom: clamp(72px, 8vw, 110px);
    overflow: hidden;
    background: var(--bg-alt);
  }
  .areas__intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 380px);
    align-items: center;
    gap: clamp(32px, 5vw, 64px);
    margin-bottom: clamp(40px, 5vw, 56px);
  }
  .areas__copy {
    min-width: 0;
  }
  .areas__more {
    margin-top: 20px;
  }
  .areas__emblem {
    margin: 0;
    line-height: 0;
    justify-self: center;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1;
    border-radius: 24px;
    overflow: hidden;
    background: #0e0e10;
    box-shadow:
      0 24px 48px rgba(14, 14, 16, 0.18),
      0 0 0 1px rgba(14, 14, 16, 0.06);
  }
  .areas__emblem img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .areas__marquee {
    padding: 8px 0;
  }
  .areas__chip {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 26px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgba(14, 14, 16, 0.08);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 2.2vw, 30px);
    color: var(--c-ink);
    white-space: nowrap;
  }
  .areas__chip--alt {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }
  .areas__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-red);
  }
  .areas__dot[data-i='1'] {
    background: var(--c-yellow);
  }
  .areas__dot[data-i='2'] {
    background: var(--c-lime);
  }
  .areas__dot[data-i='3'] {
    background: var(--c-pink);
  }
  .areas__dot[data-i='4'] {
    background: var(--c-blue);
  }

  @media (max-width: 900px) {
    .areas__intro {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .areas__emblem {
      order: -1;
      width: 100vw;
      max-width: none;
      margin-inline: calc(50% - 50vw);
      margin-bottom: clamp(28px, 6vw, 40px);
      border-radius: 0;
      box-shadow: none;
    }
    .areas__copy {
      padding-top: 0;
    }
  }
</style>
