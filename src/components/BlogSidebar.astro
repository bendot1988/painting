---
import GoogleRatingBadge from '~/components/GoogleRatingBadge.astro';
import googleReviews from '~/data/google-reviews.json';
import { reviewSnippet, type GoogleReview } from '~/lib/reviews';
import { contact, quotePageHref } from '~/data/contact';
import '~/styles/blog-ui.css';

const latestReviews = (googleReviews.reviews as GoogleReview[]).slice(0, 2);

const services = [
  { href: '/commercial/', label: 'Commercial painting' },
  { href: '/domestic/', label: 'Domestic painting' },
  { href: '/housing-association-painting/', label: 'Housing associations' },
  { href: '/work/', label: 'Recent work' },
  { href: '/areas/', label: 'Areas covered' },
  { href: '/how-we-work/', label: 'How we work' },
];
---
<aside class="blog-sidebar" aria-label="Related links and reviews">
  <div class="blog-ui-card">
    <h2 class="blog-ui-card__title">Our services</h2>
    <ul class="blog-sidebar__links">
      {services.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </div>

  <div class="blog-ui-card">
    <h2 class="blog-ui-card__title">Google reviews</h2>
    <GoogleRatingBadge />
    <ul class="blog-sidebar__reviews">
      {latestReviews.map((item) => (
        <li class="blog-sidebar__review">
          <div class="blog-sidebar__stars" aria-hidden="true">★★★★★</div>
          <p>{reviewSnippet(item.review, 100)}</p>
          <footer>
            <strong>{item.name}</strong>
          </footer>
        </li>
      ))}
    </ul>
    <a class="blog-sidebar__more" href="/reviews/">All reviews <span class="arrow">→</span></a>
  </div>

  <div class="blog-ui-card blog-ui-card--dark">
    <h2 class="blog-ui-card__title">Get a quote</h2>
    <p class="blog-sidebar__cta-text">Free fixed-price quotes — same-day reply Mon–Sun, 6am–5pm.</p>
    <a class="btn blog-sidebar__btn" href={quotePageHref}>
      Request a quote <span class="arrow">→</span>
    </a>
    <p class="blog-sidebar__contact">
      <a href={`tel:${contact.phone.tel}`}>{contact.phone.display}</a>
      <a href={`mailto:${contact.email}`}>{contact.email}</a>
    </p>
  </div>
</aside>

<style>
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .blog-sidebar__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .blog-sidebar__links a {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: none;
  }
  .blog-sidebar__links a:hover {
    color: var(--c-red);
  }
  .blog-sidebar :global(.google-rating) {
    margin-bottom: 14px;
  }
  .blog-sidebar__reviews {
    list-style: none;
    margin: 0 0 12px;
    padding: 0;
    display: grid;
    gap: 12px;
  }
  .blog-sidebar__review {
    padding-top: 12px;
    border-top: 1px solid rgba(14, 14, 16, 0.08);
  }
  .blog-sidebar__review:first-child {
    padding-top: 0;
    border-top: none;
  }
  .blog-sidebar__stars {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--c-yellow);
    margin-bottom: 4px;
  }
  .blog-sidebar__review p {
    margin: 0 0 6px;
    font-size: 13px;
    line-height: 1.45;
    color: var(--c-graphite);
  }
  .blog-sidebar__review footer strong {
    font-size: 12px;
    color: var(--c-ink);
  }
  .blog-sidebar__more {
    font-size: 14px;
    font-weight: 700;
    color: var(--c-red);
    text-decoration: none;
  }
  .blog-sidebar__more:hover {
    text-decoration: underline;
  }
  .blog-sidebar__cta-text {
    margin: 0 0 14px;
    font-size: 14px;
    line-height: 1.5;
    color: #cfcdc8;
  }
  .blog-sidebar__btn {
    width: 100%;
    justify-content: center;
    margin-bottom: 12px;
  }
  .blog-sidebar__contact {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 14px;
  }
  .blog-sidebar__contact a {
    color: #cfcdc8;
    font-weight: 600;
    text-decoration: none;
  }
  .blog-sidebar__contact a:hover {
    color: var(--c-yellow);
  }
</style>
